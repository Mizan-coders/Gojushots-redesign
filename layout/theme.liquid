<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'ecom_header' -%}
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Thin.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Light.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Regular.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Medium.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Bold.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-ExtraBold.woff2' | asset_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ 'Ratch-Black.woff2' | asset_url }}" type="font/woff2" crossorigin>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% comment %} 
     {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%} 
     {% endcomment %}

    <title>
      {{ page_title }}
      {%- if current_tags %}
        &ndash; tagged "{{ current_tags | join: ', ' }}"
      {%- endif -%}
      {%- if current_page != 1 %}
        &ndash; Page {{ current_page -}}
      {%- endif -%}
      {%- unless page_title contains shop.name %}
        &ndash; {{ shop.name -}}
      {%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}

    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {% style %}
      .product__info-container {
        transition: unset!important;
      }
        .product__info-container.fixed {
          position:fixed;
          top:50px;

        }
{% comment %}
Disabled Shopify font-face output — using custom Ratch font
{{ settings.type_body_font | font_face: font_display: 'swap' }}
{{ body_font_bold | font_face: font_display: 'swap' }}
{{ body_font_italic | font_face: font_display: 'swap' }}
{{ body_font_bold_italic | font_face: font_display: 'swap' }}
{{ settings.type_header_font | font_face: font_display: 'swap' }}
{% endcomment %}

        /* ===== Ratch Font Family ===== */
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Thin.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Thin.woff" | asset_url }}') format('woff');
  font-weight: 100;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Light.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Light.woff" | asset_url }}') format('woff');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Regular.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Regular.woff" | asset_url }}') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Medium.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Medium.woff" | asset_url }}') format('woff');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Bold.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Bold.woff" | asset_url }}') format('woff');
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-ExtraBold.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-ExtraBold.woff" | asset_url }}') format('woff');
  font-weight: 800;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Ratch';
  src: url('{{ "Ratch-Black.woff2" | asset_url }}') format('woff2'),
       url('{{ "Ratch-Black.woff" | asset_url }}') format('woff');
  font-weight: 900;
  font-style: normal;
  font-display: swap;
}


