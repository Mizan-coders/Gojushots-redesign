            if (pack == compare_pack) {
              vm.toggleAddButton(false, addButtonText);
              $('.shotcount-error').hide();
            } else {
              $('.shotcount-error').show()
              $('.shotcount-error').find('.maxShot').text(pack);
              vm.toggleAddButton(true, addButtonText);
            }
          });

          $('[name="options[Pack of]"]').on('change', function() {
            let pack = $('[name="options[Pack of]"]').val();
            pack = parseInt(pack.replace(/[A-Za-z\s+]*/g, ''));
            console.log('pack-', pack);
            let compare_pack = 0;
            $('[data-properties]').each(function(ii, ee) {
              compare_pack += parseInt($(ee).val());
            });
            console.log('compare_pack-', compare_pack);
            if (pack == compare_pack) {
              vm.toggleAddButton(false, addButtonText);
              $('.shotcount-error').hide();
            } else {
              $('.shotcount-error').show()
              $('.shotcount-error').find('.maxShot').text(pack);
              vm.toggleAddButton(true, addButtonText);
            }
          });

          console.log(productForm);
        }

      })
