
{% style %}
.single-post-body-box img {
    height: 338px;
    width: 100%;
}
{% endstyle %}
<div class="overflow-hidden">
    <!--============================== content-container Start ==============================-->
    <div class="single-post-container">
        <div class="container">
            <div class="row">
                <div class="col-md-8 offset-md-2">
                    <div class="single-post-title-box">
                        
                        <!--<span>Health Advice</span>-->
                        <h3>{{ article.title | escape }}</h3>
                        <p>By: {{ article.author }} | {{ article.published_at | time_tag: format: 'date' }}</p>
                        <ul class="social-links-list d-flex align-items-center justify-content-center">
                            <li>
                                <a target="_blank" title="{{ article.title }}" href="http://www.facebook.com/sharer.php?u=/node/[nid]&p=[{{ article.title | handleize }}]"><i class="fab fa-facebook-square"></i></a>
                            </li>
                            <li>
                                <a target="_blank" title="{{ article.title }}" href="http://pinterest.com/pin/create/button/?url=/node/[nid]&description=[{{ article.title| handleize }}]"><i class="fab fa-pinterest"></i></a>
                            </li>
                            <li>
                                <a target="_blank" title="{{ article.title }}" href="//twitter.com/share?text={{ article.title }}&amp;url={{ article.url }}&amp;source=webclient"><i class="fab fa-twitter"></i></a>
                            </li>
                        </ul>
                    </div>
                    <div class="single-post-body-box">
                        
                         {{ article.content }}
                         {% comment %}
                        <div class="box-pink-text text-white">
                            <h4>Reference List:</h4>
                            <p>
                                Seppala, E., Bradley, C., & Goldstein, M.R. (2020). Research: Why Breathing Is So Effective at Reducing Stress. Harvard Business Review.
                                https://hbr.org/2020/09/research-why-breathing-is-so-effective-at-reducing-stress
                            </p>
                        </div>
                        {% endcomment %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--============================== content-container End ==============================-->
    <!--============================== content-container Start ==============================-->
