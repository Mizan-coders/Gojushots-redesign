        },
        {
          "type": "row",
          "settings": {
            "feature": "No Sugar Added",
            "goju_text": "Clean energy without the spike and crash cycle.",
            "competitor_text": "High sugar content causes energy spikes and inevitable crashes."
          }
        },
        {
          "type": "row",
          "settings": {
