{%- style -%}
  .wg-{{ section.id }} {
    {%- if section.settings.bg_image != blank -%}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-color: {{ section.settings.fallback_bg_color | default: '#EDE4D1' }};
    {%- else -%}
      background: {{ section.settings.fallback_bg_color | default: '#EDE4D1' }};
    {%- endif -%}
    position: relative;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 40px;
    padding-right: 40px;
  }
  @media screen and (min-width: 750px) {
    .wg-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Dark overlay (only when bg image is set) ── */
  {%- if section.settings.bg_image != blank -%}
  .wg-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 0;
    pointer-events: none;
  }
  {%- endif -%}

  /* ── Inner ── */
  .wg-{{ section.id }} .wg__inner {
    max-width: 920px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  .wg-{{ section.id }} .wg__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .wg-{{ section.id }} .wg__eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--goju-accent);
    margin-bottom: 10px;
  }
  .wg-{{ section.id }} .wg__title {
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 900;
    color: white;
    margin: 0;
    line-height: 1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }
  .wg-{{ section.id }} .wg__title em {
    font-style: italic;
    color: var(--goju-accent);
    font-weight: 700;
    text-transform: none;
    letter-spacing: 0;
    margin-right: 6px;
  }

  /* ── Card ── */
  .wg-{{ section.id }} .wg__card {
    background: var(--goju-page-bg, #f5f0e8);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 8px 40px rgba(0,0,0,0.06);
  }

  /* ── Column grid shared ── */
  .wg-{{ section.id }} .wg__head-row,
  .wg-{{ section.id }} .wg__row {
    display: grid;
    grid-template-columns: 220px 1fr 1fr;
  }
  .wg-{{ section.id }} .wg__cta-row {
    display: grid;
    grid-template-columns: 220px 1fr 1fr;
  }

  /* ── Head row ── */
  .wg-{{ section.id }} .wg__head-row {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .wg-{{ section.id }} .wg__head-cell {
    padding: 26px 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wg-{{ section.id }} .wg__head-cell--feature {
    background: var(--goju-page-bg, #f5f0e8);
    justify-content: flex-start;
  }
  .wg-{{ section.id }} .wg__head-cell--goju {
    background: white;
    border-left: 1px solid rgba(0,0,0,0.08);
    border-right: 1px solid rgba(0,0,0,0.08);
  }
  .wg-{{ section.id }} .wg__head-cell--competitor {
    background: var(--goju-page-bg, #f5f0e8);
    font-size: 15px;
    font-weight: 600;
    color: rgba(0,0,0,0.38);
    text-align: center;
    line-height: 1.3;
  }
  .wg-{{ section.id }} .wg__logo {
    height: 34px;
    width: auto;
    display: block;
  }
  .wg-{{ section.id }} .wg__logo-text {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.5px;
    color: #0a0a0a;
  }

  /* ── Comparison rows ── */
  .wg-{{ section.id }} .wg__row {
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .wg-{{ section.id }} .wg__row:last-of-type {
    border-bottom: none;
  }
  .wg-{{ section.id }} .wg__cell {
    padding: 20px 28px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .wg-{{ section.id }} .wg__cell--feature {
    background: var(--goju-page-bg, #f5f0e8);
    font-size: 14px;
    font-weight: 700;
    color: #0a0a0a;
    line-height: 1.4;
    align-items: center;
  }
  .wg-{{ section.id }} .wg__cell--goju {
    background: white;
    border-left: 1px solid rgba(0,0,0,0.08);
    border-right: 1px solid rgba(0,0,0,0.08);
    font-size: 13px;
    color: #1a1a1a;
    line-height: 1.55;
  }
  .wg-{{ section.id }} .wg__cell--competitor {
    background: var(--goju-page-bg, #f5f0e8);
    font-size: 13px;
    color: rgba(0,0,0,0.48);
    line-height: 1.55;
  }

  /* ── Icons ── */
  .wg-{{ section.id }} .wg__icon {
    flex-shrink: 0;
    margin-top: 1px;
    display: block;
  }

  /* ── CTA row ── */
  .wg-{{ section.id }} .wg__cta-cell--feature {
    background: var(--goju-page-bg, #f5f0e8);
  }
  .wg-{{ section.id }} .wg__cta-cell--goju {
    grid-column: 2;
    background: white;
    border-left: 1px solid rgba(0,0,0,0.08);
    border-right: 1px solid rgba(0,0,0,0.08);
    border-top: 1px solid rgba(0,0,0,0.08);
    padding: 20px 24px;
  }
  .wg-{{ section.id }} .wg__cta-cell--competitor {
    background: var(--goju-page-bg, #f5f0e8);
  }
  .wg-{{ section.id }} .wg__cta-btn {
    display: block;
    width: 100%;
    box-sizing: border-box;
    background: #1F1A17;
    color: #F7F1E4;
    text-align: center;
    padding: 16px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .wg-{{ section.id }} .wg__cta-btn:hover {
    background: #6B5E52;
    transform: translateY(-1px);
    color: #F7F1E4;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .wg-{{ section.id }} {
      padding-left: 12px;
      padding-right: 12px;
    }
    .wg-{{ section.id }} .wg__header {
      margin-bottom: 32px;
    }
    .wg-{{ section.id }} .wg__head-row,
    .wg-{{ section.id }} .wg__row,
    .wg-{{ section.id }} .wg__cta-row {
      grid-template-columns: 75px 1fr 1fr;
    }
    .wg-{{ section.id }} .wg__cell--feature {
      font-size: 11px;
    }
    .wg-{{ section.id }} .wg__head-cell,
    .wg-{{ section.id }} .wg__cell {
      padding: 10px 8px;
    }
    .wg-{{ section.id }} .wg__cell--goju,
    .wg-{{ section.id }} .wg__cell--competitor {
      font-size: 12px;
      gap: 6px;
    }
    .wg-{{ section.id }} .wg__cta-cell--goju {
      grid-column: 2;
      padding: 12px 10px;
    }
    .wg-{{ section.id }} .wg__cta-btn {
      font-size: 11px;
      padding: 12px 8px;
      letter-spacing: 0.02em;
    }
  }
{%- endstyle -%}

<section class="wg-{{ section.id }}">
  <div class="wg__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="wg__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="wg__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      <div class="wg__title" role="heading" aria-level="2">
        {%- if section.settings.title_italic != blank -%}
          <em>{{ section.settings.title_italic | escape }}</em>
        {%- endif %} {{ section.settings.title_main | escape }}
      </div>
    </div>

    {%- comment -%} Comparison card {%- endcomment -%}
    <div class="wg__card">

      {%- comment -%} Column headers {%- endcomment -%}
      <div class="wg__head-row">
        <div class="wg__head-cell wg__head-cell--feature"></div>
        <div class="wg__head-cell wg__head-cell--goju">
          {%- if section.settings.goju_logo != blank -%}
            {%- assign _logo = section.settings.goju_logo -%}
          {%- elsif sections['header'].settings.logo != blank -%}
            {%- assign _logo = sections['header'].settings.logo -%}
          {%- endif -%}
          {%- if _logo != blank -%}
            <img
              src="{{ _logo | image_url: height: 68 }}"
              alt="{{ shop.name }}"
              class="wg__logo"
              loading="lazy"
            >
          {%- else -%}
            <span class="wg__logo-text">{{ section.settings.goju_logo_text | default: 'GOJU.' | escape }}</span>
          {%- endif -%}
        </div>
        <div class="wg__head-cell wg__head-cell--competitor">
          {{ section.settings.competitor_label | default: 'Typical Wellness Shots' | escape }}
        </div>
      </div>

      {%- comment -%} Comparison rows {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' -%}
          <div class="wg__row" {{ block.shopify_attributes }}>
            <div class="wg__cell wg__cell--feature">{{ block.settings.feature | escape }}</div>
            <div class="wg__cell wg__cell--goju">
              <svg class="wg__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="#1F1A17"/><path d="M5.5 10.5L8.5 13.5L14.5 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ block.settings.goju_text | escape }}
            </div>
            <div class="wg__cell wg__cell--competitor">
              <svg class="wg__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="10" fill="#c0392b"/><path d="M6.5 6.5L13.5 13.5M13.5 6.5L6.5 13.5" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
              {{ block.settings.competitor_text | escape }}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} CTA row {%- endcomment -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="wg__cta-row">
          <div class="wg__cta-cell wg__cta-cell--feature"></div>
          <div class="wg__cta-cell wg__cta-cell--goju">
            <a href="{{ section.settings.cta_url | default: '#' }}" class="wg__cta-btn">
              {{- section.settings.cta_label | escape -}}
            </a>
          </div>
          <div class="wg__cta-cell wg__cta-cell--competitor"></div>
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why GOJU",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Recommended: min 2400px wide. If left empty, the solid background colour below is used."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "info": "Dark layer over the image to keep text readable. 0 = no overlay, 100 = fully black.",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 60,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "fallback_bg_color",
      "label": "Background colour (no image)",
      "default": "#EDE4D1",
      "info": "Used when no background image is set."
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Why GOJU?"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Heading italic word",
      "default": "Why"
    },
    {
      "type": "text",
      "id": "title_main",
      "label": "Heading main word",
      "default": "GOJU."
    },
    {
      "type": "header",
      "content": "Table columns"
    },
    {
      "type": "image_picker",
      "id": "goju_logo",
      "label": "GOJU logo (table header)"
    },
    {
      "type": "text",
      "id": "goju_logo_text",
      "label": "Logo text fallback",
      "default": "GOJU.",
      "info": "Shown as text if no logo image is selected"
    },
    {
      "type": "text",
      "id": "competitor_label",
      "label": "Competitor column header",
      "default": "Typical Wellness Shots"
    },
    {
      "type": "header",
      "content": "CTA button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop GOJU Now →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL",
      "info": "Supports collections, products, pages or any custom URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Cold-Pressed"
        },
        {
          "type": "textarea",
          "id": "goju_text",
          "label": "GOJU benefit",
          "default": "Preserves nutrients — heat destroys up to 70% of benefits."
        },
        {
          "type": "textarea",
          "id": "competitor_text",
          "label": "Competitor drawback",
          "default": "Heat-treated, destroying key nutrients before you drink them."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why GOJU",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "feature": "Cold-Pressed",
            "goju_text": "Preserves nutrients — heat destroys up to 70% of benefits.",
