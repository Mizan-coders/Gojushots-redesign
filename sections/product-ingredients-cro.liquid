{{ 'section-product-cro.css' | asset_url | stylesheet_tag }}

{%- assign pc_primary = product.metafields.custom.primary_color -%}

{% style %}
  .pdp-cro.ingredients-cro-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- assign _accent = section.settings.accent_color -%}
    {%- if _accent == blank or _accent == 'rgba(0,0,0,0)' -%}{%- assign _accent = pc_primary -%}{%- endif -%}
    {% if _accent != blank and _accent != 'rgba(0,0,0,0)' %}
    --cro-accent: {{ _accent }};
    --cro-accent-light: {{ _accent }}14;
    {% endif %}
    {% if section.settings.highlight_color != blank and section.settings.highlight_color != 'rgba(0,0,0,0)' %}
    --cro-highlight: {{ section.settings.highlight_color }};
    {% endif %}
  }
  @media screen and (max-width: 749px) {
    .pdp-cro.ingredients-cro-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }
  }
{% endstyle %}

<section
  class="pdp-cro cro-section--dark ingredients-cro-{{ section.id }}"
  id="ingredients-cro-{{ section.id }}"
  {%- if section.settings.bg_color != blank and section.settings.bg_color != 'rgba(0,0,0,0)' -%}
    style="background-color: {{ section.settings.bg_color }};"
  {%- endif -%}
>
  <div class="cro-container">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="cro-section-header cro-fade-up" id="whats-in-it">
      {%- if section.settings.kicker != blank -%}
        <span class="cro-kicker cro-kicker--accent">{{ section.settings.kicker }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cro-heading cro-ingredients__heading">
          {%- if section.settings.heading_accent_word != blank -%}
            {%- assign accent = section.settings.heading_accent_word -%}
            {%- assign plain  = section.settings.heading | remove: accent -%}
            {{ plain }}<em>{{ accent }}</em>
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}
    </div>

    {%- comment -%} Ingredient cards grid {%- endcomment -%}
    {%- assign mf_ingredients = product.metafields.cro.ingredients.value -%}
    {%- if mf_ingredients.size > 0 or section.blocks.size > 0 -%}
      <div class="cro-ingredients-grid">
        {%- if mf_ingredients.size > 0 -%}
          {%- for ing in mf_ingredients -%}
            {%- assign card_bg = ing.card_color.value | default: '' -%}
            <div class="cro-ingredient-card cro-fade-up delay-{{ forloop.index }}">
              <div class="cro-ingredient-card__img-wrap"{% if card_bg != blank %} style="background: {{ card_bg }};"{% endif %}>
                {%- if ing.image.value != blank -%}
                  <img
                    src="{{ ing.image.value | img_url: '800x533', crop: 'center' }}"
                    alt="{{ ing.image.value.alt | default: ing.name.value | escape }}"
                    loading="lazy"
                    width="800"
                    height="533"
                    class="cro-ingredient-card__img"
                  >
                {%- else -%}
                  <div class="cro-ingredient-card__placeholder" aria-hidden="true">
                    <span class="cro-ingredient-card__emoji">{{ ing.emoji.value | default: '🌿' }}</span>
                  </div>
                {%- endif -%}
                {%- if ing.tag.value != blank -%}
                  <span class="cro-tag cro-ingredient-card__tag">{{ ing.tag.value }}</span>
                {%- endif -%}
              </div>
              <div class="cro-ingredient-card__body">
                {%- if ing.name.value != blank -%}
                  <h3 class="cro-ingredient-card__name">{{ ing.name.value }}</h3>
                {%- endif -%}
                {%- if ing.benefit.value != blank -%}
                  <p class="cro-ingredient-card__benefit">{{ ing.benefit.value }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'ingredient' -%}
              <div
                class="cro-ingredient-card cro-fade-up delay-{{ forloop.index }}"
                {{ block.shopify_attributes }}
              >
                {%- assign card_bg = block.settings.card_color | default: '' -%}
                <div class="cro-ingredient-card__img-wrap"{% if card_bg != blank %} style="background: {{ card_bg }};"{% endif %}>
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | img_url: '800x533', crop: 'center' }}"
                      alt="{{ block.settings.image.alt | default: block.settings.name | escape }}"
                      loading="lazy"
                      width="800"
                      height="533"
                      class="cro-ingredient-card__img"
                    >
                  {%- else -%}
                    <div class="cro-ingredient-card__placeholder" aria-hidden="true">
                      {%- if block.settings.emoji != blank -%}
                        <span class="cro-ingredient-card__emoji">{{ block.settings.emoji }}</span>
                      {%- else -%}
                        <span class="cro-ingredient-card__emoji">🌿</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.tag != blank -%}
                    <span class="cro-tag cro-ingredient-card__tag">{{ block.settings.tag }}</span>
                  {%- endif -%}
                </div>
                <div class="cro-ingredient-card__body">
                  {%- if block.settings.name != blank -%}
                    <h3 class="cro-ingredient-card__name">{{ block.settings.name }}</h3>
                  {%- endif -%}
                  {%- if block.settings.benefit != blank -%}
                    <p class="cro-ingredient-card__benefit">{{ block.settings.benefit }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('ingredients-cro-{{ section.id }}');
  if (!section) return;

  var items = section.querySelectorAll('.cro-fade-up');
  if (!items.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.10 });

    items.forEach(function (el) { observer.observe(el); });
  } else {
    items.forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>

{% schema %}
{
  "name": "Ingredients CRO",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "color",
          "id": "card_color",
          "label": "Card background colour",
          "default": "#F9C74F",
          "info": "Gradient start colour for the card image area"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient image",
          "info": "Optional. If blank, emoji placeholder is shown."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (fallback)",
          "default": "🌿",
          "info": "Shown when no image is uploaded"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name",
          "default": "Fresh Ginger"
        },
        {
          "type": "textarea",
          "id": "benefit",
          "label": "Benefit description",
          "default": "Supports digestion, reduces nausea, and delivers powerful anti-inflammatory gingerols."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Category tag",
          "default": "Anti-inflammatory",
          "info": "Short label shown as a pill on the card image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker label",
      "default": "What's Inside",
      "info": "Small uppercase label above heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Active Ingredients"
    },
    {
      "type": "text",
      "id": "heading_accent_word",
      "label": "Accent word(s) in heading",
      "default": "Ingredients",
      "info": "These exact words will be highlighted in accent colour. Must match text in Heading exactly."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "info": "Leave blank to use the default dark section colour."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Kicker colour",
      "default": "#1D7A3F",
      "info": "Controls the small kicker label colour above the heading."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Heading accent word colour",
      "default": "#F9C74F",
      "info": "Controls the highlighted word colour in the heading."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Ingredients CRO",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🫚",
            "name": "Fresh Ginger",
            "benefit": "Supports digestion, reduces nausea, and delivers powerful anti-inflammatory gingerols.",
            "tag": "Anti-inflammatory"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🟡",
            "name": "Turmeric Root",
            "benefit": "Curcumin in turmeric is one of nature's most studied anti-inflammatory compounds.",
            "tag": "Immunity Boost"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🍋",
            "name": "Lemon Juice",
            "benefit": "Natural source of Vitamin C to support immune function and skin health.",
            "tag": "Vitamin C"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "emoji": "🍎",
            "name": "Apple",
            "benefit": "Balances the shot's flavour profile while adding natural prebiotic fibre.",
            "tag": "Gut Health"
          }
        }
      ]
    }
  ]
}
{% endschema %}
