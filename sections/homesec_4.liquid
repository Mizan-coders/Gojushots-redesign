<section id="four" data-color="#FFDA00" class="dksoni panel review-container position-relative" data-color="#E81F76" style="overflow:hidden;">
     <div class="review-sticker-img d-lg-block d-none">
       <img src="{{ section.settings.image |img_url:'220x239' }}" alt="sticker-shots" />
     </div>
     <div class="container">
       <div class="row">
         <div class="col-lg-5">
           <div class="heading">
             <h3>{{ section.settings.heading }}</h3>
             <span>{{ section.settings.sub_heading }}</span>
           </div>
         </div>
       </div>
       <div class="row">
         <div class="col-md-12">
           <div class="review-card-list d-flex">
             <div class="review-list-left">
               {% for block in section.blocks %}
                 {% if forloop.index <= 3 %}
                 
                 <div class="review-card-item">
                   <div class="review-card-box">
                     <div class="review-card-upper">
                       <div class="rating-box">
                         <span><i class="fas fa-star" aria-hidden="true"></i></span>
                         <span><i class="fas fa-star" aria-hidden="true"></i></span>
                         <span><i class="fas fa-star" aria-hidden="true"></i></span>
                         <span><i class="fas fa-star" aria-hidden="true"></i></span>
                         <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       </div>
                       <h4>{{ block.settings.quote }}</h4>
                       <p>{{ block.settings.body_text }}</p>
                     </div>
                     <div class="review-card-lower d-flex">
                       <div class="review-profile">
                         <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/profile-img.png?v=1654048639" alt="" />
                       </div>
                       <p>{{ block.settings.author }}</p>
                     </div>
                   </div>
                 </div>
                 {% endif %}
               {% endfor %}
             </div>
             <div class="review-list-bg-img">
               <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/review-bg.png?v=1654048757" alt="" />
             </div>
             <div class="review-list-right"> 
               {% for block in section.blocks %}
               {% if forloop.index >= 4 %}
               
               <div class="review-card-item">
                 <div class="review-card-box">
                   <div class="review-card-upper">
                     <div class="rating-box">
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                     </div>
                     <h4>{{ block.settings.quote }}</h4>
                     <p>{{ block.settings.body_text }}</p>
                   </div>
                   <div class="review-card-lower d-flex">
                     <div class="review-profile">
                       <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/profile-img.png?v=1654048639" alt="" />
                     </div>
                     <p>{{ block.settings.author }}</p>
                   </div>
                 </div>
               </div>
               {% endif %}
               {% endfor %}
             </div>
           </div>
           <ul class="reviw-list"> 
             {% for block in section.blocks %}
               <div class="review-card-item">
                 <div class="review-card-box">
                   <div class="review-card-upper">
                     <div class="rating-box">
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       <span><i class="fas fa-star" aria-hidden="true"></i></span>
                     </div>
                     <h4>{{ block.settings.quote }}</h4>
                     {{ block.settings.body_text }}
                   </div>
                   <div class="review-card-lower d-flex">
                     <div class="review-profile">
                       <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/profile-img.png?v=1654048639" alt="" />
                     </div>
                     <p>{{ block.settings.author }}</p>
                   </div>
                 </div>
               </div>
               {% endfor %}
           </ul>
<!--            <div class="custom-arrow">
             <ul>
                <li class="prev slick-arrow" style="">
                   {% include 'prev-icon'%}
                </li>
                <li class="next slick-arrow" style="">
                   {% include 'next-icon'%}
                </li>
             </ul>
          </div> -->
           <div class="home-review-arrow d-flex align-items-center justify-content-between">
                <a href="#!" class="custom-arrow-btn home-review-prev"><img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/arrow-left.png?v=1658050161" alt="arrow-left" /></a>
                  <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                      <span class="slider__label"></span>
                  </div>
                <a href="#!" class="custom-arrow-btn home-review-next"><img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/arrow-right.png?v=1658050161" alt="right-arrow" /></a>
            </div>
         </div>
       </div>
     </div>
</section>
{% schema %}
  {
    "name": "Review",
    "class": "review-block",
     "max_blocks": 7,
     "settings": [
		{
		"type":"image_picker",
        "id": "image",
        "label": "Image"
	   },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "text",
        "id": "sub_heading",
        "label": "Sub Heading"
      }
    ],
	"blocks": [
     {
       "name": "Review",
       "type": "review",
       "settings": [
         {
           "type": "text",
           "id": "quote",
           "label": "Quote's"
         },
		{
           "type": "richtext",
           "id": "body_text",
           "label": "Body Text"
         },
		{
           "type": "text",
           "id": "author",
           "label": "Author Name & Date"
         }
       ]
     }
   ]
  }

{% endschema %}