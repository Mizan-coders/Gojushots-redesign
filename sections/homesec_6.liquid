<section id="six"  data-color="#FFFFFF" class="dksoni img-with-text-container panel" data-color="#FFDA00" style="overflow:hidden;">
  <div class="container position-relative">
    <div class="row">
      <div class="col-md-6">
          {% if section.settings.top_image != blank %}
          <div class="iwt-img-box d-md-block d-none">
              <img src="{{ section.settings.image |img_url:'442x442' }}" alt="{{ section.settings.image |alt }}"/>
          </div>
          {% endif %}
      </div>
      <div class="col-md-6">
         <div class="iwt-text-box">
            <h3>{{ section.settings.heading }}</h3>
           {{ section.settings.body_text }}
           {% if section.settings.btn_url != blank %}
            <a href="{{ section.settings.btn_url }}" class="btn btn-outline">{{ section.settings.btn_text }}</a>
            {% endif %}
         </div>
      </div>
    </div>
    {% if section.settings.top_image != blank %}
    <div class="yellow-sticker-img">
      <img src="{{ section.settings.top_image |img_url:'368x396' }}" alt="{{ section.settings.top_image |alt }}"/>
    </div>
    {% endif %}
  </div>
</section>
{% schema %}
  {
    "name": "Our Commitment",
    "settings": [
    {
      "type":"text",
      "id":"heading",
      "label":"Heading"
    },
    {
      "type":"image_picker",
      "id":"top_image",
      "label":"Top Image"
    },
    {
      "type":"richtext",
      "id":"body_text",
      "label":"Paragraph"
    },
    {
      "type":"url",
      "id":"btn_url",
      "label":"Button URL"
    },
    {
      "type":"text",
      "id":"btn_text",
      "label":"Button Text"
    },
    {
      "type":"image_picker",
      "id":"image",
      "label":"Image"
    }
    ]
  }
{% endschema %}