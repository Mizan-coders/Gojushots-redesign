

<header id="header">
   		{% if section.settings.message %}
        <div class="header-upper">
            <div class="container container1">
                <div class="row">
                    <div class="col-md-12 d-flex align-items-center justify-content-center position-relative">
                        <div class="hu-title">{{ section.settings.message_text }}</div>
                        <div class="hu-link">
                            <a href="{{ section.settings.message_link }}" class="header-btn d-flex align-items-center">Shop now</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
   		{% endif %}
        <div class="header-lower">
            <nav class="navbar navbar-expand-xl">
                <div class="container container1">
                    <div class="nav-inside d-flex align-items-center justify-content-xl-between">
                        <a class="navbar-brand" href="{{ routes.root_url }}"><img src="{{ section.settings.logo | img_url:'100x50' }}" alt="{{ shop.name }}" /></a>
                        <button class="navbar-toggler collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="mainNav">
                          <div class="navbar-inside ms-auto">
                            <ul class="navbar-nav">
                             {% for link in section.settings.main_linklist.links %}
                             <li class="nav-item">
                                  <a class="nav-link {% if link.links != blank %}dropdown-toggle{% endif %}" {% if link.links != blank %}id="id-{{ forloop.index }}"{% endif %} href="{{ link.url }}" {% if link.links != blank %} data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"{% endif %}>
                                      {{ link.title }}<i><img src="include/images/chervon-down.svg" alt="" /></i>
                                  </a>
                               	  {% if link.links != blank %}
                                  <ul class="dropdown-menu" aria-labelledby="id-{{ forloop.index }}">
                                      {% for child_link in link.links %} 
                                      <li>
                                        <a class="dropdown-item" href="{{ child_link.url }}" class="mn-childhead"><span>{{ child_link.title }}</span></a>   
                                      </li> 
                                      {% endfor %}
                                  </ul>
                               	  {% endif %}
                              </li>
                              {% endfor %}
                             </ul>
                      		</div>
                        </div>
                        <div class="header-right d-flex align-items-center"> 
                        	
                            <a href="#!" class="account-icon">
                              <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/user.png?v=1654011608" alt="user" />
                          	</a>
                            <a href="{{ routes.cart_url }}" class="cart-icon">
                              <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/cart.png?v=1654011608" alt="cart" />
                          	</a>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>
