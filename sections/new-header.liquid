{% if template.name != "index" %} 
<style>

/* ================== new header ====================== */
 #header { background: #fff; position: fixed; left: 0; top: 0; right: 0; padding: 0; z-index: 9999; transition: all 0.2s ease-in; -webkit-transition: all 0.2s ease-in; box-shadow: 0 0 8px rgb(0 0 0 / 10%); }
.header-upper { background: #282828; padding: 6px 0; color: #fff; text-align: center;display: flex;justify-content: center;align-items: center; height: 40px;}
.hu-title { font-size: 14px; display: inline-block; }
.hu-link { margin-left: 8px; display: inline-block; line-height: 14px; }
.hu-link > a { color: #fff; text-decoration: none; line-height: 16px; }

.header-lower{background-color:#fff;}
.header-lower .navbar { padding: 0; width: 100%; height: 80px; display: flex; align-items: center; }
.header-lower .container.container1 { width: 100%; max-width: 1420px; margin: 0 auto; padding: 0 15px; }
.header-lower .navbar-brand {width: 100px;padding: 0;margin: 0;position: relative;z-index: 999;display: flex;}
.header-lower .nav-inside {display: flex;justify-content: space-between;align-items: center;}
.header-lower .navbar-toggler { display: none; }
.header-lower .navbar-nav { display: flex; list-style: none; }
.header-lower .navbar-nav .dropdown-menu {list-style: none;opacity: 0;visibility: hidden;background: #fff;color: #546579;min-width: 180px;box-shadow: 0 5px 8px rgb(0 0 0 / 20%);border: 0;border-radius: 0;position: absolute;top: 100%;margin-top: 5px;padding: 10px 0;transition: all .3s ease-in;}
  
.header-lower .nav-item {padding: 0 21px;position: relative;}
.header-lower .nav-item .dropdown-item { color: #546579; padding: 5px 15px; font-weight: 400; width: 100%; display: block; text-decoration: none; font-size: 14px; }
.header-lower .nav-item:hover > .dropdown-menu { margin-top: 0; opacity: 1; visibility: visible; }
.header-lower .nav-link {font-size: 14px;line-height: 30px;font-weight: 600;color: #000;padding: 0;margin: 0;text-decoration: none;}
.header-lower .navbar-collapse { margin-left: auto; margin-right: 6%; }
.header-right { display: flex;}
.header-lower .header-right > a { width: 25px; line-height: 25px; }
.header-lower .header-right > a + a { margin-left: 25px;  width: 30px; }
.header-lower .header-right > a > img { vertical-align: middle; width: 100%; object-fit: contain;} 

@media (max-width:1199.98px) {
	.header-lower .navbar-collapse { position: fixed; top: 100px; left: 0; background: #fff; padding: 0; z-index: 99; margin: 0; border: 0; overflow-y: auto; bottom: 0; width: 100%; height: 0; display: block !important; transition: all .3s cubic-bezier(0.77, 0.2, 0.05, 1.0); }
	.header-lower .navbar-inside { height: calc(100vh - 125px); padding: 0 19px; }
	.header-lower .navbar-nav { flex-flow: column; padding: 0; }
	.header-lower .nav-item { padding: 0; border-bottom: 1px solid #DFDED8; }
	.header-lower .nav-link { font-size: 14px; line-height: 51px; position: relative; color: #6E6B63; }
    .header-lower .header-right { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); }
    .header-lower .header-right > a { width: 22px; }
    .header-lower .navbar { height: 60px; position: relative; }
    .header-lower .navbar-brand { width: 80px; margin: 0 auto; }
    .header-lower .header-right > a + a { margin-left: 20px; }
    .header-lower .header-right > a > img { }
    .header-lower .navbar-toggler { display: block; width: 60px; height: 60px; border-radius: 0; cursor: pointer; text-decoration: none; padding: 0; border: 0; background: transparent; margin: 0; position: absolute; top: 50%; z-index: 999; transform: translateY(-50%); left: 0; }
    .navbar-toggler-icon { position: relative; display: inline-block; width: 20px; height: 2px; color: #243238; text-indent: -55px; margin-top: 0; background: #546579; transition: all .2s ease-out; -webkit-transition: all .2s ease-out; -moz-transition: all .2s ease-out; -ms-transition: all .2s ease-out; vertical-align: middle; }
    .navbar-toggler .navbar-toggler-icon:before, .navbar-toggler .navbar-toggler-icon:after { content: ''; width: 20px; height: 2px; background: #546579; position: absolute; left: 0; transition: all .2s ease-out; }
    .navbar-toggler .navbar-toggler-icon:before { top: -7px; }
    .navbar-toggler .navbar-toggler-icon:after { bottom: -7px; }
    .nav-open .navbar-toggler-icon { background: transparent; }
    .nav-open .navbar-toggler .navbar-toggler-icon:before { transform: rotate(45deg); top: 2px; }
    .nav-open .navbar-toggler .navbar-toggler-icon:after { transform: rotate(-45deg); bottom: -2px; }
    .nav-open .header-lower .navbar-collapse { height: calc(100vh - 100px); 
}
}
  
@media (max-width:767.98px) {
	.header-lower .header-right > a + a { margin-left: 16px; width: 25px; }
	.header-lower .header-right > a { width: 19px; }
}

</style>

<script>
$('.navbar-toggler').on('click', function() {
    $('body').toggleClass('nav-open');
});
</script>

{%endif%}