<section class="content-container goju-fam-container">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="heading-type-2">
                    <h3>{{ section.settings.heading }}</h3>
                    <span class="heading-type-2-overlay">
                      <img src="{{ section.settings.icon |img_url:'260x130' }}" alt="{{ section.settings.icon |alt }}" />
                    </span>
                </div>
                <ul class="about-fam-list d-flex flex-wrap">
                  {% for block in section.blocks %}  
                  <li class="about-fam-item">
                        <div class="about-fam-box">
                            <div class="about-fam-img">
                                <img src="{{ block.settings.image |img_url:'354x354' }}" alt="{{ block.settings.image |alt }}" />
                            </div>
                            <div class="about-fam-content text-md-center">
                                <h6>{{ block.settings.sub_heading }}</h6>
                                <h3>{{ block.settings.heading }}</h3>
                                {{ block.settings.body_text }}
                            </div>
                        </div>
                    </li>
                   {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</section>
{% schema %}
  {
    "name": "The Goju Fam",
    "settings": [
      {
        "type" : "text",
        "id" : "heading",
        "label" : "Heading"
      },
      {
        "type" : "image_picker",
        "id" : "icon",
        "label" : "Icon"
      }
    ],
    "blocks": [
         {
           "name": "Goju Fum",
           "type": "gojufum",
           "settings": [
             {
               "type": "image_picker",
               "id": "image",
               "label": "Image"
             },
             {
                "type" : "text",
                "id" : "sub_heading",
                "label" : "Sub Heading"
              },
              {
              "type" : "text",
              "id" : "heading",
              "label" : "Heading"
            },
             {
              "type" : "richtext",
              "id" : "body_text",
              "label" : "Body Text"
            }         
           ]
         }
      ]
  }
{% endschema %}