    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "insta_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "fb_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
