{%- style -%}
  .hero-{{ section.id }} {
    background: {{ section.settings.bg_color | default: 'var(--goju-page-bg, #f5f0e8)' }};
    min-height: 90vh;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    align-items: center;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 80px;
    gap: 0;
    position: relative;
    overflow: hidden;
  }

  /* Radial green glow */
  .hero-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(26,74,46,0.5) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Left column ── */
  .hero-{{ section.id }} .hero__content {
    position: relative;
    z-index: 2;
  }

  /* Rating row */
  .hero-{{ section.id }} .hero__rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .hero-{{ section.id }} .hero__stars {
    color: #fbbf24;
    font-size: 16px;
    letter-spacing: 2px;
  }
  .hero-{{ section.id }} .hero__rating-text {
    font-size: 13px;
    color: rgba(255,255,255,0.65);
  }
  .hero-{{ section.id }} .hero__rating-text strong {
    color: white;
  }

  /* Heading */
  .hero-{{ section.id }} .hero__heading {
    font-size: clamp(56px, 5.5vw, 140px);
    font-weight: 600;
    line-height: 0.95;
    color: white;
    letter-spacing: 1px;
    margin: 0 0 20px;
    text-transform: uppercase;
  }
  .hero-{{ section.id }} .hero__heading em {
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    color: var(--goju-accent);
    font-size: 0.9em;
    letter-spacing: 0;
  }

  /* Subtext */
  .hero-{{ section.id }} .hero__sub {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin-bottom: 36px;
    max-width: 420px;
  }
  .hero-{{ section.id }} .hero__sub strong {
    color: white;
  }

  /* Price anchor */
  .hero-{{ section.id }} .hero__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .hero-{{ section.id }} .hero__price-original {
    font-size: 18px;
    color: rgba(255,255,255,0.35);
    text-decoration: line-through;
    font-weight: 400;
  }
  .hero-{{ section.id }} .hero__price-current {
    font-size: 36px;
    font-weight: 700;
    color: var(--goju-accent);
    line-height: 1;
  }
  .hero-{{ section.id }} .hero__price-pack {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
  }
  .hero-{{ section.id }} .hero__price-per {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    font-style: italic;
  }

  /* CTAs */
  .hero-{{ section.id }} .hero__ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .hero-{{ section.id }} .hero__btn-primary {
    background: var(--goju-btn-primary-bg, #1d7a3f);
    color: var(--goju-btn-primary-text, #ffffff);
    padding: 16px 32px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: transform 0.2s, box-shadow 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero-{{ section.id }} .hero__btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255,255,255,0.2);
    color: var(--goju-btn-primary-text, #ffffff);
  }
  .hero-{{ section.id }} .hero__btn-secondary {
    background: transparent;
    color: white;
    padding: 16px 32px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    transition: border-color 0.2s, background 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .hero-{{ section.id }} .hero__btn-secondary:hover {
    border-color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.06);
    color: white;
  }

  /* Urgency */
  .hero-{{ section.id }} .hero__urgency-stack {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }
  .hero-{{ section.id }} .hero__urgency {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hero-{{ section.id }} .hero__urgency-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: hero-pulse-{{ section.id }} 1.5s ease-in-out infinite;
  }
  @keyframes hero-pulse-{{ section.id }} {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(1.3); }
  }
  .hero-{{ section.id }} .hero__urgency-text {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.01em;
  }

  /* Trust pills */
  .hero-{{ section.id }} .hero__pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero-{{ section.id }} .hero__pill {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.7);
    font-size: 12px;
    padding: 6px 14px;
    border-radius: 50px;
    font-weight: 500;
    white-space: nowrap;
  }

  /* ── Right column ── */
  .hero-{{ section.id }} .hero__visual {
    align-self: stretch;
    overflow: hidden;
    position: relative;
    z-index: 2;
  }
  .hero-{{ section.id }} .hero__img-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .hero-{{ section.id }} .hero__img-badge {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--goju-accent);
    color: var(--goju-accent-text);
    font-size: 12px;
    font-weight: 700;
    padding: 6px 20px;
    border-radius: 50px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    z-index: 3;
    box-shadow: 0 4px 16px rgba(255,255,255,0.25);
  }
  .hero-{{ section.id }} .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* ── Tablet ── */
  @media screen and (max-width: 989px) {
    .hero-{{ section.id }} {
      grid-template-columns: 1fr;
      padding: 60px 20px 40px;
      min-height: auto;
      text-align: center;
    }
    .hero-{{ section.id }}::before {
      background: radial-gradient(ellipse at 50% 30%, rgba(26,74,46,0.5) 0%, transparent 70%);
    }
    .hero-{{ section.id }} .hero__rating { justify-content: center; }
    .hero-{{ section.id }} .hero__sub { margin-left: auto; margin-right: auto; }
    .hero-{{ section.id }} .hero__ctas { justify-content: center; }
    .hero-{{ section.id }} .hero__urgency-stack { align-items: center; }
    .hero-{{ section.id }} .hero__pills { justify-content: center; }
    .hero-{{ section.id }} .hero__price { justify-content: center; }
    .hero-{{ section.id }} .hero__visual { min-height: 360px; margin-top: 24px; }
    .hero-{{ section.id }} .hero__img { position: static; height: 360px; border-radius: 14px; object-position: center top; }
    .hero-{{ section.id }} .hero__heading { font-size: clamp(40px, 10vw, 72px) !important; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 479px) {
    .hero-{{ section.id }} { padding: 40px 20px; }
    .hero-{{ section.id }} .hero__heading { font-size: clamp(32px, 12.5vw, 56px) !important; line-height: 0.92; }
    .hero-{{ section.id }} .hero__sub { font-size: 14px; }
    .hero-{{ section.id }} .hero__ctas { flex-direction: column; width: 100%; }
    .hero-{{ section.id }} .hero__btn-primary,
    .hero-{{ section.id }} .hero__btn-secondary { justify-content: center; width: 100%; }
    .hero-{{ section.id }} .hero__img { height: 280px; border-radius: 14px; }
    .hero-{{ section.id }} .hero__pills { gap: 6px; }
  }
{%- endstyle -%}

<section class="hero-{{ section.id }}">

  {%- comment -%} Left — content {%- endcomment -%}
  <div class="hero__content">

    {%- comment -%} Rating — always rendered; setting overrides the fallback default {%- endcomment -%}
    <div class="hero__rating">
      <span class="hero__stars">
        {%- assign star_count = section.settings.star_count | default: 5 -%}
        {%- for i in (1..star_count) -%}★{%- endfor -%}
      </span>
      <span class="hero__rating-text">
        {%- if section.settings.rating_text != blank -%}
          {{ section.settings.rating_text }}
        {%- else -%}
          <strong>4.9</strong> stars &middot; <strong>2,100+</strong> happy customers
        {%- endif -%}
      </span>
    </div>

    {%- comment -%} Heading {%- endcomment -%}
    <h1 class="hero__heading">
      {{- section.settings.heading_line1 | escape -}}
      {%- if section.settings.heading_italic != blank %} <em>{{ section.settings.heading_italic | escape }}</em>{%- endif -%}
      {%- if section.settings.heading_line2 != blank -%}<br>{{ section.settings.heading_line2 | escape }}{%- endif -%}
    </h1>

    {%- comment -%} Subtext {%- endcomment -%}
    {%- if section.settings.subtext != blank -%}
      <p class="hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- comment -%} Price anchor {%- endcomment -%}
    {%- if section.settings.price_current != blank -%}
      <div class="hero__price">
        {%- if section.settings.price_original != blank -%}
          <span class="hero__price-original">{{ section.settings.price_original | escape }}</span>
        {%- endif -%}
        <span class="hero__price-current">{{ section.settings.price_current | escape }}</span>
        {%- if section.settings.price_pack != blank -%}
          <span class="hero__price-pack">{{ section.settings.price_pack | escape }}</span>
        {%- endif -%}
        {%- if section.settings.price_per != blank -%}
          <span class="hero__price-per">{{ section.settings.price_per | escape }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} CTAs {%- endcomment -%}
    {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
      <div class="hero__ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: '#' }}" class="hero__btn-primary">
            {{- section.settings.cta1_label | escape -}}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '#' }}" class="hero__btn-secondary">
            {{- section.settings.cta2_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Urgency {%- endcomment -%}
    {%- if section.settings.urgency1_text != blank or section.settings.urgency2_text != blank -%}
      <div class="hero__urgency-stack">
        {%- if section.settings.urgency1_text != blank -%}
          <div class="hero__urgency">
            <span class="hero__urgency-dot" style="background: {{ section.settings.urgency1_color | default: '#ff4d4d' }};"></span>
            <span class="hero__urgency-text">{{ section.settings.urgency1_text | escape }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.urgency2_text != blank -%}
          <div class="hero__urgency">
            <span class="hero__urgency-dot" style="background: {{ section.settings.urgency2_color | default: '#f59e0b' }};"></span>
            <span class="hero__urgency-text">{{ section.settings.urgency2_text | escape }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Trust pills {%- endcomment -%}
    {%- assign has_pills = false -%}
    {%- for i in (1..4) -%}
      {%- assign pill_key = 'pill_' | append: i | append: '_text' -%}
      {%- if section.settings[pill_key] != blank -%}{%- assign has_pills = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_pills -%}
      <div class="hero__pills">
        {%- for i in (1..4) -%}
          {%- assign icon_key = 'pill_' | append: i | append: '_icon' -%}
          {%- assign text_key = 'pill_' | append: i | append: '_text' -%}
          {%- if section.settings[text_key] != blank -%}
            <span class="hero__pill">
              {%- if section.settings[icon_key] != blank -%}{{ section.settings[icon_key] }} {%- endif -%}
              {{- section.settings[text_key] | escape -}}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} Right — image {%- endcomment -%}
  {%- if section.settings.image != blank -%}
    <div class="hero__visual">
      <div class="hero__img-wrap">
        {%- if section.settings.img_badge != blank -%}
          <div class="hero__img-badge">{{ section.settings.img_badge | escape }}</div>
        {%- endif -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: 'Hero image' | escape }}"
          class="hero__img"
          width="1200"
          height="560"
          loading="eager"
          fetchpriority="high"
        >
      </div>
    </div>
  {%- endif -%}

</section>

