{%- style -%}
  .hero-{{ section.id }} {
    position: relative;
    min-height: {{ section.settings.hero_height | default: 80 }}vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #1F1A17;
    --hero-overlay: {{ section.settings.overlay_opacity | default: 45 | times: 0.01 }};
  }

  /* ── Background image ── */
  .hero-{{ section.id }} .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-{{ section.id }} .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position | default: 'center center' }};
    display: block;
  }

  /* ── Overlay ── */
  .hero-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(31, 26, 23, var(--hero-overlay, 0.45));
    z-index: 1;
    pointer-events: none;
  }

  /* ── Content ── */
  .hero-{{ section.id }} .hero__content {
    position: relative;
    z-index: 3;
    padding-left: 80px;
    padding-right: 80px;
    max-width: 780px;
  }

  /* ── Eyebrow ── */
  .hero-{{ section.id }} .hero__eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(247, 241, 228, 0.6);
    margin-bottom: 20px;
  }

  /* ── Heading ── */
  .hero-{{ section.id }} .hero__heading {
    font-size: clamp({{ section.settings.heading_size | times: 0.56 | round }}px, {{ section.settings.heading_size | times: 0.06 }}vw, {{ section.settings.heading_size }}px);
    font-weight: 700;
    line-height: 0.95;
    color: {{ section.settings.heading_color | default: '#F7F1E4' }};
    letter-spacing: -0.01em;
    text-transform: {{ section.settings.heading_transform | default: 'uppercase' }};
    margin: 0 0 24px;
  }
  .hero-{{ section.id }} .hero__heading em {
    display: block;
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    color: {{ section.settings.heading_color | default: '#F7F1E4' }};
    opacity: 0.75;
    letter-spacing: 0;
    font-size: 0.85em;
  }

  /* ── Subtext ── */
  .hero-{{ section.id }} .hero__sub {
    font-size: 17px;
    color: rgba(247, 241, 228, 0.9);
    line-height: 1.6;
    margin: 0 0 40px;
    max-width: 480px;
  }

  /* ── CTAs ── */
  .hero-{{ section.id }} .hero__ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  /* Primary CTA size override for hero */
  .hero-{{ section.id }} .goju-btn--lg {
    padding: 16px 36px;
    font-size: 15px;
  }

  /* Secondary CTA — outlined style on dark background */
  .hero-{{ section.id }} .hero__btn-secondary {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: #F7F1E4;
    padding: 16px 36px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border: 1.5px solid rgba(247, 241, 228, 0.4);
    white-space: nowrap;
    transition: border-color 0.2s, background 0.2s;
  }
  .hero-{{ section.id }} .hero__btn-secondary:hover {
    border-color: rgba(247, 241, 228, 0.75);
    background: rgba(247, 241, 228, 0.08);
    color: #F7F1E4;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .hero-{{ section.id }} {
      min-height: {{ section.settings.hero_height_mobile | default: 90 }}vh;
      align-items: flex-end;
      padding-bottom: 52px;
    }
    .hero-{{ section.id }}::after {
      background: linear-gradient(to top, rgba(31, 26, 23, 0.65) 0%, transparent 65%);
    }
    .hero-{{ section.id }} .hero__content {
      padding-left: 24px;
      padding-right: 24px;
      max-width: 100%;
    }
    .hero-{{ section.id }} .hero__heading {
      font-size: clamp({{ section.settings.heading_size | times: 0.40 | round }}px, 11vw, {{ section.settings.heading_size | times: 0.64 | round }}px);
    }
    .hero-{{ section.id }} .hero__sub {
      font-size: 15px;
      max-width: 100%;
    }
    .hero-{{ section.id }} .hero__ctas {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
    }
    .hero-{{ section.id }} .hero__btn-primary,
    .hero-{{ section.id }} .hero__btn-secondary {
      justify-content: center;
    }
  }
{%- endstyle -%}

<section class="hero-{{ section.id }}">

  {%- if section.settings.image != blank -%}
    <div class="hero__bg">
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 1200 }}"
          >
        {%- endif -%}
        <img
          src="{{ section.settings.image | image_url: width: 2400 }}"
          alt="{{ section.settings.image.alt | default: '' | escape }}"
          class="hero__bg-img"
          width="2400"
          height="1350"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    </div>
  {%- endif -%}

  <div class="hero__content">

    {%- if section.settings.eyebrow != blank -%}
      <span class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    <h1 class="hero__heading">
      {{- section.settings.heading_line1 | escape -}}
      {%- if section.settings.heading_italic != blank -%}
        <em>{{ section.settings.heading_italic | escape }}</em>
      {%- endif -%}
      {%- if section.settings.heading_line2 != blank -%}
        <br>{{ section.settings.heading_line2 | escape }}
      {%- endif -%}
    </h1>

    {%- if section.settings.subtext != blank -%}
      <p class="hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.cta1_label != blank or section.settings.cta2_label != blank -%}
      <div class="hero__ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: '#' }}" class="goju-btn goju-btn--primary goju-btn--lg">
            {{- section.settings.cta1_label | escape -}}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '#' }}" class="hero__btn-secondary">
            {{- section.settings.cta2_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. If left empty, the desktop image is used on mobile."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focus point",
      "options": [
        { "value": "center center", "label": "Centre" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Height (desktop)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Height (mobile)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 90,
      "unit": "vh"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness (desktop)",
      "info": "Higher = darker overlay. Mobile always uses a gradient.",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 45,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small uppercase label above the heading. Leave blank to hide."
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "ONE SHOT."
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic line",
      "default": "All day"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "ENERGY."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Cold-pressed. No sugar. No crash. Just results."
    },
    {
      "type": "header",
      "content": "Heading Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Font size (desktop max)",
      "min": 40,
      "max": 120,
      "step": 2,
      "default": 100,
      "unit": "px",
      "info": "Mobile scales automatically."
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Text transform",
      "options": [
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "none", "label": "As typed (mixed case)" },
        { "value": "capitalize", "label": "Title Case" },
        { "value": "lowercase", "label": "lowercase" }
      ],
      "default": "uppercase"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#F7F1E4"
    },
    {
      "type": "header",
      "content": "CTA Buttons"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Primary button label",
      "default": "Shop Best Seller →"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button label",
      "default": "Find My Shot"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
