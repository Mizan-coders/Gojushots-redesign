{{ 'section-product-cro.css' | asset_url | stylesheet_tag }}

{% style %}
  .reviews-cro-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .reviews-cro-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }
  }
{% endstyle %}

<section
  class="pdp-cro cro-section--warm reviews-cro-{{ section.id }}"
  id="reviews-cro-{{ section.id }}"
>
  <div class="cro-container">

    {%- comment -%} Anchor for scroll links {%- endcomment -%}
    <div id="reviews"></div>

    {%- comment -%} App block slot (Growave / Loox / etc.) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          <div class="cro-reviews__app-block cro-fade-up delay-2">
            {% render block %}
          </div>
      {%- endcase -%}
    {%- endfor -%}

  </div>
</section>

<script>
(function () {
  function initReviews() {
    var section = document.getElementById('reviews-cro-{{ section.id }}');
    if (!section) return;
    var items = section.querySelectorAll('.cro-fade-up');
    if (!items.length) return;
    if (window.Shopify && window.Shopify.designMode) {
      items.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05 });
      items.forEach(function (el) { observer.observe(el); });
    } else {
      items.forEach(function (el) { el.classList.add('is-visible'); });
    }
  }
  document.addEventListener('DOMContentLoaded', initReviews);
  document.addEventListener('shopify:section:load', initReviews);
})();
</script>

{% schema %}
{
  "name": "Reviews CRO",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Rating Summary"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "default": "4.9",
      "info": "Displayed as the large score number (e.g. 4.9)"
    },
    {
      "type": "text",
      "id": "review_count_text",
      "label": "Review count text",
      "default": "2,100+ verified reviews",
      "info": "Text shown below the stars"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Real reviews from real people who made the switch to whole-food wellness."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Reviews CRO"
    }
  ]
}
{% endschema %}
