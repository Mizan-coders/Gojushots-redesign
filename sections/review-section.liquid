<section class="product-review-section review-container position-relative" style="overflow:hidden;">
  <div class="container container1">
     <div class="row">
       <div class="col-lg-10">
            <div class="heading">
                <h3>{{ section.settings.heading }}</h3>
                <span>{{ section.settings.back_heading }}</span>
            </div>
       </div>
     </div>
     <div class="row">
        <div class="col-md-12">
           <ul class="product-review-list product-review-slider">
              {% for block in section.blocks %}
               <li class="review-card-item">
                 <div class="review-card-box">
                    <div class="review-card-upper">
                       <div class="rating-box">
                          <span><i class="fas fa-star" aria-hidden="true"></i></span>
                          <span><i class="fas fa-star" aria-hidden="true"></i></span>
                          <span><i class="fas fa-star" aria-hidden="true"></i></span>
                          <span><i class="fas fa-star" aria-hidden="true"></i></span>
                          <span><i class="fas fa-star" aria-hidden="true"></i></span>
                       </div>
                       <h4>{{ block.settings.quote }}</h4>
                       <p class="review-author">{{ block.settings.quote_by }}</p>
                      {{ block.settings.paragraph }}
                    </div>
                 </div>
              </li>
              {% endfor %}
           </ul>
           <div class="product-review-arrow d-flex align-items-center justify-content-between">
                    <a href="#!" class="custom-arrow-btn product-review-prev">
                    <svg class="custom-arrow-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" >
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M17.3946 7.95066H4.62363L10.4897 2.08461L8.99955 0.60498L0.604492 9.00004L8.99955 17.3951L10.4792 15.9155L4.62363 10.0494H17.3946V7.95066Z"/>
                    </svg>
                    </a>
                    <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
                        <span class="slider__label"></span>
                    </div>
                    <a href="#!" class="custom-arrow-btn product-review-next">
                    <svg class="custom-arrow-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" >
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9.00053 0.60498L7.5209 2.08461L13.3765 7.95066H0.605469V10.0494H13.3765L7.5209 15.9155L9.00053 17.3951L17.3956 9.00004L9.00053 0.60498Z" /> 
                     </svg>
                    </a>
            </div>
        </div>
     </div>
  </div>
</section>

{% schema %}
  {
    "name": "Review",
    "settings": [
      {
        "type":"text",
        "id":"heading",
        "label":"Heading"
      },
      {
        "type":"text",
        "id":"back_heading",
        "label":"Back Heading"
      }
    ],
  "blocks": [
     {
       "name": "Featured Review",
       "type": "featured-review",
       "settings": [
         {
          "type": "text",
          "id": "quote",
          "label": "Quote"
        },
         {
          "type": "text",
          "id": "quote_by",
          "label": "Review By & Date"
        },
         {
          "type": "richtext",
          "id": "paragraph",
          "label": "Review Text"
        }
       ]
     }
  ],
  "presets": [
    {
      "name": "Featured Review"
    }
  ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}