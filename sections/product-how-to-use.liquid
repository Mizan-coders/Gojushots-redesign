{{ 'section-product-cro.css' | asset_url | stylesheet_tag }}

{%- assign pc_primary = product.metafields.custom.primary_color -%}

{%- assign htu_image = section.settings.image -%}
{%- if htu_image == blank and product.metafields.custom.wellness_image != blank -%}
  {%- assign htu_image = product.metafields.custom.wellness_image -%}
{%- endif -%}
{%- assign htu_visual_bg = section.settings.visual_bg_color -%}
{%- if htu_visual_bg == blank or htu_visual_bg == 'rgba(0,0,0,0)' -%}
  {%- assign htu_visual_bg = product.metafields.custom.secondary_color | default: '#EEEBE4' -%}
{%- endif -%}

{% style %}
  .pdp-cro.how-to-use-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- assign _accent = section.settings.accent_color -%}
    {%- if _accent == blank or _accent == 'rgba(0,0,0,0)' -%}{%- assign _accent = pc_primary -%}{%- endif -%}
    {% if _accent != blank and _accent != 'rgba(0,0,0,0)' %}
    --cro-accent: {{ _accent }};
    --cro-accent-light: {{ _accent }}14;
    {% endif %}
    {% if section.settings.highlight_color != blank and section.settings.highlight_color != 'rgba(0,0,0,0)' %}
    --cro-highlight: {{ section.settings.highlight_color }};
    {% endif %}
  }
  @media screen and (max-width: 749px) {
    .pdp-cro.how-to-use-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }
  }
{% endstyle %}

<section
  class="pdp-cro how-to-use-{{ section.id }}"
  id="how-to-use-{{ section.id }}"
>
  <div class="cro-container">
    <div class="cro-htu-layout">

      {%- comment -%} ── LEFT: Header + Steps ── {%- endcomment -%}
      <div class="cro-htu__left">

        <div class="cro-htu__header cro-fade-up">
          {%- if section.settings.kicker != blank -%}
            <span class="cro-kicker cro-kicker--dark">{{ section.settings.kicker }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="cro-heading cro-htu__heading">
              {%- if section.settings.heading_accent != blank -%}
                {%- assign accent = section.settings.heading_accent -%}
                {%- assign plain  = section.settings.heading | remove: accent -%}
                {{ plain }}<em>{{ accent }}</em>
              {%- else -%}
                {{ section.settings.heading }}
              {%- endif -%}
            </h2>
          {%- endif -%}
        </div>

        {%- comment -%} Steps list {%- endcomment -%}
        {%- assign mf_steps = product.metafields.cro.steps.value -%}
        <ol class="cro-htu-steps">
          {%- if mf_steps.size > 0 -%}
            {%- for step in mf_steps -%}
              <li class="cro-htu-step cro-fade-up delay-{{ forloop.index }}">
                <div class="cro-htu-step__num" aria-hidden="true">{{ forloop.index }}</div>
                <div class="cro-htu-step__content">
                  {%- if step.title.value != blank -%}
                    <h3 class="cro-htu-step__title">{{ step.title.value }}</h3>
                  {%- endif -%}
                  {%- if step.description.value != blank -%}
                    <p class="cro-htu-step__desc">{{ step.description.value }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'step' -%}
                <li
                  class="cro-htu-step cro-fade-up delay-{{ forloop.index }}"
                  {{ block.shopify_attributes }}
                >
                  <div class="cro-htu-step__num" aria-hidden="true">{{ forloop.index }}</div>
                  <div class="cro-htu-step__content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="cro-htu-step__title">{{ block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if block.settings.description != blank -%}
                      <p class="cro-htu-step__desc">{{ block.settings.description }}</p>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </ol>

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="cro-btn cro-btn--dark cro-fade-up delay-5">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}

      </div>{%- comment -%} /.cro-htu__left {%- endcomment -%}

      {%- comment -%} ── RIGHT: Visual card ── {%- endcomment -%}
      <div class="cro-htu__right cro-fade-up delay-2">
        <div class="cro-htu__visual" style="background-color: {{ htu_visual_bg }};">
          {%- if htu_image != blank -%}
            <img
              src="{{ htu_image | img_url: '700x' }}"
              alt="{{ htu_image.alt | default: 'How to use GOJU' | escape }}"
              loading="lazy"
              width="{{ htu_image.width }}"
              height="{{ htu_image.height }}"
              class="cro-htu__img"
            >
          {%- else -%}
            {%- comment -%} Decorative placeholder {%- endcomment -%}
            <div class="cro-htu__visual-placeholder" aria-hidden="true">
              <div class="cro-htu__blob"></div>
              <span class="cro-htu__placeholder-icon">🥤</span>
            </div>
          {%- endif -%}

          {%- if section.settings.badge_text != blank -%}
            <div class="cro-htu__badge">
              <span>{{ section.settings.badge_text }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var section = document.getElementById('how-to-use-{{ section.id }}');
  if (!section) return;

  var items = section.querySelectorAll('.cro-fade-up');
  if (!items.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.10 });

    items.forEach(function (el) { observer.observe(el); });
  } else {
    items.forEach(function (el) { el.classList.add('is-visible'); });
  }
})();
</script>

{% schema %}
{
  "name": "How To Use",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Shake the bottle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Natural ingredients settle — give it a good shake before opening to mix everything evenly."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker label",
      "default": "Simple Routine"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to use Action Shot"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent word(s) in heading",
      "default": "Action Shot",
      "info": "These exact words will be highlighted in accent colour. Must match text in Heading exactly."
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour",
      "default": "#1D7A3F",
      "info": "Controls the heading accent word colour."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Step number colour",
      "default": "#F9C74F",
      "info": "Controls the number colour inside the step circles."
    },
    {
      "type": "header",
      "content": "Right Visual"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Visual image",
      "info": "Optional. If blank, pulls from product wellness_image metafield."
    },
    {
      "type": "color",
      "id": "visual_bg_color",
      "label": "Visual card background colour",
      "info": "If blank, uses product secondary_color metafield. Fallback: #EEEBE4."
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "30-Day Guarantee",
      "info": "Short label shown on the visual card"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop Action Shot"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "How To Use",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Shake the bottle",
            "description": "Natural ingredients settle — give it a good shake before opening to mix everything evenly."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Drink in the morning",
            "description": "Take your shot first thing in the morning, ideally before breakfast for maximum absorption."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Or before a workout",
            "description": "The ginger and turmeric blend provides natural energy support before training."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Make it a daily habit",
            "description": "Best results come with consistent daily use. Subscribe so you never miss a day."
          }
        }
      ]
    }
  ]
}
{% endschema %}
