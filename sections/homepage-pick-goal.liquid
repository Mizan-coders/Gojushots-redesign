{%- style -%}
  .pg-{{ section.id }} {
    background: {{ section.settings.bg_color | default: 'var(--goju-page-bg, #f5f0e8)' }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .pg-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Header ── */
  .pg-{{ section.id }} .pg__header {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 48px;
    text-align: center;
  }
  .pg-{{ section.id }} .pg__eyebrow {
    font-size: {{ section.settings.eyebrow_size | default: 11 }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.eyebrow_color | default: '#1F1A17' }};
    margin-bottom: 12px;
  }
  .pg-{{ section.id }} .pg__heading {
    font-size: clamp({{ section.settings.heading_size | times: 0.6 | round }}px, {{ section.settings.heading_size | times: 0.08 }}vw, {{ section.settings.heading_size | default: 60 }}px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: {{ section.settings.heading_color | default: '#191917' }};
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .pg-{{ section.id }} .pg__heading em {
    font-style: italic;
    font-weight: 700;
    text-transform: none;
    color: {{ section.settings.heading_color | default: '#191917' }};
    opacity: 0.7;
    letter-spacing: 0;
  }
  .pg-{{ section.id }} .pg__sub {
    font-size: {{ section.settings.subtext_size | default: 16 }}px;
    color: {{ section.settings.subtext_color | default: '#888888' }};
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── Filter bar ── */
  .pg-{{ section.id }} .pg__filters {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto 48px;
    padding: 0 40px 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .pg-{{ section.id }} .pg__filters::-webkit-scrollbar { display: none; }
  .pg-{{ section.id }} .pg-filter-btn {
    padding: 10px 22px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid rgba(0,0,0,0.2);
    background: transparent;
    color: #191917;
    transition: all 0.2s;
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .pg-{{ section.id }} .pg-filter-btn.is-active {
    background: #1F1A17;
    color: #F7F1E4;
    border-color: #1F1A17;
  }
  .pg-{{ section.id }} .pg-filter-btn:not(.is-active):hover {
    border-color: #191917;
  }
  .pg-{{ section.id }} .pg-filter-btn .tab-icon-img {
    width: 18px;
    height: 18px;
    object-fit: contain;
    display: inline-block;
    vertical-align: middle;
    margin-right: 4px;
    flex-shrink: 0;
  }

  /* ── Products grid ── */
  .pg-{{ section.id }} .pg__grid-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    overflow: visible;
  }
  {%- assign card_gap = section.settings.card_gap | default: 20 -%}
  .pg-{{ section.id }} .pg__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns | default: 4 }}, 1fr);
    gap: {{ card_gap }}px;
  }

  /* ── Slider mode ── */
  .pg-{{ section.id }} .pg__grid--slider {
    display: block !important;
  }
  .pg-{{ section.id }} .pg__grid--slider .slick-list {
    overflow: hidden;
  }
  .pg-{{ section.id }} .pg__grid--slider .slick-track {
    display: flex;
    align-items: stretch;
    gap: {{ card_gap }}px;
  }
  .pg-{{ section.id }} .pg__grid--slider .slick-slide {
    height: auto;
  }
  .pg-{{ section.id }} .pg__grid--slider .slick-slide > div,
  .pg-{{ section.id }} .pg__grid--slider .slick-slide .pg__card {
    height: 100%;
  }
  /* Slider nav row — arrows left, CTA right */
  .pg-{{ section.id }} .pg__slider-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    padding: 0 40px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
  .pg-{{ section.id }} .pg__slider-nav .slick-prev { order: 1; }
  .pg-{{ section.id }} .pg__slider-nav .slick-next { order: 2; }
  .pg-{{ section.id }} .pg__slider-nav .pg__cta-btn { order: 3; margin-left: auto; }
  .pg-{{ section.id }} .pg__slider-nav .slick-prev,
  .pg-{{ section.id }} .pg__slider-nav .slick-next {
    position: static;
    transform: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #1F1A17;
    border: none;
    cursor: pointer;
    font-size: 0;
    flex-shrink: 0;
    transition: background 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .pg-{{ section.id }} .pg__slider-nav .slick-prev::before {
    content: '←';
    font-size: 16px;
    color: #F7F1E4;
    line-height: 1;
  }
  .pg-{{ section.id }} .pg__slider-nav .slick-next::before {
    content: '→';
    font-size: 16px;
    color: #F7F1E4;
    line-height: 1;
  }
  .pg-{{ section.id }} .pg__slider-nav .slick-prev:hover,
  .pg-{{ section.id }} .pg__slider-nav .slick-next:hover { background: #6B5E52; }
  .pg-{{ section.id }} .pg__slider-nav .slick-disabled { opacity: 0.3; pointer-events: none; }
  @media screen and (max-width: 989px) {
    .pg-{{ section.id }} .pg__slider-nav { padding: 0 20px; }
  }

  /* ── Product card ── */
  .pg-{{ section.id }} .pg__card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: transform 0.3s, box-shadow 0.3s;
    border: 1px solid rgba(0,0,0,0.06);
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }
  .pg-{{ section.id }} .pg__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
  }
  .pg-{{ section.id }} .pg__card:hover .pg__quick-add {
    opacity: 1;
    transform: translateY(0);
  }
  .pg-{{ section.id }} .pg__card:hover .pg__card-info {
    padding-bottom: 56px;
  }

  /* Image */
  .pg-{{ section.id }} .pg__card-img {
    aspect-ratio: 1 / 1;
    width: 100%;
    display: block;
    position: relative;
    overflow: hidden;
  }
  .pg-{{ section.id }} .pg__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.3s ease;
    display: block;
  }
  .pg-{{ section.id }} .pg__card:hover .pg__card-img img {
    transform: scale(1.04);
  }

  /* Badge */
  .pg-{{ section.id }} .pg__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    z-index: 2;
  }
  .pg-{{ section.id }} .pg__badge--bestseller {
    background: var(--goju-accent);
    color: var(--goju-accent-text);
  }
  .pg-{{ section.id }} .pg__badge--new {
    background: #1F1A17;
    color: #F7F1E4;
  }

  /* Card info */
  .pg-{{ section.id }} .pg__card-info {
    padding: 16px 18px 20px;
    position: relative;
    z-index: 2;
    background: white;
    transition: padding-bottom 0.35s ease;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pg-{{ section.id }} .pg__goal-tags {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(31,26,23,0.6);
    margin-bottom: 4px;
  }
  .pg-{{ section.id }} .pg__card-name {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 0.5px;
    color: #191917;
    margin: 0 0 4px;
    text-transform: uppercase;
  }
  .pg-{{ section.id }} .pg__card-desc {
    font-size: 13px;
    color: rgba(25,25,23,0.55);
    line-height: 1.4;
    margin-bottom: 12px;
    flex: 1;
  }
  .pg-{{ section.id }} .pg__card-footer {
    display: flex;
    flex-direction: column;
  }
  .pg-{{ section.id }} .pg__price {
    font-size: 20px;
    font-weight: 700;
    color: #191917;
  }
  .pg-{{ section.id }} .pg__price span {
    font-size: 12px;
    font-weight: 400;
    color: rgba(25,25,23,0.5);
  }
  .pg-{{ section.id }} .pg__stars {
    font-size: 13px;
    color: rgba(25,25,23,0.5);
    margin-top: 4px;
  }
  .pg-{{ section.id }} .pg__stars strong {
    color: #fbbf24;
  }

  /* Quick-add */
  .pg-{{ section.id }} .pg__quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #1F1A17;
    color: #F7F1E4;
    text-align: center;
    padding: 14px 16px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    border-radius: 0 0 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    z-index: 3;
    border: none;
    width: 100%;
  }
  .pg-{{ section.id }} .pg__quick-add::before {
    content: '+';
    font-size: 18px;
    font-weight: 400;
    line-height: 1;
  }

  /* Shop All CTA */
  .pg-{{ section.id }} .pg__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    border-radius: 50px;
    background: #1F1A17;
    color: #F7F1E4;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 0.2s;
  }
  .pg-{{ section.id }} .pg__cta-btn:hover {
    background: #6B5E52;
    color: #F7F1E4;
  }

  /* ── Tablet ── */
  @media screen and (max-width: 989px) {
    .pg-{{ section.id }} .pg__header,
    .pg-{{ section.id }} .pg__grid-wrap { padding-left: 20px; padding-right: 20px; }
    .pg-{{ section.id }} .pg__filters { padding-left: 20px; padding-right: 20px; justify-content: flex-start; flex-wrap: nowrap; }
    .pg-{{ section.id }} .pg__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .pg-{{ section.id }} .pg__grid--single { grid-template-columns: 1fr !important; max-width: 360px; }
    .pg-{{ section.id }} .pg__quick-add { opacity: 1; transform: translateY(0); font-size: 12px; padding: 12px 16px; }
    .pg-{{ section.id }} .pg__card-info { padding-bottom: 56px !important; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .pg-{{ section.id }} .pg__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .pg-{{ section.id }} .pg__grid--single { grid-template-columns: 1fr !important; max-width: 100%; }
    .pg-{{ section.id }} .pg__card-name { font-size: 16px; }
    .pg-{{ section.id }} .pg__price { font-size: 16px; }
    .pg-{{ section.id }} .pg__quick-add { font-size: 11px; padding: 11px 14px; }
    .pg-{{ section.id }} .pg__filter-btn { font-size: 12px; padding: 8px 16px; }

    /* Mobile page wrapper: span full grid width, hidden by default */
    .pg-{{ section.id }} .pg__mob-page {
      display: none;
      grid-column: 1 / -1;
    }
    .pg-{{ section.id }} .pg__mob-page.is-active {
      display: grid;
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    /* Nav row on mobile */
    .pg-{{ section.id }} .pg__slider-nav {
      flex-wrap: nowrap;
      align-items: center;
      padding: 0 20px;
      margin-top: 20px;
    }
    /* Hide desktop Slick arrows on mobile */
    .pg-{{ section.id }} .pg__slider-nav .slick-prev,
    .pg-{{ section.id }} .pg__slider-nav .slick-next {
      display: none !important;
    }
    /* Dot container */
    .pg-{{ section.id }} .pg__mob-dots {
      display: flex;
      align-items: center;
      gap: 6px;
      order: 1;
    }
    /* Individual dots */
    .pg-{{ section.id }} .pg__mob-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(0,0,0,0.2);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s, width 0.2s;
      flex-shrink: 0;
    }
    .pg-{{ section.id }} .pg__mob-dot.is-active {
      background: #1F1A17;
      width: 20px;
      border-radius: 4px;
    }
    .pg-{{ section.id }} .pg__slider-nav .pg__cta-btn {
      order: 2;
      margin-left: auto;
    }
  }
{%- endstyle -%}

<div class="pg-{{ section.id }}">

  {%- comment -%} Header {%- endcomment -%}
  <div class="pg__header">
    {%- if section.settings.eyebrow != blank -%}
      <div class="pg__eyebrow">{{ section.settings.eyebrow | escape }}</div>
    {%- endif -%}
    <h2 class="pg__heading">
      {{- section.settings.heading | escape -}}
      {%- if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent | escape }}</em>{%- endif -%}
    </h2>
    {%- if section.settings.subtext != blank -%}
      <p class="pg__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Filter buttons {%- endcomment -%}
  <div class="pg__filters" id="PgFilters-{{ section.id }}">
    <button class="pg-filter-btn is-active" data-goal="all">
      {{- section.settings.tab_all_label | default: 'All Products' | escape -}}
    </button>
    {%- for i in (1..6) -%}
      {%- assign icon_key  = 'tab_' | append: i | append: '_icon' -%}
      {%- assign img_key   = 'tab_' | append: i | append: '_image' -%}
      {%- assign label_key = 'tab_' | append: i | append: '_label' -%}
      {%- if section.settings[label_key] != blank -%}
        <button
          class="pg-filter-btn"
          data-goal="{{ section.settings[label_key] | downcase | strip | escape }}"
        >
          {%- if section.settings[img_key] != blank -%}
            <img class="tab-icon-img" src="{{ section.settings[img_key] | image_url: width: 40 }}" alt="" width="20" height="20" loading="lazy" aria-hidden="true">
          {%- elsif section.settings[icon_key] != blank -%}
            {{- section.settings[icon_key] -}}&nbsp;
          {%- endif -%}
          {{- section.settings[label_key] | escape -}}
        </button>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Products grid {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="pg__grid-wrap">
      <div class="pg__grid" id="PgGrid-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}
            {%- assign card_product = block.settings.product -%}
            {%- assign card_url = card_product.url | default: '#' -%}
            {%- if block.settings.image != blank -%}
              {%- assign card_image = block.settings.image -%}
            {%- elsif card_product.featured_image != blank -%}
              {%- assign card_image = card_product.featured_image -%}
            {%- else -%}
              {%- assign card_image = card_product.images[1] -%}
            {%- endif -%}
            {%- assign card_price = card_product.selected_or_first_available_variant.price -%}
            {%- assign card_title = block.settings.name_override | default: card_product.title -%}
            {%- assign goals_raw = block.settings.goals | default: '' | downcase | strip -%}
            <div
              class="pg__card"
              data-goals="{{ goals_raw | escape }}"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Image {%- endcomment -%}
              <a href="{{ card_url }}" class="pg__card-img" aria-label="{{ card_title | escape }}" tabindex="-1">
                {%- if card_image != blank -%}
                  <img
                    src="{{ card_image | image_url: width: 600 }}"
                    alt="{{ card_image.alt | default: card_title | escape }}"
                    width="600"
                    height="600"
                    loading="lazy"
                  >
                {%- endif -%}

                {%- comment -%} Badge {%- endcomment -%}
                {%- if block.settings.badge_type != 'none' and block.settings.badge_text != blank -%}
                  <div class="pg__badge pg__badge--{{ block.settings.badge_type }}">
                    {{- block.settings.badge_text | escape -}}
                  </div>
                {%- endif -%}
              </a>

              {%- comment -%} Card info {%- endcomment -%}
              <div class="pg__card-info">
                {%- if block.settings.goal_label != blank -%}
                  <div class="pg__goal-tags">{{ block.settings.goal_label | escape }}</div>
                {%- endif -%}
                <a href="{{ card_url }}" style="text-decoration:none;">
                  <h3 class="pg__card-name">{{ card_title | escape }}</h3>
                </a>
                {%- if block.settings.short_desc != blank -%}
                  <p class="pg__card-desc">{{ block.settings.short_desc | escape }}</p>
                {%- elsif card_product.description != blank -%}
                  <p class="pg__card-desc">{{ card_product.description | strip_html | truncatewords: 12 }}</p>
                {%- endif -%}
                <div class="pg__card-footer">
                  <div>
                    <div class="pg__price">
                      {%- if block.settings.price_text != blank -%}
                        {{ block.settings.price_text | escape }}
                        {%- if block.settings.pack_text != blank -%}
                          <span>{{ block.settings.pack_text | escape }}</span>
                        {%- endif -%}
                      {%- elsif card_price != blank -%}
                        {{ card_price | money }}
                        {%- if block.settings.pack_text != blank -%}
                          <span>{{ block.settings.pack_text | escape }}</span>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                    {%- if block.settings.review_count != blank -%}
                      <div class="pg__stars">
                        {%- assign star_count = block.settings.star_rating | default: 5 -%}
                        <strong>
                          {%- for i in (1..star_count) -%}★{%- endfor -%}
                        </strong>
                        ({{ block.settings.review_count | escape }})
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>

              {%- comment -%} Quick-add {%- endcomment -%}
              {%- if card_product != blank -%}
                {%- assign first_variant = card_product.selected_or_first_available_variant -%}
                <button
                  class="pg__quick-add"
                  data-variant-id="{{ first_variant.id }}"
                  aria-label="Add {{ card_title | escape }} to cart"
                >
                  <span class="pg__quick-add-text">Add to Cart</span>
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pg__slider-nav" id="PgSliderNav-{{ section.id }}">
        {%- comment -%} Shop All CTA — right-aligned via margin-left: auto {%- endcomment -%}
        {%- if section.settings.cta_label != blank -%}
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="pg__cta-btn"
          >
            {{- section.settings.cta_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</div>

<script>
(function() {
  // Capture window.fetch NOW — before slidecarthq.js patches it
  var _nativeFetch = window.fetch.bind(window);

  var section = document.querySelector('.pg-{{ section.id }}');
  if (!section) return;

  var filterBtns = section.querySelectorAll('.pg-filter-btn');
  var cards      = Array.from(section.querySelectorAll('.pg__card'));
  var grid       = section.querySelector('.pg__grid');

  var THRESHOLD   = {{ section.settings.slider_threshold | default: 4 }};
  var SLIDER_COLS = parseInt('{{ section.settings.columns | default: 4 }}', 10);

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function slickReady() {
    return typeof window.jQuery !== 'undefined' && typeof window.jQuery.fn.slick !== 'undefined';
  }

  function getMatching(goal) {
    return cards.filter(function(card) {
      if (goal === 'all') return true;
      return (card.dataset.goals || '').toLowerCase().indexOf(goal) !== -1;
    });
  }

  var sliderNav = section.querySelector('.pg__slider-nav');

  // ── Mobile custom pager (no Slick) ───────────────────────────────────────────
  var mobCurrentPage = 0;
  var mobPages       = [];
  var mobDotsEl      = null;

  function unwrapPages() {
    Array.from(grid.querySelectorAll('.pg__mob-page')).forEach(function(page) {
      while (page.firstChild) grid.insertBefore(page.firstChild, page);
      grid.removeChild(page);
    });
    mobPages = [];
  }

  function mobGoToPage(n) {
    mobCurrentPage = Math.max(0, Math.min(n, mobPages.length - 1));
    mobPages.forEach(function(p, i) { p.classList.toggle('is-active', i === mobCurrentPage); });
    if (mobDotsEl) {
      Array.from(mobDotsEl.querySelectorAll('.pg__mob-dot')).forEach(function(d, i) {
        d.classList.toggle('is-active', i === mobCurrentPage);
      });
    }
  }

  function initMobilePager(visibleCards) {
    mobCurrentPage = 0;
    unwrapPages();

    // Build page wrappers
    for (var i = 0; i < visibleCards.length; i += 4) {
      var page = document.createElement('div');
      page.className = 'pg__mob-page' + (i === 0 ? ' is-active' : '');
      visibleCards.slice(i, Math.min(i + 4, visibleCards.length)).forEach(function(c) {
        c.style.display = '';
        page.appendChild(c);
      });
      grid.appendChild(page);
      mobPages.push(page);
    }

    // Build dots
    if (!mobDotsEl) {
      mobDotsEl = document.createElement('div');
      mobDotsEl.className = 'pg__mob-dots';
      sliderNav.insertBefore(mobDotsEl, sliderNav.firstChild);
    }
    mobDotsEl.innerHTML = '';
    if (mobPages.length > 1) {
      mobPages.forEach(function(_, i) {
        var btn = document.createElement('button');
        btn.className = 'pg__mob-dot' + (i === 0 ? ' is-active' : '');
        btn.setAttribute('aria-label', 'Page ' + (i + 1));
        (function(idx) {
          btn.addEventListener('click', function() { mobGoToPage(idx); });
        })(i);
        mobDotsEl.appendChild(btn);
      });
      mobDotsEl.style.display = 'flex';
    } else {
      mobDotsEl.style.display = 'none';
    }

    // Swipe handler
    var touchStartX = 0;
    function onTouchStart(e) { touchStartX = e.touches[0].clientX; }
    function onTouchEnd(e) {
      var dx = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) mobGoToPage(mobCurrentPage + (dx > 0 ? 1 : -1));
    }
    if (grid._pgMobStart) {
      grid.removeEventListener('touchstart', grid._pgMobStart);
      grid.removeEventListener('touchend', grid._pgMobEnd);
    }
    grid._pgMobStart = onTouchStart;
    grid._pgMobEnd   = onTouchEnd;
    grid.addEventListener('touchstart', onTouchStart, { passive: true });
    grid.addEventListener('touchend', onTouchEnd);
  }

  function destroyMobilePager() {
    if (grid._pgMobStart) {
      grid.removeEventListener('touchstart', grid._pgMobStart);
      grid.removeEventListener('touchend', grid._pgMobEnd);
      delete grid._pgMobStart;
      delete grid._pgMobEnd;
    }
    if (mobDotsEl) {
      mobDotsEl.innerHTML = '';
      mobDotsEl.style.display = 'none';
    }
    unwrapPages();
  }

  // ── Slider (desktop/tablet via Slick, mobile via custom pager) ───────────────
  function initSlider(goal) {
    var isMobile = window.innerWidth <= 767;

    if (isMobile) {
      // Destroy Slick if active
      if (slickReady()) {
        var $g = jQuery(grid);
        if ($g.hasClass('slick-initialized')) $g.slick('unslick');
      }
      grid.classList.remove('pg__grid--slider');
      // Filter cards then page them
      cards.forEach(function(c) {
        var ok = goal === 'all' || (c.dataset.goals || '').toLowerCase().indexOf(goal) !== -1;
        c.style.display = ok ? '' : 'none';
      });
      var visible = cards.filter(function(c) { return c.style.display !== 'none'; });
      initMobilePager(visible);
    } else {
      if (!slickReady()) return;
      destroyMobilePager();
      var $grid = jQuery(grid);
      if ($grid.hasClass('slick-initialized')) $grid.slick('unslick');
      grid.classList.add('pg__grid--slider');
      grid.classList.remove('pg__grid--single');
      cards.forEach(function(c) { c.style.display = ''; });
      var $nav = jQuery(sliderNav);
      $grid.slick({
        slidesToShow: SLIDER_COLS,
        slidesToScroll: 1,
        infinite: false,
        swipe: true,
        touchMove: true,
        arrows: true,
        appendArrows: $nav,
        dots: false,
        speed: 400,
        responsive: [
          { breakpoint: 990, settings: { slidesToShow: 2, arrows: true, appendArrows: $nav } }
        ]
      });
      if (goal !== 'all') {
        $grid.slick('slickFilter', '[data-goals*="' + goal + '"]');
      }
    }
  }

  function destroySlider() {
    destroyMobilePager();
    if (slickReady()) {
      var $grid = jQuery(grid);
      if ($grid.hasClass('slick-initialized')) $grid.slick('unslick');
      grid.classList.remove('pg__grid--slider');
    }
  }

  // ── Filter + conditional slider ─────────────────────────────────────────────
  function applyFilter(goal) {
    var matching = getMatching(goal);
    var isMobile = window.innerWidth <= 767;
    // On mobile: slider only when >4 products (5+); ≤4 = static 2×2 grid, no dots
    var effectiveThreshold = isMobile ? 5 : THRESHOLD;
    if (matching.length >= effectiveThreshold) {
      initSlider(goal);
    } else {
      destroySlider();
      cards.forEach(function(card) {
        var matches = goal === 'all' || (card.dataset.goals || '').toLowerCase().indexOf(goal) !== -1;
        card.style.display = matches ? '' : 'none';
      });
      grid.classList.toggle('pg__grid--single', matching.length === 1);
    }
  }

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      applyFilter(btn.dataset.goal);
    });
  });

  // Init: wait for DOMContentLoaded on first load; run immediately on customizer re-renders
  function tryInit() {
    if (slickReady()) {
      applyFilter('all');
    }
    // If Slick not ready yet, DOMContentLoaded hasn't fired — the listener below handles it
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryInit);
  } else {
    tryInit();
  }

  // Re-evaluate on resize (e.g. orientation change mobile ↔ desktop)
  var pgResizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(pgResizeTimer);
    pgResizeTimer = setTimeout(function() {
      var activeBtn = section.querySelector('.pg-filter-btn.is-active');
      if (activeBtn) applyFilter(activeBtn.dataset.goal);
    }, 250);
  });

  // Quick-add: use _nativeFetch (captured before Slide Cart patches window.fetch)
  // so Slide Cart never intercepts this call and its own cart UI never opens.
  // After add, open Dawn's cart-drawer directly via renderContents.
  section.querySelectorAll('.pg__quick-add').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var variantId = parseInt(btn.dataset.variantId);
      if (!variantId) return;

      var label = btn.querySelector('.pg__quick-add-text');
      btn.disabled = true;
      btn.style.opacity = '0.7';
      if (label) label.textContent = 'Adding…';

      _nativeFetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      })
      .then(function(res) {
        if (!res.ok) return res.json().then(function(err) { throw new Error(err.description || 'Error'); });
        return res.json();
      })
      .then(function() {
        if (label) label.textContent = '✓ Added!';
        btn.style.opacity = '1';

        var cart = document.querySelector('cart-drawer');
        if (!cart) { window.location.href = '/cart'; return; }

        // Fix is-empty on the outer wrapper (renderContents only clears it from .drawer__inner)
        cart.classList.remove('is-empty');
        fetch('/?sections=cart-drawer,cart-icon-bubble')
          .then(function(r) { return r.json(); })
          .then(function(sections) {
            cart.renderContents({ id: variantId, sections: sections });
          })
          .catch(function() { window.location.href = '/cart'; });

        setTimeout(function() {
          if (label) label.textContent = 'Add to Cart';
          btn.disabled = false;
          btn.style.opacity = '';
        }, 2000);
      })
      .catch(function(err) {
        if (label) label.textContent = err.message || 'Try again';
        setTimeout(function() {
          if (label) label.textContent = 'Add to Cart';
          btn.disabled = false;
          btn.style.opacity = '';
        }, 2000);
      });
    });
  });
})();
</script>

