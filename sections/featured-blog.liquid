<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── HOMEPAGE BLOG ── */
  .homepage-blog {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 40px;
    padding-right: 40px;
  }

  /* ── Section header ── */
  .homepage-blog__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .homepage-blog__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(31,26,23,0.6);
    margin-bottom: 12px;
  }
  .homepage-blog__title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: #191917;
    margin: 0;
  }
  .homepage-blog__title em {
    font-style: italic;
    color: rgba(31,26,23,0.7);
  }
  .homepage-blog__sub {
    font-size: 16px;
    color: #888;
    margin: 12px auto 0;
    max-width: 480px;
    line-height: 1.6;
  }

  /* ── Grid mode ── */
  .homepage-blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Slider mode overrides ── */
  .homepage-blog__grid--slider {
    display: flex;
    gap: 0;
  }
  .homepage-blog__grid--slider .homepage-blog__card-item {
    flex-shrink: 0;
  }

  /* ── Card ── */
  .homepage-blog__card {
    border-radius: 16px;
    overflow: hidden;
    background: white;
    border: 1px solid rgba(0,0,0,0.06);
    transition: transform 0.3s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .homepage-blog__card:hover {
    transform: translateY(-4px);
  }

  /* ── Card image ── */
  .homepage-blog__card-image {
    height: 200px;
    position: relative;
    overflow: hidden;
    background: #f0ede5;
    flex-shrink: 0;
  }
  .homepage-blog__card-image img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }
  .homepage-blog__card:hover .homepage-blog__card-image img {
    transform: scale(1.04);
  }
  .homepage-blog__card-tag {
    position: absolute;
    top: 12px; left: 12px;
    background: #1F1A17;
    color: #F7F1E4;
    font-size: 10px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    z-index: 1;
  }

  /* ── Card body ── */
  .homepage-blog__card-body {
    padding: 16px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .homepage-blog__card-title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: #191917;
    margin: 0 0 8px;
  }
  .homepage-blog__card-meta {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .homepage-blog__card-cta {
    font-size: 13px;
    font-weight: 600;
    color: #1F1A17;
    margin-top: 10px;
    display: inline-block;
    text-decoration: none;
    transition: color 0.2s;
  }
  .homepage-blog__card-cta:hover {
    color: #191917;
  }

  /* ── Slider buttons ── */
  .homepage-blog__slider-buttons {
    margin-top: 24px;
  }

  /* ── View all ── */
  .homepage-blog__view-all {
    text-align: center;
    margin-top: 40px;
  }

  /* ── Responsive ── */
  @media screen and (max-width: 989px) {
    .homepage-blog {
      padding-left: 20px;
      padding-right: 20px;
    }
    .homepage-blog__grid:not(.homepage-blog__grid--slider) {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }
  @media screen and (max-width: 479px) {
    .homepage-blog__grid:not(.homepage-blog__grid--slider) {
      grid-template-columns: 1fr;
    }
    .homepage-blog__header {
      margin-bottom: 32px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign posts_displayed = section.settings.post_limit
  if section.settings.blog != blank
    if section.settings.post_limit > section.settings.blog.articles_count
      assign posts_displayed = section.settings.blog.articles_count
    endif
  endif
  assign show_view_all = false
  if section.settings.show_view_all and section.settings.blog != blank and posts_displayed < section.settings.blog.articles_count
    assign show_view_all = true
  endif
-%}

<div class="homepage-blog section-{{ section.id }}-padding">

  {%- comment -%} ── Section header ── {%- endcomment -%}
  <div class="homepage-blog__header">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="homepage-blog__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
    {%- endif -%}
    <h2 class="homepage-blog__title">
      {{- section.settings.heading | escape -}}
      {%- if section.settings.heading_italic != blank -%}
        <em> {{ section.settings.heading_italic | escape }}</em>
      {%- endif -%}
    </h2>
    {%- if section.settings.subtext != blank -%}
      <p class="homepage-blog__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── Blog posts ── {%- endcomment -%}
  {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}

    {%- if section.settings.enable_slider -%}
      <slider-component class="slider-mobile-gutter">
    {%- endif -%}

    <ul
      {% if section.settings.enable_slider %}
        id="Slider-{{ section.id }}"
        class="homepage-blog__grid homepage-blog__grid--slider grid grid--peek grid--2-col-tablet grid--3-col-desktop slider slider--tablet"
      {% else %}
        class="homepage-blog__grid"
      {% endif %}
      role="list"
    >
      {%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
        {%- liquid
          assign word_count = article.content | strip_html | split: ' ' | size
          assign read_time = word_count | divided_by: 200 | at_least: 1
          assign first_tag = article.tags | first
        -%}
        <li
          {% if section.settings.enable_slider %}
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="homepage-blog__card-item grid__item slider__slide"
          {% else %}
            class="homepage-blog__card-item"
          {% endif %}
        >
          <article>
            <a href="{{ article.url }}" class="homepage-blog__card" aria-label="{{ article.title | escape }}">

              {%- if section.settings.show_image and article.image != blank -%}
                <div class="homepage-blog__card-image">
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | default: article.title | escape }}"
                    loading="lazy"
                    width="600"
                    height="400"
                  >
                  {%- if first_tag != blank -%}
                    <span class="homepage-blog__card-tag">{{ first_tag | escape }}</span>
                  {%- endif -%}
                </div>
              {%- elsif section.settings.show_image -%}
                <div class="homepage-blog__card-image">
                  {%- if first_tag != blank -%}
                    <span class="homepage-blog__card-tag">{{ first_tag | escape }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="homepage-blog__card-body">
                <p class="homepage-blog__card-title">{{ article.title | escape }}</p>
                {%- if section.settings.show_date -%}
                  <p class="homepage-blog__card-meta">{{ read_time }} min read · {{ article.published_at | date: "%B %d, %Y" }}</p>
                {%- endif -%}
                <span class="homepage-blog__card-cta">Learn More &rarr;</span>
              </div>

            </a>
          </article>
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.enable_slider -%}
      <div class="slider-buttons no-js-hidden homepage-blog__slider-buttons">
        <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">{% render 'icon-caret' %}</button>
        <div class="slider-counter caption">
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ posts_displayed }}</span>
        </div>
        <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">{% render 'icon-caret' %}</button>
      </div>
      </slider-component>
    {%- endif -%}

    {%- if show_view_all -%}
      <div class="homepage-blog__view-all">
        <a href="{{ section.settings.blog.url }}" class="button">
          {{ 'sections.featured_blog.view_all' | t }}
        </a>
      </div>
    {%- endif -%}

  {%- else -%}
    <div class="homepage-blog__grid">
      {%- for i in (1..3) -%}
        <div class="homepage-blog__card-item">
          <div class="homepage-blog__card">
            <div class="homepage-blog__card-image">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="homepage-blog__card-body">
              <p class="homepage-blog__card-title">{{ 'sections.featured_blog.onboarding_title' | t }}</p>
              <p class="homepage-blog__card-meta">{{ 'sections.featured_blog.onboarding_content' | t }}</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "t:sections.featured-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "default": "Health & Wellness",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Dive deeper",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "default": "into health.",
      "label": "Heading italic part"
    },
    {
      "type": "text",
      "id": "subtext",
      "default": "Expert-led guides on nutrition, recovery, sleep and everyday performance.",
      "label": "Subtext"
    },
    {
      "type": "header",
      "content": "Blog posts"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.featured-blog.settings.blog.label"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 2,
      "max": 9,
      "step": 1,
      "default": 3,
      "label": "Number of posts"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "Show date & read time"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_view_all.label"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "default": false,
      "label": "Enable slider with arrows"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-blog.presets.name",
      "settings": {
        "blog": "News"
      }
    }
  ]
}
{% endschema %}
