{% style %}
  .announcement-bar--goju {
    background-color: {{ section.settings.bg_color | default: '#191917' }};
    border-bottom: none;
    padding: 10px 20px;
  }
  .announcement-bar--goju .announcement-bar__message {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    color: var(--goju-accent);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0;
    margin: 0;
  }
  .announcement-bar--goju .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .announcement-bar--goju .announcement-bar__item a {
    color: var(--goju-accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .announcement-bar--goju .announcement-bar__item a:hover {
    text-decoration: underline;
    background: none;
  }
  .announcement-bar--goju .announcement-bar__item .icon-arrow {
    width: 1.2rem;
    height: 1.2rem;
    color: var(--goju-accent);
  }
  .announcement-bar--goju .announcement-bar__sep {
    color: rgba(255, 255, 255, 0.35);
    margin: 0 10px;
    font-size: 12px;
  }
  @media screen and (max-width: 749px) {
    .announcement-bar--goju .announcement-bar__message {
      font-size: 13px;
    }
  }
{% endstyle %}

<div class="announcement-bar announcement-bar--goju" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  <p class="announcement-bar__message">
    {%- assign visible_blocks = section.blocks | where: 'type', 'announcement' -%}
    {%- for block in visible_blocks -%}
      {%- if block.settings.text != blank -%}
        <span class="announcement-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="focus-inset">
              {{ block.settings.text | escape }}
              {% render 'icon-arrow' %}
            </a>
          {%- else -%}
            {{ block.settings.text | escape }}
          {%- endif -%}
        </span>
        {%- unless forloop.last -%}
          <span class="announcement-bar__sep" aria-hidden="true">·</span>
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  </p>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#191917"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "select",
          "id": "color_scheme",
          "options": [
            {
              "value": "accent-1",
              "label": "t:sections.all.colors.accent_1.label"
            },
            {
              "value": "accent-2",
              "label": "t:sections.all.colors.accent_2.label"
            },
            {
              "value": "background-1",
              "label": "t:sections.all.colors.background_1.label"
            },
            {
              "value": "background-2",
              "label": "t:sections.all.colors.background_2.label"
            },
            {
              "value": "inverse",
              "label": "t:sections.all.colors.inverse.label"
            }
          ],
          "default": "accent-1",
          "label": "t:sections.all.colors.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
