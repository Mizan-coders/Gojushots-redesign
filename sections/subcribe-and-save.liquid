{%- style -%}
      .subscribe h2{
            max-width: 600px;
            color: var(--Greyscale-Feature, #191917);
            text-align: center;
            font-size: 34px;
            font-weight: 900;
            line-height: 115%;
            margin: auto;
      }
      .subscribe p {
          max-width: 600px;
          color: var(--Greyscale-8-Middle-Shadow, #4B4A46);
          text-align: center;
          font-size: 14px;
          font-weight: 400;
          line-height: 135%;
          margin: 20px auto 0 auto;
      }
     .subscribe-step-wrapper {
          display: flex;
          max-width: 960px;
          padding: 0px var(--no-space, 0px);
          justify-content: center;
          align-items: flex-start;
          gap: var(--2xl-space, 80px);
          margin: 40px auto 0 auto;
      }
      .subscribe-step-wrapper .col-md-4,
      .subscribe-step-wrapper .col-sm-4 {
          display: flex;
          flex-shrink: 1;
          justify-content: center;
      }
      
      .step-icon-img {
          margin: auto;
          text-align: center;
      }
      .subscribe-step p {
        max-width: 600px;
        color: var(--Greyscale-8-Middle-Shadow, #4B4A46);
        text-align: center;
        font-size: 14px;
        font-weight: 400;
        line-height: 135%;
        margin: 0;
    }
       .subscribe-step h3 {
        color: var(--Greyscale-Feature, #191917);
        text-align: center;
        font-size: 24px;
        font-weight: 900;
        line-height: 115%;
        margin: 0;
    }

    @media(max-width:992px){
      .subscribe-step-wrapper {
          gap: var(--xl-space, 20px);
      }
      .subscribe-step {
        padding: 20px;
      }
      .step-icon-img {
        max-width: 60px;
      }
    }
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
      }

      @media screen and (min-width: 750px) {
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
        }
      }
  
      @media screen and (max-width: 750px) {
        .subscribe-step-wrapper {
          flex-direction: column;
          }
        .subscribe-step-wrapper {
          display: block; }
        .subscribe-step-wrapper .col-md-4,
        .subscribe-step-wrapper .col-sm-4 {
          display: block;
          }      
        .subscribe-step h3 {
          max-width: 100%;
          margin:0 20% 10px 20%;
          }
        .subscribe-step p {
          max-width: 100%;
          margin:0 20%;
          }
      }
  
{%- endstyle -%}
<section class="content-container subscribe light section-{{ section.id }}-padding">
  <div class="container position-relative">
    <div class="row">
      <div class="col-12">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.short_text }}</p>
      </div>
    </div>
    
    <div class="subscribe-step-wrapper">
      {%- for block in section.blocks -%}
        <div class="col-md-4 col-sm-4">
          <div class="subscribe-step">
            {%- assign icon = block.settings.icon -%}
            {% if icon != blank %}
              <div class="step-icon-img">
                {{ icon | image_url: width: icon.width | image_tag: class: 'icon-img', loading: 'lazy' }}
              </div>
            {% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>
{% schema %}
  {
  "name": "Subscribe and Save",
  "max_blocks": 4,
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe and Save"
    },
    {
      "type": "textarea",
      "id": "short_text",
      "label": "Short Text",
      "default": "Lorem ipsum dolor sit amet consectetur. Purus placerat nunc odio odio semper molestie volutpat vitae. Integer tristique morbi nibh aliquam aliquam senectus eget sed. Ornare non id interdum."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    }
  ],
  "blocks": [
    {
      "name": "Subscribe Step",
      "type": "subscribe_step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Subscribe and Save"
    }
  ]
}
{% endschema %}
