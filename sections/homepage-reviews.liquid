{%- style -%}
  .rv-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#EDE4D1' }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 40px;
    padding-right: 40px;
    overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .rv-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Header ── */
  .rv-{{ section.id }} .rv__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    max-width: 1200px;
    margin: 0 auto 48px;
    gap: 32px;
  }

  /* Rating row — headline + sub + score all inline */
  .rv-{{ section.id }} .rv__rating {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Headline */
  .rv-{{ section.id }} .rv__headline {
    font-size: clamp({{ section.settings.heading_size | times: 0.69 | round }}px, {{ section.settings.heading_size | times: 0.077 }}vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight | default: 700 }};
    text-transform: {{ section.settings.heading_transform | default: 'uppercase' }};
    letter-spacing: 0.02em;
    color: {{ section.settings.heading_color | default: '#1F1A17' }};
    line-height: 1;
    margin: 0;
  }
  .rv-{{ section.id }} .rv__headline em {
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    color: {{ section.settings.heading_color | default: '#1F1A17' }};
    opacity: 0.6;
    display: block;
    letter-spacing: 0;
  }
  .rv-{{ section.id }} .rv__sub {
    font-size: {{ section.settings.sub_size | default: 16 }}px;
    color: {{ section.settings.sub_color | default: '#888888' }};
    margin: 0;
    line-height: 1.5;
  }

  /* Score row */
  .rv-{{ section.id }} .rv__score-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .rv-{{ section.id }} .rv__big-score {
    font-size: 80px;
    font-weight: 700;
    color: #1F1A17;
    line-height: 1;
    letter-spacing: -2px;
  }
  .rv-{{ section.id }} .rv__meta {
    color: rgba(31,26,23,0.6);
    line-height: 1.5;
  }
  .rv-{{ section.id }} .rv__meta-stars {
    font-size: 20px;
    color: #fbbf24;
    display: block;
    margin-bottom: 4px;
    letter-spacing: 1px;
  }
  .rv-{{ section.id }} .rv__meta-count {
    font-size: 13px;
    display: block;
  }
  .rv-{{ section.id }} .rv__meta-verified {
    font-size: 13px;
    font-weight: 600;
    color: #1F1A17;
    display: block;
  }

  /* Write a review button */
  .rv-{{ section.id }} .rv__write-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    border-radius: 50px;
    background: #1F1A17;
    color: #F7F1E4;
    border: 1px solid transparent;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .rv-{{ section.id }} .rv__write-btn:hover {
    background: #6B5E52;
    color: #F7F1E4;
  }

  /* ── Cards grid ── */
  .rv-{{ section.id }} .rv__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .rv-{{ section.id }} .rv__card {
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(31,26,23,0.1);
    border-radius: 16px;
    padding: 24px;
    transition: background 0.2s;
    display: flex;
    flex-direction: column;
  }
  .rv-{{ section.id }} .rv__card:hover {
    background: rgba(255,255,255,0.8);
  }

  /* Card top */
  .rv-{{ section.id }} .rv__card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14px;
  }
  .rv-{{ section.id }} .rv__reviewer {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rv-{{ section.id }} .rv__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    color: #1F1A17;
    flex-shrink: 0;
    overflow: hidden;
  }
  .rv-{{ section.id }} .rv__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }
  .rv-{{ section.id }} .rv__name {
    font-size: 14px;
    font-weight: 600;
    color: #1F1A17;
    line-height: 1.3;
  }
  .rv-{{ section.id }} .rv__verified {
    font-size: 11px;
    color: #1F1A17;
    margin-top: 2px;
  }
  .rv-{{ section.id }} .rv__stars {
    color: #fbbf24;
    font-size: 13px;
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  /* Review body */
  .rv-{{ section.id }} .rv__text {
    font-size: 14px;
    color: rgba(31,26,23,0.75);
    line-height: 1.6;
    flex: 1;
  }
  .rv-{{ section.id }} .rv__product {
    font-size: 11px;
    color: rgba(31,26,23,0.4);
    margin-top: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .rv-{{ section.id }} {
      padding-left: 20px;
      padding-right: 20px;
    }
    .rv-{{ section.id }} .rv__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .rv-{{ section.id }} .rv__rating {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .rv-{{ section.id }} .rv__score-row {
      margin-top: 8px;
    }
    .rv-{{ section.id }} .rv__big-score {
      font-size: 64px;
    }
    .rv-{{ section.id }} .rv__grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
  @media screen and (max-width: 479px) {
    .rv-{{ section.id }} .rv__big-score {
      font-size: 56px;
    }
    .rv-{{ section.id }} .rv__meta-stars {
      font-size: 18px;
    }
  }
{%- endstyle -%}

<section class="rv-{{ section.id }}">

  {%- comment -%} Header {%- endcomment -%}
  <div class="rv__header">
    <div class="rv__rating">
      <div class="rv__headline" role="heading" aria-level="2">
        {{- section.settings.headline | escape -}}
        {%- if section.settings.headline_italic != blank -%}
          <em>{{ section.settings.headline_italic | escape }}</em>
        {%- endif -%}
      </div>
      {%- if section.settings.sub_headline != blank -%}
        <p class="rv__sub">{{ section.settings.sub_headline | escape }}</p>
      {%- endif -%}
      <div class="rv__score-row">
        {%- if section.settings.score != blank -%}
          <div class="rv__big-score">{{ section.settings.score | escape }}</div>
        {%- endif -%}
        <div class="rv__meta">
          {%- assign star_count = section.settings.score_stars | default: 5 -%}
          <span class="rv__meta-stars">
            {%- for i in (1..star_count) -%}★{%- endfor -%}
          </span>
          {%- if section.settings.review_count != blank -%}
            <span class="rv__meta-count">{{ section.settings.review_count | escape }}</span>
          {%- endif -%}
          {%- if section.settings.verified_count != blank -%}
            <span class="rv__meta-verified">{{ section.settings.verified_count | escape }}</span>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if section.settings.write_review_url != blank or section.settings.write_review_label != blank -%}
      <a href="{{ section.settings.write_review_url | default: '#' }}" class="rv__write-btn">
        {{- section.settings.write_review_label | default: 'Write a Review' | escape -}}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} Review cards {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="rv__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="rv__card" {{ block.shopify_attributes }}>
            <div class="rv__card-top">
              <div class="rv__reviewer">
                {%- if block.settings.avatar_image != blank -%}
                  <div class="rv__avatar" aria-hidden="true">
                    <img
                      src="{{ block.settings.avatar_image | image_url: width: 80 }}"
                      alt="{{ block.settings.name | escape }}"
                      width="40"
                      height="40"
                      loading="lazy"
                    >
                  </div>
                {%- else -%}
                  <div
                    class="rv__avatar"
                    style="background: {{ block.settings.avatar_color | default: '#EDE4D1' }};"
                    aria-hidden="true"
                  >{{ block.settings.initials | escape }}</div>
                {%- endif -%}
                <div>
                  <div class="rv__name">{{ block.settings.name | escape }}</div>
                  <div class="rv__verified">✓ Verified Buyer</div>
                </div>
              </div>
              <div class="rv__stars">
                {%- assign rating = block.settings.rating | default: 5 -%}
                {%- for i in (1..rating) -%}★{%- endfor -%}
              </div>
            </div>
            {%- if block.settings.review_text != blank -%}
              <p class="rv__text">{{ block.settings.review_text | escape }}</p>
            {%- endif -%}
            {%- if block.settings.product_name != blank -%}
              <div class="rv__product">{{ block.settings.product_name | escape }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

