{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      }
  }
{%- endstyle -%}

<section class="what-inside-container section-{{ section.id }}-padding overflow-hidden">
  <div class="container container1">
     <div class="row">
        <div class="col-md-12">
            <div class="wi-box d-flex flex-wrap">
               <div class="wi-text sdb-text-box" id="description">
                  <div class="wi-heading">
                     <h4>{{ section.settings.heading }}</h4>
                     <h6 class="d-xl-block d-none">{{ section.settings.sub_heading }}</h6> 
                  </div>
                  <div class="accordion" id="wi_1">
                    <div class="accordion-item">
                      <div class="accordion-header" id="headingOne">
                        <a href="javascript:void(0)" class="accordion-button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                          Product Description
                        </a>
                      </div>
                      <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#wi_1">
                        <div class="accordion-body">
                            {{ product.description }}
                        </div>
                      </div>
                    </div>
<!--    START - benefits accordion - to be implemented later                       
                    <div class="accordion-item">
                      <div class="accordion-header" id="headingTwo">
                        <a href="javascript:void(0)" class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                          Benefits
                        </a>
                      </div>
                      <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#wi_1">
                        <div class="accordion-body">
                          {{ product.metafields.custom.benefits }}
                        </div>
                      </div>
                    </div>
----    END - benefits accordion - to be implemented later     -->
                    <div class="accordion-item">
                      <div class="accordion-header" id="headingThree">
                        <a href="javascript:void(0)" class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                          How to 
                        </a>
                      </div>
                      <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#wi_1">
                        <div class="accordion-body">
                          {{ product.metafields.custom.how_to }}
                        </div>
                      </div>
                    </div>
                    <div class="accordion-item">
                      <div class="accordion-header" id="headingFour">
                        <a href="javascript:void(0)" class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                          Ingredients 
                        </a>
                      </div>
                      <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour" data-bs-parent="#wi_1">
                        <div class="accordion-body">
                          {{ product.metafields.custom.ingredients }}
                        </div>
                      </div>
                    </div>
                  </div>
<!--    START - the science button - to be implemented later                  
                  <div class="wi-btn">
                     <a href="javascript:void(0)" class="btn"  data-bs-toggle="modal" data-bs-target="#custom-popup">The science behind {{ product.title | truncatewords: 1, "" }}</a>
                  </div> 
----    END - the science button - to be implemented later     -->    
               </div>
               <div class="wi-img-box">
                 {% if product.metafields.custom.inside_count_image !=blank %}
                  <div class="wi-img">
                     <img src="{{ product.metafields.custom.inside_count_image.value |img_url:'640x766' }}" alt="{{ product.title }}"/>
                    </div>
                   {% else %}
                     <div class="wi-img">
                     <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/image.jpg?v=1665816778" alt="{{ product.title }}"/>
                    </div>
                 {% endif %}
               </div>
            </div>
        </div>
     </div>
  </div>
</section>

<div class="custom-modal modal fade" id="custom-popup" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="custom-popupLabel" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content">
      <div class="modal-header">
        <a class="navbar-brand" href="/"><img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Goju_logo_pos_1_14cf97aa-3101-4df8-a8d3-7fffa703b496.png?v=1658043940" alt="Goju Shots" /></a>
        <div class="close-btn" data-bs-dismiss="modal" aria-label="Close">{% include 'close' %}</div>
      </div>
      <div class="modal-body">
        <div class="modal-content-text">
            <h4>{{ product.metafields.custom.popup_heading }}</h4>
            <p>{{ product.metafields.custom.popup_paragraph }}</p>
        </div>
      </div>
    </div>
  </div>
</div>
 

{% schema %}
  {
    "name": "What Inside",
    "settings": [
      {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 80
      },
      {
        "type":"text",
        "id":"heading",
        "label":"Heading"
      },
      {
        "type":"text",
        "id":"sub_heading",
        "label":"Sub Heading"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}