        { "value": "align--bottom-center--mobile", "label": "Bottom center"},
        { "value": "align--bottom-right--mobile", "label": "Bottom right"}
      ]
    }
     ]
    }
  ],
  "presets":[
    {
    "name":"Hero Banner"
    }
