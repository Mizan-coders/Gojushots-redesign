{% style %}
  .hero-outer-container .col-md-12 .desktop-banner {
    display:flex;
    }

  .hero-outer-container .col-md-12 .mobile-banner{
    display:none;
    }


  a.full_url_link {
    display:block; position:absolute;
    left:0; right:0; top:0; bottom:0;
  }


  @media only screen and (max-width: 991.98px) {


  .hero-outer-container .col-md-12 .desktop-banner {
    display:none;
    }

  .hero-outer-container .col-md-12 .mobile-banner{
    display:flex;
    }

  }


  .height_control {
    height: calc({{ section.settings.desktop_height }}vh - 120px)!important;
    }

  .hero-outer-text-box {
    padding:4rem;
  }

  .hero-text-box h1 {
      font-size: 70px;
      font-weight: 700;
      color: #000;
      line-height: 80px;
      margin-bottom: 10px;
      margin-top: 0px;
  }

  .hero-text-box h3 {
      font-size: 30px;
      font-weight: 400;
      margin-bottom: 6px;
      color: #000;
      margin-top: 0px;
  }

  .hero-banner-content h4{
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 10px;
      color: #000;
  }

  .hero-banner-content p {
      font-size: 1.6rem;
      font-weight: 700;
      margin-bottom: 10px;
      color: #000;
  }

  .hero-text p {
      font-size: 18px;
      font-weight: 500;
  }

  @media only screen and (max-width: 767.98px) {

  .hero-text-box h1 {
      font-size: 54px;
      line-height: 60px;
  }

  .hero-text-box h3 {
      font-size: 24px;
  }

  .hero-banner-content h4{
      font-size: 1.8rem;
  }

  .hero-banner-content p {
      font-size: 1.6rem;}

  .hero-text p {
      font-size: 16px;
  }

  }

  @media only screen and (max-width: 512px) {

  .hero-text-box h1 {
      font-size: 40px;
      line-height: 46px;
  }

  .hero-text-box h3 {
      font-size: 20px;
  }

  .hero-banner-content h4{
      font-size: 1.6rem;
  }

  .hero-banner-content p {
      font-size: 1.4rem;}

    .hero-btn {
      display: flex;
      flex-direction:column;
      gap:1rem;
    }
    .hero-btn .btn {
      text-align:center!important;
    }

    .hero-btn a {
      min-width:240px;
    }
        .btn+.btn {
        margin-left: 0px!important;
    }

  }

        .hero-btn .btn {
          padding: 13px 4rem;
          border-radius: 46px;
          background-color: #191917;
          border-color: #191917;
          border-width: 0px;
          color: #fff;
          text-decoration: unset !important;
      }
            .hero-container .hero-outer-text-box {
                max-width: 1300px;
                width: 100%;
                margin: 0 auto;
            }

          .hero-text-box {
            max-width: 600px;
        }
      .btn+.btn {
        margin-left: 25px;
    }

            .hero-btn .btn {
