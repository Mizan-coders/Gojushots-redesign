<section
  class="hero-outer-container   hero-slider desktop-banner hero-slider-{{ section.id }}"
  style="overflow:hidden;"
>
  <div class="row">
    <div class="col-md-12">
      {% for block in section.blocks %}
        <div
          class="desktop-banner hero-container text-{{ block.settings.flex_align }} height_control mobile-text-{{ block.settings.flex_align_mobile }}"
          style="background-size: cover; background-position: center; background-image:url('{% if block.settings.image != blank %}{{ block.settings.image | img_url:'1920x'}}{% endif %}');"
        >
          {% if block.settings.full_url != blank %}
            <a href="{{ block.settings.full_url }}" class="full_url_link"></a>
          {% endif %}

          {% if block.settings.video_id != blank %}
            <iframe
              src="https://www.youtube.com/embed/{{ block.settings.video_id }}?rel=0&amp;controls=0&amp;showinfo=0&amp;autoplay=1"
              frameborder="0"
              allow="autoplay; encrypted-media"
            ></iframe>
          {% endif %}

          <div class="hero-outer-text-box">
            <div>
              <div class="hero-text-box">
                <div>
                  {% if block.settings.sub_heading_1 != blank %}
                    <h3 style="color:{{ block.settings.text_color }}">{{ block.settings.sub_heading_1 }}</h3>
                  {% endif %}

                  {% if block.settings.heading != blank %}
                    <h1 style="color:{{ block.settings.text_color }}">{{ block.settings.heading }}</h1>
                  {% endif %}

                  <div class="hero-text">
                    {% if block.settings.sub_heading_2 != blank %}
                      <p style="margin-bottom:10px; color:{{ block.settings.text_color }}">
                        {{ block.settings.sub_heading_2 }}
                      </p>
                    {% endif %}

                    {% if block.settings.text != blank %}
                      <p style="color:{{ block.settings.text_color }}">{{ block.settings.text }}</p>
                    {% endif %}

                    {% if block.settings.sub_heading_3 != blank %}
                      <p style="margin-top:10px; color:{{ block.settings.text_color }}">
                        {{ block.settings.sub_heading_3 }}
                      </p>
                    {% endif %}
                  </div>

                  <div class="hero-btn">
                    {% if block.settings.btn_url != blank %}
                      <a
                        href="{{ block.settings.btn_url }}"
                        class="btn btn-black"
                        style="background-color:{{ block.settings.btn1_color }}; color:{{ block.settings.btn1_text_color }}"
                      >
                        {{ block.settings.btn_text }}
                      </a>
                    {% endif %}

               
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="mobile-banner hero-container text-{{ block.settings.flex_align }} height_control mobile-text-{{ block.settings.flex_align_mobile }}"
          style="background-size: cover; background-position: center; background-image:url('{% if block.settings.image != blank %}{{ block.settings.image_mob | img_url:'1920x'}}{% endif %}');"
        >
          {% if block.settings.full_url != blank %}
            <a href="{{ block.settings.full_url }}" class="full_url_link"></a>
          {% endif %}
          {% if block.settings.video_id != blank %}
            <iframe
              src="https://www.youtube.com/embed/{{ block.settings.video_id }}?rel=0&amp;controls=0&amp;showinfo=0&amp;autoplay=1"
              frameborder="0"
              allow="autoplay; encrypted-media"
            ></iframe>
          {% endif %}

          <div class="hero-outer-text-box">
            <div>
              <div class="hero-text-box">
                <div>
                  {% if block.settings.sub_heading_1 != blank %}
                    <h3 style="color:{{ block.settings.text_color }}">{{ block.settings.sub_heading_1 }}</h3>
                  {% endif %}

                  {% if block.settings.heading != blank %}
                    <h1 style="color:{{ block.settings.text_color }}">{{ block.settings.heading }}</h1>
                  {% endif %}

                  <div class="hero-text">
                    {% if block.settings.sub_heading_2 != blank %}
                      <p style="margin-bottom:10px; color:{{ block.settings.text_color }}">
                        {{ block.settings.sub_heading_2 }}
                      </p>
                    {% endif %}

                    {% if block.settings.text != blank %}
                      <p style="color:{{ block.settings.text_color }}">{{ block.settings.text }}</p>
                    {% endif %}

                    {% if block.settings.sub_heading_3 != blank %}
                      <p style="margin-top:10px; color:{{ block.settings.text_color }}">
                        {{ block.settings.sub_heading_3 }}
                      </p>
                    {% endif %}
                  </div>

                  <div class="hero-btn">
                    {% if block.settings.btn_url != blank %}
                      <a
                        href="{{ block.settings.btn_url }}"
                        class="btn btn-black"
                        style="background-color:{{ block.settings.btn1_color }}; color:{{ block.settings.btn1_text_color }}"
                      >
                        {{ block.settings.btn_text }}
                      </a>
                    {% endif %}

               
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
<script>
    /*==========================*/
  /* sliders */
  /*==========================*/
  if($('.hero-slider').length > 0){
  jQuery('.hero-slider').slick({
    slidesToShow: 1,
    slidesToScroll: 1,
    dots: false,
    arrows: false,
    infinite: true,
    centerMode: false,
    autoplay: true,
    autoplaySpeed: 3000,
    fade: true,
    speed: 3000,
  });
  }


  if($('.wic-slider').length > 0){
