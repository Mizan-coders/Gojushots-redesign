{% style %}
              .whatis-in {
       padding: 60px 0;
       position: relative;
       z-index: 1;
  }
   .whatis-in:before {
       content: '';
       position: absolute;
       width: 100%;
       height: 50%;
       z-index: -1;
       bottom: 0;
       left: 0;
       right: 0;
       background-color:{{ section.settings.optional-background-color}};
  }
   .whatis-in-box {
       border-radius: 12px;
       background: #AC489C;
       box-shadow: 0px 4px 4px 0px rgba(0, 0, 0, 0.25);
       color: #fff;
       padding: 60px 80px;
  }
   .whatis-in-header {
       text-align: center;
       font-size: 18px;
       font-style: normal;
       font-weight: 900;
       line-height: 115%;
       margin-bottom: 40px;
  }
   .whatis-in-header .heading h3 {
       font-family: 'Ratch', sans-serif!important;
       font-size: 94px;
       line-height: 115%;
       color: rgba(236, 233, 221, 0.25);
       margin: 0;
       position: absolute;
       top: -20px;
       left: 50%;
       transform: translateX(-50%);
       width:100%;
  }
   .whatis-in-header .heading span {
       font-size: 40px;
       font-style: normal;
       font-weight: 900;
       line-height: 115%;
       display: block;
       margin-bottom: 8px;
       z-index:2;
       position:relative;
  }
   .whatis-in-header .heading {
       position: relative;
  }
   .whatis-in-header p {
       max-width: 400px;
       margin: 0 auto;
       z-index:2;
       position:relative;
  }
   .mobile-only.col-12 {
       display: none;
  }
   li.whatis-in-content-list__item {
       text-align: center;
       font-size: 14px;
       font-weight: 400;
       line-height: 135%;
  }
   .step-icon-img img {
       width: auto;
       height: 50px;
       object-fit: cover;
       margin-bottom: 20px;
  }
   li.whatis-in-content-list__item h3 {
       font-size: 18px;
       font-weight: 900;
       line-height: 115%;
       margin-bottom: 10px;
  }
   li.whatis-in-content-list__item + li.whatis-in-content-list__item {
       margin-top: 40px;
  }
   @media (max-width: 991.98px){
     .step-icon-img img {
          margin: 0 auto 20px auto;
      }
       .row.desktop-v {
           display: none;
      }
       .mobile-only.col-12 {
           display: block;
      }
       .whatis-in-box {
           padding: 40px;
      }
       .center-image {
           text-align: center;
      }
       li.whatis-in-content-list__item p {
           max-width: 400px;
           margin: 0 auto;
      }
       .wic-slider .slick-dots li button:before {
           width: 10px;
           height: 10px;
           background: #fff;
           content: '';
           border-radius: 50%;
           opacity: 0.2;
      }
       .wic-slider .slick-dots li.slick-active button:before {
           opacity: 1;
           color: #fff;
      }
       .wic-slider .slick-dots li.slick-active button, .wic-slider .slick-dots li:hover button {
           opacity: 1;
            background: #FFF;
      }
       .wic-slider .slick-dots li {
           width: 10px;
           height: 10px;
      }
       .wic-slider ul.slick-dots {
           position: static;
           margin-top: 30px;
            display: flex;
          justify-content: center;
          align-items: center;
          gap: 7px;
      }
       .whatis-in-header .heading span{
           font-size:34px;
      }
       .full-width.container1 .whatis-in-box {
          padding: 120px 0px;
      }
        .whatis-in-header .heading h3 {
          font-size: 56px;
      }

  }
{% endstyle %}
<section class="whatis-in overflow-hidden" style="background-color:{{ section.settings.background-color}};" style="overflow:hidden;">
  <div class="{% if section.settings.full_width == false %}container{% else %}full-width{% endif %} container1">
    <div class="row">
      <div class="col-12">
        <div class="whatis-in-box" style="background-color:{{ section.settings.container-color}};">
          <div class="whatis-in-header">
            <div class="heading">
              <h3 style="color:{{ section.settings.secondary-color}};">{{ section.settings.sub_heading }}</h3>
              <span style="color:{{ section.settings.text-color}}!important;">{{ section.settings.heading }}</span>
            </div>
            <p style="color:{{ section.settings.text-color}}!important;">{{ section.settings.text }}</p>
          </div>
          <div class="whatis-in-content">
            <div class="row desktop-v">
              <div class="col-4">
                <ul class="whatis-in-content-list left-content">
                  {%- for block in section.blocks -%}
                    {% if block.type == 'left_list' %}
                      <li class="whatis-in-content-list__item">
                        {%- assign icon = block.settings.icon -%}
                        {% if icon != blank %}
                          <div class="step-icon-img">
                            {{ icon | image_url: width: icon.width | image_tag: class: 'icon-img', loading: 'lazy' }}
                          </div>
                        {% endif %}
                        <h3 style="color:{{ section.settings.text-color}}!important;">{{ block.settings.title }}</h3>
                        <p style="color:{{ section.settings.text-color}}!important;">{{ block.settings.text }}</p>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
              <div class="col-4">
                {%- assign image = section.settings.image -%}
                {% if image != blank %}
                  <div class="center-image">
                    {{ image | image_url: width: image.width | image_tag: class: 'image', loading: 'lazy' }}
                  </div>
                {% endif %}
              </div>
              <div class="col-4">
                <ul class="whatis-in-content-list right-content">
                  {%- for block in section.blocks -%}
                    {% if block.type == 'right_list' %}
                      <li class="whatis-in-content-list__item">
                        {%- assign icon = block.settings.icon -%}
                        {% if icon != blank %}
                          <div class="step-icon-img">
                            {{ icon | image_url: width: icon.width | image_tag: class: 'icon-img', loading: 'lazy' }}
                          </div>
                        {% endif %}
                        <h3 style="color:{{ section.settings.text-color}}!important;">{{ block.settings.title }}</h3>
                        <p style="color:{{ section.settings.text-color}}!important;">{{ block.settings.text }}</p>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>
            <div class="mobile-only col-12">
              {%- assign image = section.settings.image -%}
              {% if image != blank %}
                <div class="center-image">
                  {{ image | image_url: width: image.width | image_tag: class: 'image', loading: 'lazy' }}
                </div>
              {% endif %}
              <ul class="whatis-in-content-list wic-slider">
                {%- for block in section.blocks -%}
                  {% if block.type == 'left_list' %}
                    <li class="whatis-in-content-list__item">
                      {%- assign icon = block.settings.icon -%}
                      {% if icon != blank %}
                        <div class="step-icon-img">
                          {{ icon | image_url: width: icon.width | image_tag: class: 'icon-img', loading: 'lazy' }}
                        </div>
                      {% endif %}
                      <h3 style="color:{{ section.settings.text-color}}!important;">{{ block.settings.title }}</h3>
                      <p style="color:{{ section.settings.text-color}}!important;">{{ block.settings.text }}</p>
                    </li>
                  {% endif %}
                {% endfor %}
                {%- for block in section.blocks -%}
                  {% if block.type == 'right_list' %}
                    <li class="whatis-in-content-list__item">
                      {%- assign icon = block.settings.icon -%}
                      {% if icon != blank %}
                        <div class="step-icon-img">
                          {{ icon | image_url: width: icon.width | image_tag: class: 'icon-img', loading: 'lazy' }}
                        </div>
                      {% endif %}
                      <h3 style="color:{{ section.settings.text-color}}!important;">{{ block.settings.title }}</h3>
                      <p style="color:{{ section.settings.text-color}}!important;">{{ block.settings.text }}</p>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
  {
  "name": "What’s in it",
  "tag": "section",
  "settings": [
    {
      "type":"checkbox",
      "id":"full_width",
      "label":"Full Width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 80
      },
    {
      "type": "color",
      "id": "background-color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "optional-background-color",
      "label": "Bottom Background Color (Optional)"
    },
    {
      "type": "color",
      "id": "container-color",
      "label": "Container Color"
    },
    {
      "type": "color",
      "id": "secondary-color",
      "label": "Secondary Color"
    },
    {
      "type": "color",
      "id": "text-color",
      "label": "Text Color"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "name": "Left List",
      "type": "left_list",
      "limit":3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "name": "Right List",
      "type": "right_list",
      "limit":3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What’s in it"
    }
  ]
}
{% endschema %}
