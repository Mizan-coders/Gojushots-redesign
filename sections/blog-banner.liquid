
<section class="content-container blog-banner-container d-flex align-items-end">
<div class="blog-banner-img">
      <img src="{{ section.settings.image |img_url:'1440x' }}" alt="{{ section.settings.image |alt }}">
</div>  
<div class="container container1 position-relative">
  <div class="row align-items-center">
      <div class="col-sm-6 col-md-7">
          <div class="blog-banner-text">
            
              <div class="blog-banner-heading  {{ section.settings.layout }}" style="color:{{ section.settings.text_color }}">
                  <h3>{{ section.settings.heading }}
                        
                    </h3>
                  <p>{{ section.settings.paragraph }}</p>
              </div>
          </div>
      </div>
      <div class="col-md-5 col-lg-4 offset-md-0 offset-lg-1 d-none d-md-block">
          
      </div>
  </div>
  {% comment %}
  <div class="blog-banner-bg d-none d-md-block">
      <img src="{{ section.settings.image_mob |img_url:'663x331' }}" alt="{{ section.settings.image_mob |alt }}">
  </div>
  {% endcomment %}
</div>
</section>
{% schema %}
  {
    "name": "Banner",
    "settings": [
      {
        "type" : "text",
        "id" : "heading",
        "label" : "Heading"
      },
      
      {
        "type" : "textarea",
        "id" : "paragraph",
        "label" : "Paragraph"
      },
      {
        "type" : "image_picker",
        "id" : "image",
        "label" : "Image"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#fcfbf4"
      }
     
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}