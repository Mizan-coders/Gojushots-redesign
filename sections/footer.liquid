{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-newsletter.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-social.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-list-social.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  /* ── GOJU FOOTER ── */
  .footer--goju {
    background: {{ section.settings.bg_color | default: '#0a0a0a' }};
    color: rgba(255,255,255,0.6);
    padding: 60px 40px 0;
    margin-top: 0;
    border-top: none;
  }
  .footer--goju .footer__goju-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto 48px;
  }

  /* ── Brand column ── */
  .footer--goju .footer__brand-logo {
    display: block;
    margin-bottom: 12px;
    text-decoration: none;
  }
  .footer--goju .footer__brand-logo img {
    height: 60px;
    width: auto;
    display: block;
  }
  .footer--goju .footer__brand-name {
    font-size: 24px;
    font-weight: 700;
    color: white;
    letter-spacing: 0.05em;
  }
  .footer--goju .footer__brand-tagline {
    font-size: 14px;
    line-height: 1.6;
    max-width: 260px;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  /* ── Newsletter form ── */
  .footer--goju .footer__newsletter {
    margin-top: 20px;
  }
  .footer--goju .footer__newsletter .newsletter-form__field-wrapper {
    display: flex;
    gap: 8px;
  }
  .footer--goju .footer__newsletter .field {
    display: flex;
    gap: 8px;
    width: 100%;
  }
  .footer--goju .footer__newsletter .field__input {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    padding: 10px 16px;
    border-radius: 50px;
    font-size: 13px;
    outline: none;
    font-family: inherit;
    height: auto;
  }
  .footer--goju .footer__newsletter .field__input::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .footer--goju .footer__newsletter .field__input:focus {
    border-color: rgba(255,255,255,0.35);
    box-shadow: none;
  }
  .footer--goju .footer__newsletter .field__label {
    display: none;
  }
  .footer--goju .footer__newsletter .newsletter-form__button {
    background: var(--goju-accent);
    color: var(--goju-accent-text);
    border: none;
    padding: 10px 18px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    height: auto;
    min-width: auto;
    display: inline-flex;
    align-items: center;
  }
  .footer--goju .footer__newsletter .newsletter-form__button:hover {
    background: #c4e03a;
  }
  .footer--goju .footer__newsletter .newsletter-form__button .icon {
    display: none;
  }
  .footer--goju .footer__newsletter .newsletter-form__button::after {
    content: 'Subscribe';
  }
  .footer--goju .newsletter-form__message {
    color: rgba(255,255,255,0.6);
    font-size: 12px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .footer--goju .newsletter-form__message--success {
    color: var(--goju-accent);
  }

  /* ── Social icons ── */
  .footer--goju .footer__social {
    display: flex;
    gap: 10px;
    margin-top: 20px;
  }
  .footer--goju .footer__social-link {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    flex-shrink: 0;
  }
  .footer--goju .footer__social-link:hover {
    border-color: var(--goju-accent);
    color: var(--goju-accent);
    background: rgba(212,242,74,0.08);
  }
  .footer--goju .footer__social-link svg,
  .footer--goju .footer__social-link .icon {
    width: 18px;
    height: 18px;
    display: block;
  }

  /* ── Link columns ── */
  .footer--goju .footer__links-col .footer-block__heading {
    font-size: 13px;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
    margin-top: 0;
  }
  .footer--goju .footer__links-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer--goju .footer__links-col a {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 0.2s;
    background: none !important;
  }
  .footer--goju .footer__links-col a:hover {
    color: white;
    background: none !important;
  }

  /* ── Footer bottom bar ── */
  .footer--goju .footer__goju-bottom {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }

  /* ── Responsive: tablet (900px) ── */
  @media screen and (max-width: 899px) {
    .footer--goju {
      padding: 48px 20px 0;
    }
    .footer--goju .footer__goju-top {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer--goju .footer__brand {
      grid-column: 1 / -1;
    }
    .footer--goju .footer__newsletter .field {
      flex-direction: column;
    }
    .footer--goju .footer__newsletter .field__input {
      width: 100%;
    }
    .footer--goju .footer__newsletter .newsletter-form__button {
      align-self: flex-start;
    }
    .footer--goju .footer__goju-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }

  /* ── Responsive: mobile (480px) ── */
  @media screen and (max-width: 479px) {
    .footer--goju .footer__goju-top {
      grid-template-columns: 1fr;
    }
    .footer--goju .footer__links-col ul {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 16px;
    }
    .footer--goju .footer__links-col {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 20px;
    }
  }
{%- endstyle -%}

<footer class="footer footer--goju">
  <div class="footer__goju-top">

    {%- comment -%} ── Brand column ── {%- endcomment -%}
    <div class="footer__brand">
      <a href="{{ routes.root_url }}" class="footer__brand-logo">
        {%- if section.settings.logo != blank -%}
          {{- section.settings.logo | image_url: width: 240 | image_tag:
            loading: 'lazy',
            alt: shop.name,
            width: section.settings.logo.width,
            height: section.settings.logo.height
          -}}
        {%- else -%}
          <span class="footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.tagline != blank -%}
        <p class="footer__brand-tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}

      {%- comment -%} Newsletter form — submits to Shopify customer endpoint {%- endcomment -%}
      {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__field-wrapper">
          <div class="field">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="field__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="ContactFooter-error"
              {% elsif form.posted_successfully? %}
                aria-describedby="ContactFooter-success"
              {% endif %}
              placeholder="Your email address"
              required
            >
            <label class="field__label" for="NewsletterForm--{{ section.id }}">{{ 'newsletter.label' | t }}</label>
            <button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe" aria-label="{{ 'newsletter.button_label' | t }}">
              {% render 'icon-arrow' %}
            </button>
          </div>
          {%- if form.errors -%}
            <small class="newsletter-form__message form__message" id="ContactFooter-error">
              {%- render 'icon-error' -%}
              {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
            </small>
          {%- endif -%}
        </div>
        {%- if form.posted_successfully? -%}
          <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>
            {%- render 'icon-success' -%}
            {{ 'newsletter.success' | t }}
          </h3>
        {%- endif -%}
      {%- endform -%}

      {%- comment -%} Social icons — pulled from theme settings {%- endcomment -%}
      <div class="footer__social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.instagram' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-instagram' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.facebook' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-facebook' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.tiktok' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-tiktok' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.youtube' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-youtube' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.twitter' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-twitter' -%}
          </a>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" class="footer__social-link" aria-label="{{ 'general.social.links.pinterest' | t }}" target="_blank" rel="noopener noreferrer">
            {%- render 'icon-pinterest' -%}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Link columns from blocks ── {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="footer__links-col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="footer-block__heading">{{- block.settings.heading | escape -}}</h2>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  {%- comment -%} ── Footer bottom bar ── {%- endcomment -%}
  <div class="footer__goju-bottom">
    <span>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}</span>
    {%- if section.settings.footer_note != blank -%}
      <span>{{ section.settings.footer_note }}</span>
    {%- endif -%}
  </div>
</footer>

{% javascript %}
  class LocalizationForm extends HTMLElement {
    constructor() {
      super();
      this.elements = {
        input: this.querySelector('input[name="locale_code"], input[name="country_code"]'),
        button: this.querySelector('button'),
        panel: this.querySelector('.disclosure__list-wrapper'),
      };
      if (!this.elements.button) return;
      this.elements.button.addEventListener('click', this.openSelector.bind(this));
      this.elements.button.addEventListener('focusout', this.closeSelector.bind(this));
      this.addEventListener('keyup', this.onContainerKeyUp.bind(this));
      this.querySelectorAll('a').forEach(item => item.addEventListener('click', this.onItemClick.bind(this)));
    }
    hidePanel() {
      this.elements.button.setAttribute('aria-expanded', 'false');
      this.elements.panel.setAttribute('hidden', true);
    }
    onContainerKeyUp(event) {
      if (event.code.toUpperCase() !== 'ESCAPE') return;
      this.hidePanel();
      this.elements.button.focus();
    }
    onItemClick(event) {
      event.preventDefault();
      const form = this.querySelector('form');
      this.elements.input.value = event.currentTarget.dataset.value;
      if (form) form.submit();
    }
    openSelector() {
      this.elements.button.focus();
      this.elements.panel.toggleAttribute('hidden');
      this.elements.button.setAttribute('aria-expanded', (this.elements.button.getAttribute('aria-expanded') === 'false').toString());
    }
    closeSelector(event) {
      const shouldClose = event.relatedTarget && event.relatedTarget.nodeName === 'BUTTON';
      if (event.relatedTarget === null || shouldClose) {
        this.hidePanel();
      }
    }
  }
  if (!customElements.get('localization-form')) {
    customElements.define('localization-form', LocalizationForm);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "t:sections.footer.blocks.link_list.settings.menu.info"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#0a0a0a"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "default": "Real ingredients. Built to work. Crafted in New Zealand for people who take their health seriously.",
      "label": "Brand tagline"
    },
    {
      "type": "header",
      "content": "Footer bottom"
    },
    {
      "type": "text",
      "id": "footer_note",
      "default": "Made with care in New Zealand 🇳🇿",
      "label": "Footer note (right side)"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Shop"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Retailers"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Help"
        }
      }
    ]
  }
}
{% endschema %}
