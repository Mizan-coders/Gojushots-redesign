<section class="content-container our-story-container pb-0">
    <div class="container">
        <div class="row flex-column-reverse flex-md-row">
            <div class="col-md-6 col-lg-5 offset-lg-1 offset-md-0">
                <div class="our-story-img">
                    <img src="{{ section.settings.image |img_url:'415x415' }}" alt="{{ section.settings.image |alt }}" />
                    <a href="{{ section.settings.btn_link }}" target="_blank" class="our-story-social-btn">
                      <img src="https://cdn.shopify.com/s/files/1/0407/5103/8632/t/31/assets/button%20_%20social.png?v=1663723133" alt="button_social"/></a>
                </div>
            </div>
            <div class="col-lg-5 col-md-6">
                <div class="new-heading mb-0">
                    <h3>{{ section.settings.heading }}
                        <span class="new-heading-overlay">{{ section.settings.sub_heading }}</span>
                    </h3>
                    {{ section.settings.body_text }}
                </div>
            </div>
        </div>
    </div>
</section>
{% schema %}
  {
    "name": "Our Story",
    "settings": [
      {
        "type" : "text",
        "id" : "sub_heading",
        "label" : "Sub Heading"
      },
      {
        "type" : "text",
        "id" : "heading",
        "label" : "Heading"
      },
      {
        "type" : "richtext",
        "id" : "body_text",
        "label" : "Body Text"
      },
      {
        "type" : "url",
        "id" : "btn_link",
        "label" : "Social Link"
      },
      {
        "type" : "image_picker",
        "id" : "image",
        "label" : "Image"
      }
    
    ]
  }
{% endschema %}
