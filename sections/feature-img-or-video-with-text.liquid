<section class="feature-img-with-text-container">
  <div class="container container1">
    <div class="row">
      <div class="col-md-12">
         <div class="feature-img-with-text-box {{ section.settings.layout }} d-flex flex-wrap" style="background-color:{{ section.settings.background_color }};color:{{ section.settings.text_color }}">
            <div class="fiwt-text-box">
              <h2>{{ section.settings.title | escape }}</h2>
              <h6>{{ section.settings.sub_title | escape }}</h6>
              <div class="fiwt-text">
                {{ section.settings.text }}
              </div>
              <ul class="selling-point-list d-flex flex-wrap">
                 {% for block in section.blocks %} 
                 <li>
                    <div class="selling-point-box">
                       {% if block.settings.icon !=blank %}
                       <div class="spb-icon">
                          <img src="{{ block.settings.icon | img_url:'38x' }}" alt=""/>
                       </div>
                       {% endif %}
                       <div class="spb-text">
                          <p>Selling point</p>
                          <h4>{{ block.settings.text | escape }}</h4>
                       </div>
                    </div>
                 </li>
                 {% endfor %}
              </ul>
              <div class="fiwt-link">
                <a href="{{ section.settings.url | escape }}" class="white-link">{{ section.settings.link_text | escape }}</a>
              </div>
            </div>
            <div class="fiwt-img-box">
                {% if section.settings.video != blank %}
                 <video width="630px" height="770px" loop="true" autoplay="autoplay" controls muted>
                  <source src="{{ section.settings.video }}" type="video/mp4" />
                </video>
                {% else %}
                 <img src="{{ section.settings.image | img_url:'640x' }}" alt="{{ section.settings.image.alt }}" />
                {% endif %}
            </div>
         </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Organic",
    "settings": [
      {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image First"
        },
        {
          "value": "text_first",
          "label": "Text First"
        }
        ],
        "default": "text_first",
        "label": "Desktop image placement",
        "info": "Content first is the default mobile layout."
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#E91976"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#fcfbf4"
      },
      {
	   "type": "text",
	   "id": "title",
	   "label": "Title"
	  },
      {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h0",
          "label": "Title Size"
        },
      {
	   "type": "text",
	   "id": "sub_title",
	   "label": "Sub Title"
	  },
      {
        "type":"richtext",
        "id":"text",
        "label":"Text"
      },
      {
	   "type": "image_picker",
	   "id": "image",
	   "label": "Image"
	  },
      {
        "type": "url",
        "id": "video",
        "label": "Video",
        "info":"Image will show, if there is no video"
      },
      {
	   "type": "text",
	   "id": "link_text",
	   "label": "Button Text"
	  },
      {
	   "type": "url",
	   "id": "url",
	   "label": "Button Url"
	  }
    ],
    "blocks": [
    	{
    	"name": "Selling Point",
    	"type": "selling-point",
    	"settings": [
    	{
    	   "type": "image_picker",
    	   "id": "icon",
    	   "label": "Icon"
    	},
        {
    	   "type": "text",
    	   "id": "text",
    	   "label": "Text"
    	}  
        ]
        }
    ],
    "presets": [
    {
      "name": "Feature Image With Text"
    }
  ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}