{%- style -%}
  .ws-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5F0E8' }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 40px;
    padding-right: 40px;
  }
  @media screen and (min-width: 750px) {
    .ws-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Header ── */
  .ws-{{ section.id }} .ws__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .ws-{{ section.id }} .ws__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .ws-{{ section.id }} .ws__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(31,26,23,0.6);
    display: block;
    margin-bottom: 12px;
  }
  .ws-{{ section.id }} .ws__title {
    font-size: clamp({{ section.settings.heading_size | times: 0.615 | round }}px, {{ section.settings.heading_size | times: 0.077 }}vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight | default: 700 }};
    text-transform: {{ section.settings.heading_transform | default: 'uppercase' }};
    letter-spacing: -0.01em;
    color: {{ section.settings.heading_color | default: '#1F1A17' }};
    line-height: 1.05;
    margin: 0;
  }
  .ws-{{ section.id }} .ws__title em {
    font-style: italic;
    font-weight: 400;
    color: {{ section.settings.heading_color | default: '#1F1A17' }};
    opacity: 0.65;
  }
  .ws-{{ section.id }} .ws__subtitle {
    font-size: 16px;
    color: #888;
    line-height: 1.6;
    max-width: 480px;
    margin: 14px auto 0;
  }

  /* ── Grid ── */
  .ws-{{ section.id }} .ws__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    align-items: start;
  }

  /* ── Card ── */
  .ws-{{ section.id }} .ws__card {
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    background: #F7F1E4;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  .ws-{{ section.id }} .ws__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.11);
  }

  /* Featured card — deeper warm accent, same style as others */
  .ws-{{ section.id }} .ws__card--featured {
    background: #D4C4A8;
  }

  /* ── Card image ── */
  .ws-{{ section.id }} .ws__card-image {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    position: relative;
    background: rgba(31,26,23,0.06);
    flex-shrink: 0;
  }
  .ws-{{ section.id }} .ws__card-image img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }
  .ws-{{ section.id }} .ws__card:hover .ws__card-image img {
    transform: scale(1.04);
  }

  /* ── Card body ── */
  .ws-{{ section.id }} .ws__card-body {
    padding: 20px 20px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Time label — eyebrow caps */
  .ws-{{ section.id }} .ws__time {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(31,26,23,0.5);
    margin-bottom: 8px;
  }
  /* Card title */
  .ws-{{ section.id }} .ws__card-title {
    font-size: 22px;
    font-weight: 700;
    color: #1F1A17;
    margin: 0 0 10px;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  /* Description */
  .ws-{{ section.id }} .ws__desc {
    font-size: 13px;
    color: rgba(31,26,23,0.6);
    line-height: 1.65;
    margin-bottom: 16px;
    flex: 1;
  }
  /* Tags */
  .ws-{{ section.id }} .ws__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }
  .ws-{{ section.id }} .ws__tag {
    background: rgba(31,26,23,0.07);
    border: 1px solid rgba(31,26,23,0.14);
    color: #1F1A17;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 50px;
    white-space: nowrap;
  }
  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .ws-{{ section.id }} {
      padding-left: 20px;
      padding-right: 20px;
    }
    .ws-{{ section.id }} .ws__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
  @media screen and (max-width: 479px) {
    .ws-{{ section.id }} .ws__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="ws-{{ section.id }}">
  <div class="ws__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="ws__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ws__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      <h2 class="ws__title">
        {{- section.settings.title | escape -}}
        {%- if section.settings.title_italic != blank %} <em>{{ section.settings.title_italic | escape }}</em>{%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="ws__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cards grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="ws__grid">
        {%- for block in section.blocks -%}

          {%- liquid
            assign img_src = ''
            assign img_alt = block.settings.title | escape
            if block.settings.image != blank
              assign img_src = block.settings.image | image_url: width: 600
              assign img_alt = block.settings.image.alt | default: block.settings.title | escape
            elsif block.settings.image_url != blank
              assign img_src = block.settings.image_url
            else
              assign time_key = block.settings.time_label | downcase | strip
              case time_key
                when 'morning'
                  assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Action_shot_2.png?v=1771724687'
                when 'pre-workout'
                  assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Ginger_ignition_2.png?v=1771719104'
                when 'afternoon'
                  assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Vital_sunshine_2_d72a021a-571e-4816-b0ca-5de91cb9fc2a.png?v=1774399335'
                when 'evening'
                  assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Good_night_2_240add19-7f99-409f-93d5-368151b9f89a.png?v=1774338496'
              endcase
            endif
          -%}

          {%- comment -%} Build card style: apply tint only on non-featured cards {%- endcomment -%}
          {%- if block.settings.featured -%}
            {%- assign card_style = '' -%}
          {%- elsif block.settings.card_color != blank -%}
            {%- assign card_style = 'background:' | append: block.settings.card_color -%}
          {%- else -%}
            {%- assign card_style = '' -%}
          {%- endif -%}

          <div class="ws__card{% if block.settings.featured %} ws__card--featured{% endif %}"
               {% if card_style != blank %}style="{{ card_style }}"{% endif %}
               {{ block.shopify_attributes }}>

            {%- if img_src != blank -%}
              <div class="ws__card-image">
                <img
                  src="{{ img_src }}"
                  alt="{{ img_alt }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              </div>
            {%- else -%}
              <div class="ws__card-image"></div>
            {%- endif -%}

            <div class="ws__card-body">
              {%- if block.settings.time_label != blank -%}
                <div class="ws__time">{{ block.settings.time_label | escape }}</div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <div class="ws__card-title">{{ block.settings.title | escape }}</div>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="ws__desc">{{ block.settings.description | escape }}</div>
              {%- endif -%}
              {%- if block.settings.tags != blank -%}
                <div class="ws__tags">
                  {%- assign tag_list = block.settings.tags | split: ',' -%}
                  {%- for tag in tag_list -%}
                    <span class="ws__tag">{{ tag | strip | escape }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "When to Take Your Shot",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background colour",
      "default": "#F5F0E8"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Daily Routine"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "When to take your"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Heading italic word",
      "default": "shot."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "GOJU fits into your day wherever you need it most — morning, workout or afternoon slump."
    },
    {
      "type": "header",
      "content": "Heading Style"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Font size (desktop max)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 52,
      "unit": "px",
      "info": "Mobile scales automatically."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "600", "label": "Semi-bold (600)" },
        { "value": "700", "label": "Bold (700)" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Text transform",
      "options": [
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "none", "label": "As typed (mixed case)" },
        { "value": "capitalize", "label": "Title Case" }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#1F1A17"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Time-of-day card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)",
          "info": "Auto-filled by time label if left blank"
        },
        {
          "type": "text",
          "id": "time_label",
          "label": "Time label",
          "default": "Morning",
          "info": "e.g. Morning, Pre-Workout, Afternoon, Evening"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card heading",
          "default": "Start Strong"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Take your shot first thing on an empty stomach for maximum absorption. Sets the tone for the whole day."
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Product tags (comma-separated)",
          "default": "Action Shot, Vital Sunshine",
          "info": "Shown as pills at the bottom of the card"
        },
        {
          "type": "color",
          "id": "card_color",
          "label": "Card background tint",
          "default": "#F7F1E4",
          "info": "Soft tint for this card. Ignored when Featured is on."
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured card (dark style)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "When to Take Your Shot",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "time_label": "Morning",
            "title": "Start Strong",
            "description": "Take your shot first thing on an empty stomach for maximum absorption. Sets the tone for the whole day.",
            "tags": "Action Shot, Vital Sunshine",
            "card_color": "#FFF8EE",
            "featured": false
          }
        },
        {
          "type": "card",
          "settings": {
            "time_label": "Pre-Workout",
            "title": "Power Up",
            "description": "The ginger and turmeric blend provides natural energy support before training — no jitters, no crash.",
            "tags": "Action Shot, Ginger Ignition",
            "card_color": "#F7F1E4",
            "featured": true
          }
        },
        {
          "type": "card",
          "settings": {
            "time_label": "Afternoon",
            "title": "Beat the Slump",
            "description": "Skip the coffee at 3pm. A GOJU shot gives you clean, sustained energy to power through the rest of your day.",
            "tags": "Immune Guard, Vital Sunshine",
            "card_color": "#F0F5EE",
            "featured": false
          }
        },
        {
          "type": "card",
          "settings": {
            "time_label": "Evening",
