{%- style -%}
  .ws-{{ section.id }} {
    background: var(--goju-page-bg, #f5f0e8);
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 40px;
    padding-right: 40px;
  }
  @media screen and (min-width: 750px) {
    .ws-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Header ── */
  .ws-{{ section.id }} .ws__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .ws-{{ section.id }} .ws__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .ws-{{ section.id }} .ws__eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #4a9c65;
    display: block;
    margin-bottom: 12px;
  }
  .ws-{{ section.id }} .ws__title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 900;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #0a0a0a;
    line-height: 1.05;
    margin: 0;
  }
  .ws-{{ section.id }} .ws__title em {
    font-style: italic;
    font-weight: 700;
    text-transform: none;
    color: #2d6b45;
    letter-spacing: 0;
  }
  .ws-{{ section.id }} .ws__subtitle {
    font-size: 16px;
    color: #888;
    line-height: 1.6;
    max-width: 480px;
    margin: 14px auto 0;
  }

  /* ── Grid ── */
  .ws-{{ section.id }} .ws__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* ── Card ── */
  .ws-{{ section.id }} .ws__card {
    background: white;
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 20px;
    padding: 28px 24px;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
  }
  .ws-{{ section.id }} .ws__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  /* Featured (dark) card */
  .ws-{{ section.id }} .ws__card--featured {
    background: #1a4a2e;
    border-color: #1a4a2e;
    box-shadow: 0 8px 32px rgba(26,74,46,0.3);
  }
  .ws-{{ section.id }} .ws__card--featured:hover {
    background: #2d6b45;
    transform: translateY(-4px);
  }

  /* Product image */
  .ws-{{ section.id }} .ws__img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 16px;
    display: block;
  }
  .ws-{{ section.id }} .ws__img-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    margin-bottom: 16px;
    background: rgba(26,74,46,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Multi-image layout */
  .ws-{{ section.id }} .ws__multi-imgs {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 6px;
    margin-bottom: 16px;
  }
  .ws-{{ section.id }} .ws__product-img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    flex-shrink: 0;
  }
  .ws-{{ section.id }} .ws__product-img-sm {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
    flex-shrink: 0;
    opacity: 0.85;
  }

  /* Time label */
  .ws-{{ section.id }} .ws__time {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4a9c65;
    margin-bottom: 6px;
  }
  .ws-{{ section.id }} .ws__card--featured .ws__time {
    color: rgba(255,255,255,0.7);
  }

  /* Card title */
  .ws-{{ section.id }} .ws__card-title {
    font-size: 26px;
    font-weight: 900;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 12px;
    line-height: 1;
  }
  .ws-{{ section.id }} .ws__card--featured .ws__card-title {
    color: white;
  }

  /* Description */
  .ws-{{ section.id }} .ws__desc {
    font-size: 13px;
    color: #888;
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }
  .ws-{{ section.id }} .ws__card--featured .ws__desc {
    color: rgba(255,255,255,0.75);
  }

  /* Tags */
  .ws-{{ section.id }} .ws__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }
  .ws-{{ section.id }} .ws__tag {
    background: rgba(26,74,46,0.08);
    border: 1px solid rgba(26,74,46,0.2);
    color: #1a4a2e;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 50px;
    white-space: nowrap;
  }
  .ws-{{ section.id }} .ws__card--featured .ws__tag {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.2);
    color: white;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 989px) {
    .ws-{{ section.id }} {
      padding-left: 20px;
      padding-right: 20px;
    }
    .ws-{{ section.id }} .ws__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
  @media screen and (max-width: 479px) {
    .ws-{{ section.id }} .ws__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="ws-{{ section.id }}">
  <div class="ws__inner">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="ws__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ws__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      <h2 class="ws__title">
        {{- section.settings.title | escape -}}
        {%- if section.settings.title_italic != blank %} <em>{{ section.settings.title_italic | escape }}</em>{%- endif -%}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="ws__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Cards grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="ws__grid">
        {%- for block in section.blocks -%}
          {%- assign card_class = 'ws__card' -%}
          {%- if block.settings.featured -%}
            {%- assign card_class = 'ws__card ws__card--featured' -%}
          {%- endif -%}
          <div class="{{ card_class }}" {{ block.shopify_attributes }}>

            {%- liquid
              assign img_src = ''
              assign img_alt = block.settings.title | escape
              if block.settings.image != blank
                assign img_src = block.settings.image | image_url: width: 160
                assign img_alt = block.settings.image.alt | default: block.settings.title | escape
              elsif block.settings.image_url != blank
                assign img_src = block.settings.image_url
              else
                assign time_key = block.settings.time_label | downcase | strip
                case time_key
                  when 'morning'
                    assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Action_shot_2.png?v=1771724687'
                  when 'pre-workout'
                    assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Ginger_ignition_2.png?v=1771719104'
                  when 'afternoon'
                    assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Vital_sunshine_2_d72a021a-571e-4816-b0ca-5de91cb9fc2a.png?v=1774399335'
                  when 'evening'
                    assign img_src = 'https://cdn.shopify.com/s/files/1/0407/5103/8632/files/Good_night_2_240add19-7f99-409f-93d5-368151b9f89a.png?v=1774338496'
                endcase
              endif
            -%}
            {%- liquid
              assign img2_src = ''
              assign img3_src = ''
              if block.settings.image_2 != blank
                assign img2_src = block.settings.image_2 | image_url: width: 112
              endif
              if block.settings.image_3 != blank
                assign img3_src = block.settings.image_3 | image_url: width: 112
              endif
              assign has_multi = false
              if img2_src != blank or img3_src != blank
                assign has_multi = true
              endif
            -%}
            {%- if img_src != blank -%}
              {%- if has_multi -%}
                <div class="ws__multi-imgs">
                  {%- if img2_src != blank -%}
                    <img src="{{ img2_src }}" alt="{{ block.settings.image_2.alt | default: img_alt | escape }}" class="ws__product-img-sm" width="56" height="56" loading="lazy">
                  {%- endif -%}
                  <img src="{{ img_src }}" alt="{{ img_alt }}" class="ws__product-img" width="80" height="80" loading="lazy">
                  {%- if img3_src != blank -%}
                    <img src="{{ img3_src }}" alt="{{ block.settings.image_3.alt | default: img_alt | escape }}" class="ws__product-img-sm" width="56" height="56" loading="lazy">
                  {%- endif -%}
                </div>
              {%- else -%}
                <img src="{{ img_src }}" alt="{{ img_alt }}" class="ws__product-img" width="80" height="80" loading="lazy">
              {%- endif -%}
            {%- else -%}
              <div class="ws__img-placeholder" aria-hidden="true"></div>
            {%- endif -%}

            {%- if block.settings.time_label != blank -%}
              <div class="ws__time">{{ block.settings.time_label | escape }}</div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <div class="ws__card-title">{{ block.settings.title | escape }}</div>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <div class="ws__desc">{{ block.settings.description | escape }}</div>
            {%- endif -%}

            {%- if block.settings.tags != blank -%}
              <div class="ws__tags">
                {%- assign tag_list = block.settings.tags | split: ',' -%}
                {%- for tag in tag_list -%}
                  <span class="ws__tag">{{ tag | strip | escape }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
