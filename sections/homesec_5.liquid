<!--============================== subscribe-box container Start ==============================-->
<section id="five" data-color="#FFFFFF" class="dksoni suscribe-block-container panel" data-color="#FFDA00" style="overflow:hidden;" >
   <div class="container">
     <div class="row">
       <div class="col-md-12">
         <div class="heading">
           <h3 class="d-none d-lg-block">{{ section.settings.heading }}</h3>
           <h3 class="d-block d-lg-none">{{ section.settings.mob_heading }}</h3>
           <h6>{{ section.settings.sub_heading }}</h6>
           <span>{{ section.settings.big_text }}</span>
         </div>
         <ul class="key-list d-flex align-items-center justify-content-center">
           {% for block in section.blocks %}
           <li>
             <div class="key-box">
               <div class="key-icon">
                 <img src="{{ block.settings.image |img_url:'143x137' }}" alt="{{ block.settings.image |alt }}" />
               </div>
               <h6>{{ block.settings.text }}</h6>
             </div>
           </li>
           {% endfor %}
         </ul>
         {% if section.settings.btn_url  !=blank %}
         <div class="sub-btn">
           <a href="{{ section.settings.btn_url }}" class="btn btn-default">{{ section.settings.btn_text }}</a>
         </div>
         {% endif %}
       </div>
     </div>
   </div>
 </section>
 <!--============================== subscribe-box container Start ==============================-->
{% schema %}
  {
    "name": "Subscribe",
    "max_blocks": 3,
    "settings": [
    {
      "type":"text",
      "id":"big_text",
      "label":"Big Text"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading"
    },
    {
      "type":"text",
      "id":"mob_heading",
      "label":"Heading (Mob)"
    },
    {
      "type":"text",
      "id":"sub_heading",
      "label":"Sub Heading"
    },
    {
      "type":"url",
      "id":"bth_url",
      "label":"Button URL"
    },
    {
      "type":"text",
      "id":"btn_text",
      "label":"Button Text"
    }
    ],
    "blocks": [
     {
       "name": "Icon List",
       "type": "icon-list",
       "settings": [
         {
           "type": "image_picker",
           "id": "image",
           "label": "Icon"
         },
         {
           "type": "text",
           "id": "text",
           "label": "Text"
         }
       ]
     }
   ]
  }
{% endschema %}

