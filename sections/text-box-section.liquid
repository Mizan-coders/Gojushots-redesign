<section class="text-box-conatiner text-center">
      <div class="container">
          <div class="row">
              <div class="col-md-12">
                  <div class="text-box">
                      <h2>{{ section.settings.heading }}</h2>
                      <a href="{{ section.settings.btn_url }}" class="btn btn-outline">{{ section.settings.btn_text }}</a>
                  </div>
              </div>
          </div>
      </div>
  </section>

{% schema %}
  {
    "name": "Goju straight up",
    "settings": [
    {
      "type" : "text",
      "id" : "heading",
      "label" : "Heading"
    },
    {
      "type" : "url",
      "id" : "btn_link",
      "label" : "Button Link"
    },
    {
      "type" : "text",
      "id" : "btn_text",
      "label" : "Button Label"
    }
    ]
  }
{% endschema %}
