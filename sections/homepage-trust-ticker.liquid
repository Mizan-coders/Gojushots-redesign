{%- style -%}
  .tt-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#EDE4D1' }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  /* ── Slide ── */
  .tt-{{ section.id }} .tt__slide {
    display: flex !important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px 16px;
    gap: 10px;
    outline: none;
  }

  .tt-{{ section.id }} .tt__icon-img {
    display: block;
    width: 32px;
    height: 32px;
    object-fit: contain;
    margin: 0 auto;
    flex-shrink: 0;
  }

  .tt-{{ section.id }} .tt__icon {
    font-size: 32px;
    line-height: 1;
    display: block;
  }

  .tt-{{ section.id }} .tt__label {
    color: {{ section.settings.text_color | default: '#1F1A17' }};
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: capitalize;
    line-height: 1.3;
    white-space: nowrap;
  }

  /* ── Slick overrides ── */
  .tt-{{ section.id }} .slick-list {
    overflow: hidden;
  }
  .tt-{{ section.id }} .slick-track {
    display: flex;
    align-items: center;
  }
  .tt-{{ section.id }} .slick-slide {
    opacity: 1;
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
  <div class="tt-{{ section.id }}">
    <div class="tt__slider">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ticker_item' -%}
          <div class="tt__slide" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 96 | image_tag: class: 'tt__icon-img', alt: '', loading: 'lazy' }}
            {%- elsif block.settings.icon != blank -%}
              <span class="tt__icon" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
            <span class="tt__label">{{- block.settings.text | escape -}}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <script>
    (function () {
      function initTicker(sliderEl) {
        if (typeof $ === 'undefined' || typeof $.fn.slick === 'undefined') {
          setTimeout(function () { initTicker(sliderEl); }, 80);
          return;
        }
        var $slider = sliderEl ? $(sliderEl) : $('.tt-{{ section.id }} .tt__slider');
        if (!$slider.length) return;
        if ($slider.hasClass('slick-initialized')) $slider.slick('unslick');

        $slider.slick({
          slidesToShow: {{ section.settings.slides_to_show | default: 5 }},
          centerMode: true,
          centerPadding: '{{ section.settings.center_padding | default: 60 }}px',
          autoplay: true,
          autoplaySpeed: {{ section.settings.autoplay_speed | default: 2000 }},
          speed: 600,
          infinite: true,
          arrows: false,
          dots: false,
          responsive: [
            {
              breakpoint: 768,
              settings: {
                slidesToShow: 1,
                centerMode: true,
                centerPadding: '28%'
              }
            }
          ]
        });
      }

      document.addEventListener('DOMContentLoaded', function () { initTicker(null); });

      document.addEventListener('shopify:section:load', function (e) {
        var el = e.target.querySelector('.tt__slider');
        if (el) initTicker(el);
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Trust Ticker",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#EDE4D1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#1F1A17"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slides_to_show",
      "label": "Items visible (desktop)",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "center_padding",
      "label": "Edge peek (desktop)",
      "info": "How much of the edge slides peek in from the sides.",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 1000,
      "max": 6000,
      "step": 500,
      "default": 2000,
      "unit": "ms"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "ticker_item",
      "name": "Ticker Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image / SVG",
          "info": "Upload a custom icon or SVG. Takes priority over the emoji field below."
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji fallback)",
          "info": "Used only if no image is uploaded above."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Made in New Zealand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Ticker",
      "blocks": [
        { "type": "ticker_item", "settings": { "icon": "🌿", "text": "Made in New Zealand" } },
        { "type": "ticker_item", "settings": { "icon": "🧃", "text": "Cold-Pressed" } },
        { "type": "ticker_item", "settings": { "icon": "✅", "text": "100% Natural" } },
        { "type": "ticker_item", "settings": { "icon": "🚫", "text": "No Sugar" } },
        { "type": "ticker_item", "settings": { "icon": "🌱", "text": "No Preservatives" } },
        { "type": "ticker_item", "settings": { "icon": "❄️", "text": "HPP Preserved" } }
      ]
    }
  ]
}
{% endschema %}
