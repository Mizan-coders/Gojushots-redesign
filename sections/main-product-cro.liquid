                    {%- if block.settings.perk_2 != blank -%}<li><span class="cro-pw__perk-dot"></span>{{ block.settings.perk_2 }}</li>{%- endif -%}
                    {%- if block.settings.perk_3 != blank -%}<li><span class="cro-pw__perk-dot"></span>{{ block.settings.perk_3 }}</li>{%- endif -%}
