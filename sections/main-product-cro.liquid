      assign seo_media = product.featured_media
    endif
  -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media %}"image": [{{ seo_media | image_url: width: seo_media.preview_image.width | prepend: "https:" | json }}],{% endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank %}"sku": {{ product.selected_or_first_available_variant.sku | json }},{% endif %}
      "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type": "Offer",
            {% if variant.sku != blank %}"sku": {{ variant.sku | json }},{% endif %}
            "availability": "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price": {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency": {{ cart.currency.iso_code | json }},
            "url": {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

</section>

{%- comment -%} ─── Gallery & Sticky ATC JavaScript ─── {%- endcomment -%}
<script>
(function() {
  'use strict';

  // ── Gallery: slide switching ──────────────────────────────────
  function CroGallery(sectionId) {
    var slidesEl  = document.getElementById('CroSlides-' + sectionId);
    var thumbsEl  = document.getElementById('CroThumbs-' + sectionId);
    if (!slidesEl) return;

    var slides = Array.from(slidesEl.querySelectorAll('.cro-gallery__slide'));
    var thumbs = thumbsEl
      ? Array.from(thumbsEl.querySelectorAll('.cro-gallery__thumb'))
      : [];
    var current = 0;

    function goTo(index) {
      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;

      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      if (thumbs[current]) {
        thumbs[current].classList.remove('is-active');
        thumbs[current].setAttribute('aria-selected', 'false');
      }

      current = index;
      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      if (thumbs[current]) {
        thumbs[current].classList.add('is-active');
        thumbs[current].setAttribute('aria-selected', 'true');
      }
    }

    // Arrow buttons
    var section = document.getElementById('MainProduct-' + sectionId);
    if (section) {
      section.querySelectorAll('.cro-gallery__arrow').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var dir = parseInt(btn.dataset.dir, 10);
          goTo(current + dir);
        });
      });
    }

    // Thumbnail clicks
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        goTo(parseInt(thumb.dataset.index, 10));
      });
    });

    // Touch/swipe on main image
    var touchStartX = 0;
    slidesEl.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    slidesEl.addEventListener('touchend', function(e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
    }, { passive: true });

    // Sync with variant change (Shopify variant-radios / variant-selects)
    document.addEventListener('variant:change', function(e) {
      var variant = e.detail && e.detail.variant;
      if (!variant || !variant.featured_media) return;
      var mediaId = String(variant.featured_media.id);
      slides.forEach(function(slide, i) {
        if (slide.querySelector('[data-media-id="' + mediaId + '"]')) goTo(i);
      });
    });
  }

  // ── Sticky ATC ───────────────────────────────────────────────
  function CroStickyATC(sectionId) {
    var bar       = document.getElementById('CroStickyATC-'    + sectionId);
    var anchor    = document.getElementById('CroATC-'          + sectionId);
    var priceEl   = document.getElementById('CroStickyPrice-'  + sectionId);
    var variantEl = document.getElementById('CroStickyVariant-'+ sectionId);
    var thumbEl   = document.getElementById('CroStickyThumb-'  + sectionId);
    var stickyBtn = document.getElementById('CroStickyBtn-'    + sectionId);
    var modeEl    = document.getElementById('CroStickyMode-'   + sectionId);
    var pw        = document.getElementById('CroPW-'           + sectionId);
    if (!bar || !anchor) return;

    // ── 1. Show / hide using IntersectionObserver ──
    // Wait for window.load so images and app widgets have settled layout
    // before we start observing — prevents the flash-on-load on mobile.
    function initVisibility() {
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function(entries) {
          var entry = entries[0];
          // Only show when ATC has scrolled ABOVE the viewport (top < 0).
          // If top > 0 the ATC is still below the fold — don't show yet.
          var show = !entry.isIntersecting && entry.boundingClientRect.top < 0;
          bar.classList.toggle('is-visible', show);
          bar.setAttribute('aria-hidden', show ? 'false' : 'true');
        }, { threshold: 0 }).observe(anchor);
      } else {
        var threshold = anchor.getBoundingClientRect().top + window.scrollY + anchor.offsetHeight;
        function checkVisibility() {
          var show = window.scrollY > threshold;
          bar.classList.toggle('is-visible', show);
          bar.setAttribute('aria-hidden', show ? 'false' : 'true');
        }
        window.addEventListener('resize', function() {
          threshold = anchor.getBoundingClientRect().top + window.scrollY + anchor.offsetHeight;
        });
        window.addEventListener('scroll', checkVisibility, { passive: true });
        checkVisibility();
      }
    }

    if (document.readyState === 'complete') {
      initVisibility();
    } else {
      window.addEventListener('load', initVisibility);
    }

    // ── 2. Price helpers ──
    window._croCurrentVariantPrice = {{ product.selected_or_first_available_variant.price }};

    function money(cents) {
      return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
    }
    function getStickyPrice(mode, price) {
      if (!pw || mode !== 'sub') return money(price);
      var disc = parseInt(pw.dataset.discount, 10) || 10;
      return money(Math.round(price * (1 - disc / 100)));
    }

    // ── 3. Mode toggle (One-time / Subscribe) ──
    var stickyMode = 'sub';

    function setMode(mode) {
      stickyMode = mode;
      if (modeEl) {
        modeEl.querySelectorAll('.cro-sticky-atc__mode-btn').forEach(function(b) {
          b.classList.toggle('is-active', b.dataset.mode === mode);
        });
      }
      var price = window._croCurrentVariantPrice;
      if (priceEl) priceEl.textContent = getStickyPrice(mode, price);
      if (stickyBtn) stickyBtn.textContent = mode === 'sub' ? 'Subscribe & Save 10%' : stickyBtn.dataset.labelAdd;
      // Mirror to main purchase widget
      if (pw) {
        pw.querySelectorAll('.cro-pw__tog-btn').forEach(function(b) {
          if (b.dataset.mode === mode && !b.classList.contains('is-active')) b.click();
        });
      }
    }

    if (modeEl) {
      modeEl.querySelectorAll('.cro-sticky-atc__mode-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { setMode(btn.dataset.mode); });
      });
    }

    // Mirror main PW toggle → sticky
    if (pw) {
      pw.querySelectorAll('.cro-pw__tog-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          stickyMode = btn.dataset.mode;
          if (modeEl) {
            modeEl.querySelectorAll('.cro-sticky-atc__mode-btn').forEach(function(b) {
              b.classList.toggle('is-active', b.dataset.mode === stickyMode);
            });
          }
          if (priceEl) priceEl.textContent = getStickyPrice(stickyMode, window._croCurrentVariantPrice);
          if (stickyBtn) stickyBtn.textContent = stickyMode === 'sub' ? 'Subscribe & Save 10%' : stickyBtn.dataset.labelAdd;
        });
      });
    }

    // Initialise price display
    if (priceEl) priceEl.textContent = getStickyPrice('sub', window._croCurrentVariantPrice);

    // ── 4. Variant change ──
    document.addEventListener('variant:change', function(e) {
      var v = e.detail && e.detail.variant;
      if (!v) return;
      window._croCurrentVariantPrice = v.price;
      if (priceEl) priceEl.textContent = getStickyPrice(stickyMode, v.price);
      if (variantEl) variantEl.textContent = v.title !== 'Default Title' ? v.title : '';
      if (thumbEl && v.featured_image) {
        thumbEl.src = v.featured_image.src.replace(/(\.[a-z]+)(\?.*)?$/, '_80x80_crop_center$1$2');
      }
      if (stickyBtn) {
        stickyBtn.disabled = !v.available;
        stickyBtn.textContent = v.available
          ? (stickyMode === 'sub' ? 'Subscribe & Save 10%' : stickyBtn.dataset.labelAdd)
          : stickyBtn.dataset.labelSoldout;
      }
    });

    // ── 5. ATC button click ──
    if (stickyBtn) {
      stickyBtn.addEventListener('click', function() {
        if (stickyBtn.disabled) return;
        var form = document.getElementById(stickyBtn.dataset.form);
        if (!form) return;
        stickyBtn.disabled = true;
        stickyBtn.textContent = stickyBtn.dataset.labelAdding;
        var mainSubmit = form.querySelector('[type="submit"][name="add"]');
        if (mainSubmit) mainSubmit.click();
        var restore = setTimeout(function() {
          stickyBtn.textContent = stickyBtn.dataset.labelAdd;
          stickyBtn.disabled = false;
        }, 3500);
        function onCartUpdate() {
          clearTimeout(restore);
          stickyBtn.textContent = stickyBtn.dataset.labelAdded;
          setTimeout(function() {
            stickyBtn.textContent = stickyBtn.dataset.labelAdd;
            stickyBtn.disabled = false;
          }, 2000);
        }
        document.addEventListener('cart:updated', onCartUpdate, { once: true });
        document.addEventListener('cart:change',  onCartUpdate, { once: true });
      });
    }

  }

  // ── Custom Purchase Widget ────────────────────────────────────
  (function () {
    var pw = document.getElementById('CroPW-{{ section.id }}');
    if (!pw) return;

    var rawPrice    = parseInt(pw.dataset.price, 10);          // price in cents
    var discount    = parseInt(pw.dataset.discount, 10) || 10;
    var defaultFreq = pw.dataset.defaultFreq || '2w';

    var onetimePrice = rawPrice / 100;
    var subPrice     = Math.round(rawPrice * (1 - discount / 100)) / 100;
    var saving       = Math.round((onetimePrice - subPrice) * 100) / 100;

    // Build planId → per_delivery_price map from variant selling_plan_allocations
    var planPriceMap = {};
    function buildPlanPriceMap(variant) {
      planPriceMap = {};
      if (!variant || !variant.selling_plan_allocations) return;
      variant.selling_plan_allocations.forEach(function(alloc) {
        planPriceMap[String(alloc.selling_plan_id)] = alloc.per_delivery_price;
      });
    }
    // Initialise from currently selected variant
    (function() {
      var varEl = document.querySelector('script[data-cst_variant="data"]');
      if (!varEl) return;
      try {
        var variants = JSON.parse(varEl.textContent);
        var initV = variants.find(function(v) { return v.id === {{ product.selected_or_first_available_variant.id }}; });
        if (initV) buildPlanPriceMap(initV);
      } catch(e) {}
    })();

    function money(n) {
      return '$' + n.toFixed(2).replace(/\.00$/, '').replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    var elPrice   = document.getElementById('CroPWPrice-{{ section.id }}');
    var elWas     = document.getElementById('CroPWWas-{{ section.id }}');
    var elSaving  = document.getElementById('CroPWSaving-{{ section.id }}');
    var elNote    = document.getElementById('CroPWNote-{{ section.id }}');
    var elPerks   = document.getElementById('CroPWPerks-{{ section.id }}');
    var elFreq    = document.getElementById('CroPWFreq-{{ section.id }}');
    var elCancel  = document.getElementById('CroPWCancel-{{ section.id }}');
    var elOtNote      = document.getElementById('CroPWOnetimeNote-{{ section.id }}');
    var elNoSubUpsell = document.getElementById('CroPWNoSubUpsell-{{ section.id }}');
    var elNoSubHint   = document.getElementById('CroNoSubHint-{{ section.id }}');
    var elHint        = document.getElementById('CroPWHint-{{ section.id }}');
    var noSubProduct           = pw.dataset.noSub === 'true';
    var currentVariantHasPlans = !noSubProduct && (pw.dataset.variantHasPlans !== '0');
    var atcBtn    = document.getElementById('CroATC-{{ section.id }}');
    var atcLabel  = atcBtn ? atcBtn.querySelector('.cro-atc-btn__label') : null;

    var subNote      = pw.dataset.subNote      || 'Free shipping included — always';
    var otShipping   = pw.dataset.otShipping   || '+ $8 shipping';

    // ── ReCharge element finders ──────────────────────────────
    function rcRadio(val) {
      return document.querySelector('input[name="purchaseOption"][value="' + val + '"]');
    }
    function rcSelect() {
      return document.querySelector('select[name="rc_selling_plan"]');
    }

    function clickRC(val) {
      var r = rcRadio(val);
      if (r) {
        r.checked = true;
        r.dispatchEvent(new Event('change', { bubbles: true }));
        var lbl = r.closest('label');
        if (lbl) lbl.click();
      }
    }
    function setRCPlan(planId) {
      var sel = rcSelect();
      if (sel) {
        sel.value = planId;
        sel.dispatchEvent(new Event('change', { bubbles: true }));
        sel.dispatchEvent(new Event('input',  { bubbles: true }));
      }
      // Set native Shopify selling_plan input so subscription is attached to cart
      var spInput = document.querySelector('input[name="selling_plan"]');
      if (spInput) {
        spInput.value = planId;
        spInput.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }

    // ── Render subscribe state ────────────────────────────────
    function renderSub(planId, hint) {
      var displayPrice  = (planId && planPriceMap[String(planId)] !== undefined)
                          ? planPriceMap[String(planId)] / 100
                          : subPrice;
      var displaySaving = Math.round((onetimePrice + 8 - displayPrice) * 100) / 100;
      if (elPrice)  elPrice.textContent  = money(displayPrice);
      if (elWas)    elWas.innerHTML      = '<s>' + money(onetimePrice) + '</s> one-time price';
      if (elSaving) { elSaving.textContent = 'Save ' + money(displaySaving) + ' per order'; elSaving.hidden = false; }
      if (elNote)   elNote.textContent   = '{{ block.settings.sub_note | default: "Free shipping included — always" }}';
      if (elPerks)  elPerks.hidden       = false;
      if (elFreq)   elFreq.hidden        = false;
      if (elCancel) elCancel.hidden      = false;
      if (elOtNote)      elOtNote.hidden      = true;
      if (elNoSubUpsell) elNoSubUpsell.hidden = true;
      if (elHint && hint) elHint.textContent = hint;
      if (atcLabel) atcLabel.innerHTML   = 'Subscribe — <span class="cro-atc-btn__price">' + money(displayPrice) + '</span>';
      // Per-shot pricing
      var elPerShot = document.getElementById('CroPWPerShot-{{ section.id }}');
      if (elPerShot) {
        var checkedRadio = document.querySelector('.cro-variant-row input[type="radio"]:checked');
        var shotMatch = checkedRadio ? checkedRadio.value.match(/^(\d+)/) : null;
        var shotCount = shotMatch ? parseInt(shotMatch[1]) : {{ block.settings.shots_per_pack | default: 0 }};
        if (shotCount > 0) {
          var perShot = Math.round((displayPrice / shotCount) * 100) / 100;
          var perShotLabel = pw.dataset.perShotLabel || 'Just {price} per shot, delivered to your door.';
          elPerShot.textContent = perShotLabel.replace(/\{price\}/g, money(perShot));
          elPerShot.hidden = false;
        } else {
          elPerShot.hidden = true;
        }
      }
      clickRC('subscription');
      if (planId) setRCPlan(planId);
    }

    // ── Render one-time state ─────────────────────────────────
    function renderOnetime() {
      if (elPrice)  elPrice.textContent  = money(onetimePrice);
      if (elWas)    elWas.innerHTML      = '';
      if (elSaving) elSaving.hidden      = true;
      var _ship = 8;
      var _otTotal = Math.round((onetimePrice + _ship) * 100) / 100;
      var _saving  = Math.round((onetimePrice + _ship - subPrice) * 100) / 100;
      if (elNote) {
        if (currentVariantHasPlans) {
          elNote.innerHTML = 'One-time: ' + money(onetimePrice) + ' + $' + _ship + ' shipping = ' + money(_otTotal) + ' delivered. Subscribe: <span style="color:#1D9E75;font-weight:500;">' + money(subPrice) + ' with free shipping always</span> — save ' + money(_saving) + ' every order. Cancel anytime.';
        } else {
          elNote.textContent = 'One-time: ' + money(onetimePrice) + ' + $' + _ship + ' shipping = ' + money(_otTotal) + ' delivered.';
        }
      }
      if (elPerks)  elPerks.hidden       = true;
      if (elFreq)   elFreq.hidden        = true;
      if (elCancel) elCancel.hidden      = true;
      if (elOtNote)      elOtNote.hidden      = currentVariantHasPlans ? false : true;
      // Upsell only for per-variant no-sub (not when whole product is no-subscription)
      if (elNoSubUpsell) elNoSubUpsell.hidden = (!currentVariantHasPlans && !noSubProduct) ? false : true;
      var elPerShot = document.getElementById('CroPWPerShot-{{ section.id }}');
      if (elPerShot) elPerShot.hidden = true;
      if (atcLabel) atcLabel.innerHTML   = 'Add to cart — <span class="cro-atc-btn__price">' + money(onetimePrice) + '</span>';
      // Only sync ReCharge widget when variant actually has plans (avoids RC's async handlers
      // re-setting selling_plan on no-plan variants like 9-shot)
      if (currentVariantHasPlans) clickRC('onetime');
      // Clear native Shopify selling_plan so one-time purchase doesn't carry a subscription
      var spInput = document.querySelector('input[name="selling_plan"]');
      if (spInput) { spInput.value = ''; spInput.dispatchEvent(new Event('change', { bubbles: true })); }
      // Delayed clears: catch any async re-set by ReCharge's event handlers
      setTimeout(function() {
        var sp = document.querySelector('input[name="selling_plan"]');
        if (sp && sp.value) { sp.value = ''; sp.dispatchEvent(new Event('change', { bubbles: true })); }
      }, 150);
      setTimeout(function() {
        var sp = document.querySelector('input[name="selling_plan"]');
        if (sp && sp.value) { sp.value = ''; sp.dispatchEvent(new Event('change', { bubbles: true })); }
      }, 600);
    }

    // ── Toggle buttons ────────────────────────────────────────
    var togBtns = pw.querySelectorAll('.cro-pw__tog-btn');
    var currentMode = 'sub';
    togBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        togBtns.forEach(function (b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        currentMode = btn.dataset.mode;
        if (currentMode === 'sub') {
          var activeFreq = pw.querySelector('.cro-pw__freq-btn.is-active');
          var planId = activeFreq ? activeFreq.dataset.planId : (pw.querySelector('.cro-pw__freq-btn') ? pw.querySelector('.cro-pw__freq-btn').dataset.planId : '');
          var hint   = activeFreq ? activeFreq.dataset.hint   : '';
          renderSub(planId, hint);
        } else {
          renderOnetime();
        }
      });
    });

    // ── Frequency buttons ─────────────────────────────────────
    var freqBtns = pw.querySelectorAll('.cro-pw__freq-btn');
    freqBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        freqBtns.forEach(function (b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        if (elHint) elHint.textContent = btn.dataset.hint || '';
        setRCPlan(btn.dataset.planId);
        renderSub(btn.dataset.planId, btn.dataset.hint);
      });
    });

    // ── "Choose the 15 pack" link — switch to first variant with plans ──
    var noSubLink = document.getElementById('CroPWNoSubLink-{{ section.id }}');
    if (noSubLink) {
      noSubLink.addEventListener('click', function(e) {
        e.preventDefault();
        var variantData = document.querySelector('script[data-cst_variant="data"]');
        if (!variantData) return;
        try {
          var variants = JSON.parse(variantData.textContent);
          var planVariant = variants.find(function(v) {
            return v.selling_plan_allocations && v.selling_plan_allocations.length > 0;
          });
          if (!planVariant) return;
          var optionValue = planVariant.options[0];
          var radios = document.querySelectorAll('.cro-variant-row input[type="radio"]');
          for (var i = 0; i < radios.length; i++) {
            if (radios[i].value === optionValue) {
              var lbl = document.querySelector('label[for="' + radios[i].id + '"]');
              if (lbl) lbl.click();
              break;
            }
          }
        } catch (err) {}
      });
    }

    // ── Init on load ──────────────────────────────────────────
    function initPW() {
      // No-subscription product or variant with no plans — lock to one-time mode
      if (pw.dataset.noSub === 'true') {
        currentMode = 'once';
        var toggle = pw.querySelector('.cro-pw__toggle');
        if (toggle) toggle.hidden = true;
        renderOnetime();
        return;
      }
      // Initial variant has no plans — show One-time only (e.g. 9-shot pack)
      if (pw.dataset.variantHasPlans === '0') {
        currentMode = 'once';
        var toggle = pw.querySelector('.cro-pw__toggle');
        if (toggle) toggle.hidden = true;
        if (elPerks)  elPerks.hidden  = true;
        if (elFreq)   elFreq.hidden   = true;
        if (elCancel) elCancel.hidden = true;
        renderOnetime();
        return;
      }
      currentMode = 'sub';
      // Set default frequency button
      var defBtn = pw.querySelector('.cro-pw__freq-btn.is-active') || pw.querySelector('.cro-pw__freq-btn');
      if (defBtn) {
        freqBtns.forEach(function(b){ b.classList.remove('is-active'); });
        defBtn.classList.add('is-active');
      }
      var planId = defBtn ? defBtn.dataset.planId : '';
      var hint   = defBtn ? defBtn.dataset.hint   : '';
      renderSub(planId, hint);
      // Poll for 3s — re-assert Subscribe if ReCharge overrides it (even without firing events)
      var pollCount = 0;
      var pollTimer = setInterval(function() {
        if (currentMode !== 'sub' || ++pollCount > 15) { clearInterval(pollTimer); return; }
        var subRadio = rcRadio('subscription');
        if (subRadio && !subRadio.checked) {
          togBtns.forEach(function(b) { b.classList.toggle('is-active', b.dataset.mode === 'sub'); });
          renderSub(planId, hint);
        }
      }, 200);
    }

    // ── Handle variant switch — show/hide sub UI per variant ──────
    // Ignore variant:change events while still on the initial variant (fired multiple times by
    // Dawn + ReCharge on page load). Only update when the user navigates to a different variant.
    var initialVariantId = {{ product.selected_or_first_available_variant.id }};
    var departedfromInitial = false;

    document.addEventListener('variant:change', function(e) {
      var variant = e.detail && e.detail.variant;
      if (!variant) return;

      // Update prices for every variant:change (safe — just math)
      rawPrice     = variant.price;
      onetimePrice = rawPrice / 100;
      subPrice     = Math.round(rawPrice * (1 - discount / 100)) / 100;
      saving       = Math.round((onetimePrice - subPrice) * 100) / 100;
      buildPlanPriceMap(variant);

      // Mark when user has navigated away from the initial variant
      if (variant.id !== initialVariantId) departedfromInitial = true;

      // While still on the initial variant, don't touch the purchase widget UI —
      // initPW() already set it correctly and the 800ms sync will finalise ReCharge state.
      if (!departedfromInitial) return;

      var hasPlans = !noSubProduct && !!(variant.selling_plan_allocations && variant.selling_plan_allocations.length > 0);
      currentVariantHasPlans = hasPlans;
      var toggle   = pw.querySelector('.cro-pw__toggle');

      // Update the "one-time only" hint below variant buttons
      if (elNoSubHint) elNoSubHint.hidden = hasPlans;

      if (!hasPlans) {
        currentMode = 'once';
        pw.dataset.variantHasPlans = '0';
        if (toggle)   toggle.hidden   = true;
        if (elPerks)  elPerks.hidden  = true;
        if (elFreq)   elFreq.hidden   = true;
        if (elCancel) elCancel.hidden = true;
        var spInput = document.querySelector('input[name="selling_plan"]');
        if (spInput) {
          spInput.value = '';
          spInput.dispatchEvent(new Event('change', { bubbles: true }));
        }
        renderOnetime();
      } else {
        pw.dataset.variantHasPlans = '1';
        if (toggle) toggle.hidden = false;
        currentMode = 'sub';
        togBtns.forEach(function(b) { b.classList.toggle('is-active', b.dataset.mode === 'sub'); });
        var activeFreq = pw.querySelector('.cro-pw__freq-btn.is-active');
        var planId = activeFreq ? activeFreq.dataset.planId : (pw.querySelector('.cro-pw__freq-btn') ? pw.querySelector('.cro-pw__freq-btn').dataset.planId : '');
        var hint   = activeFreq ? activeFreq.dataset.hint   : '';
        renderSub(planId, hint);
      }
    });

    // Run immediately for visual state
    initPW();
    // After 800ms: simulate clicks to sync all 3 layers (UI + ReCharge + Shopify selling_plan)
    setTimeout(function() {
      if (pw.dataset.noSub === 'true') return;
      if (pw.dataset.variantHasPlans === '0') return; // 9-shot or other no-plan variant — stay One-time
      var subBtn = pw.querySelector('.cro-pw__tog-btn[data-mode="sub"]');
      var firstPlanBtn = pw.querySelector('.cro-pw__freq-btn.is-active') || pw.querySelector('.cro-pw__freq-btn');
      var spInput = document.querySelector('input[name="selling_plan"]');
      if (subBtn) subBtn.click();
      if (firstPlanBtn) firstPlanBtn.click();
      if (spInput && firstPlanBtn) spInput.value = firstPlanBtn.dataset.planId;
    }, 800);

    // Safety net: clear selling_plan before form submit if current variant has no plans
    var productForm = document.getElementById('{{ product_form_id }}');
    if (productForm) {
      productForm.addEventListener('submit', function() {
        if (pw.dataset.variantHasPlans === '0' || currentMode === 'once') {
          var spInput = document.querySelector('input[name="selling_plan"]');
          if (spInput) spInput.value = '';
        }
      }, true); // capture phase — runs before ReCharge can interfere
    }
    // Belt-and-suspenders: intercept fetch to strip selling_plan from /cart/add
    // when the selected variant has no subscription plans (e.g. 9-shot).
    // Dawn sends FormData; ReCharge may send JSON or URLSearchParams — handle all formats.
    (function() {
      var _origFetch = window.fetch;
      window.fetch = function(resource, init) {
        var url = typeof resource === 'string' ? resource
                : (resource && resource.url) ? resource.url : '';
        if (url.indexOf('/cart/add') !== -1 && pw.dataset.variantHasPlans === '0') {
          if (init && init.body) {
            if (init.body instanceof FormData) {
              init.body.delete('selling_plan');
            } else if (init.body instanceof URLSearchParams) {
              init.body.delete('selling_plan');
            } else if (typeof init.body === 'string') {
              try {
                var body = JSON.parse(init.body);
                delete body.selling_plan;
                init = Object.assign({}, init, { body: JSON.stringify(body) });
              } catch(e) {
                try {
                  var params = new URLSearchParams(init.body);
                  params.delete('selling_plan');
                  init = Object.assign({}, init, { body: params.toString() });
                } catch(e2) {}
              }
            }
          }
        }
        return _origFetch.call(window, resource, init);
      };
    })();
  })();

  // ── Panel accordion (How to Take, Ingredients, Shipping) ─────
  (function () {
    var accItems = document.querySelectorAll('.cro-panel-acc-item');
    accItems.forEach(function (det) {
      var body = det.querySelector('.cro-panel-acc-item__body');
      body.style.overflow = 'hidden';
      body.style.height = '0px';
      body.style.transition = 'height 0.3s ease';

      det.querySelector('summary').addEventListener('click', function (e) {
        e.preventDefault();
        if (det.open) {
          body.style.height = body.scrollHeight + 'px';
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { body.style.height = '0px'; });
          });
          body.addEventListener('transitionend', function h() {
            det.open = false;
            body.removeEventListener('transitionend', h);
          });
        } else {
          det.open = true;
          body.style.height = body.scrollHeight + 'px';
          body.addEventListener('transitionend', function h() {
            body.style.height = 'auto';
            body.removeEventListener('transitionend', h);
          });
        }
      });
    });
  })();

  // ── Read More / Read Less description toggle ──────────────────
  function initReadMore(sectionId) {
    var btn  = document.getElementById('CroReadMoreBtn-' + sectionId);
    var full = document.getElementById('CroDescFull-' + sectionId);
    if (!btn || !full) return;

    // Set initial collapsed state
    full.style.height = '0px';
    full.style.overflow = 'hidden';
    full.style.transition = 'height 0.35s ease';

    var preview = btn.closest('.cro-info-panel__short-desc') && btn.closest('.cro-info-panel__short-desc').querySelector('.cro-short-desc');

    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        full.style.height = full.scrollHeight + 'px';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            full.style.height = '0px';
          });
        });
        full.addEventListener('transitionend', function handler() {
          full.setAttribute('aria-hidden', 'true');
          full.removeEventListener('transitionend', handler);
        });
        btn.setAttribute('aria-expanded', 'false');
        btn.querySelector('.cro-read-more-btn__text').textContent = btn.dataset.label || 'Read More';
        btn.classList.remove('is-open');
        if (preview) preview.style.display = '';
      } else {
        full.setAttribute('aria-hidden', 'false');
        full.style.height = full.scrollHeight + 'px';
        full.addEventListener('transitionend', function handler() {
          full.style.height = 'auto';
          full.removeEventListener('transitionend', handler);
        });
        btn.setAttribute('aria-expanded', 'true');
        btn.querySelector('.cro-read-more-btn__text').textContent = 'Read Less';
        btn.classList.add('is-open');
        if (preview) preview.style.display = 'none';
      }
    });
  }

  // ── Scroll-to-section links ───────────────────────────────────
  function initScrollLinks() {
    document.querySelectorAll('.cro-scroll-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var target = document.querySelector(link.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  // ── Auto-select first subscription-enabled variant on page load ──
  // If the default variant has no plans (e.g. 9-shot), switch to the first
  // variant that does (e.g. 15-shot) so Subscribe & Save shows by default.
  function autoSelectPlanVariant() {
    // Only run when no specific variant was requested in the URL.
    // Once the user picks a variant (9-shot or 15-shot), it appears in the URL
    // and this guard prevents auto-switching from overriding their choice.
    if (new URLSearchParams(window.location.search).has('variant')) return;
    var pw = document.getElementById('CroPW-{{ section.id }}');
    if (!pw || pw.dataset.noSub === 'true') return;
    if (pw.dataset.variantHasPlans !== '0') return; // already on a plan variant
    var varEl = document.querySelector('script[data-cst_variant="data"]');
    if (!varEl) return;
    try {
      var allVariants = JSON.parse(varEl.textContent);
      var planVariant = allVariants.find(function(v) {
        return v.available && v.selling_plan_allocations && v.selling_plan_allocations.length > 0;
      });
      if (!planVariant) return;
      var variantRadios = document.querySelector('variant-radios.cro-variant-row');
      if (!variantRadios) return;
      var radios = variantRadios.querySelectorAll('input[type="radio"]');
      planVariant.options.forEach(function(optVal) {
        var radio = Array.from(radios).find(function(r) { return r.value === optVal && !r.checked; });
        if (radio) {
          radio.checked = true;
          radio.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    } catch(e) {}
  }

  // ── Init on DOM ready ─────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    CroGallery('{{ section.id }}');
    CroStickyATC('{{ section.id }}');
    initScrollLinks();
    initReadMore('{{ section.id }}');
    autoSelectPlanVariant();
  });

  // Re-init on Shopify theme editor section reload
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === '{{ section.id }}') {
      CroGallery('{{ section.id }}');
      CroStickyATC('{{ section.id }}');
      initReadMore('{{ section.id }}');
    }
  });
})();
</script>

<script>
/* Fix: Bootstrap 5.0.x does NOT teleport modals to <body> when they have a parent
   element — the modal stays inside .cro-gallery (position:sticky stacking context),
   preventing it from painting above the right info panel. Move them manually. */
(function () {
  function teleportModals() {
    ['#nutrition-popup', '#custom-popup'].forEach(function (id) {
      var el = document.querySelector(id);
      if (el && el.parentElement !== document.body) {
        document.body.appendChild(el);
      }
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', teleportModals);
  } else {
    teleportModals();
  }
})();
</script>

