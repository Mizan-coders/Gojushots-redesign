{{ 'section-product-cro.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- comment -%} Per-product color tokens + section padding {%- endcomment -%}
{% style %}
  /* Per-product gallery bg driven by metafield */
  .cro-gallery__main-{{ section.id }} {
    background-color: {{ product.metafields.custom.primary_color | default: '#f3f3f3' }};
  }
  .cro-gallery__thumb-dot-{{ section.id }} {
    background-color: {{ product.metafields.custom.secondary_color | default: '#191917' }};
  }
  /* Section padding override */
  .cro-hero-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .cro-hero-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
  }
  {%- if section.settings.button_scheme == 'black' -%}
  #MainProduct-{{ section.id }} .cro-btn--primary {
    background: #191917;
  }
  #MainProduct-{{ section.id }} .cro-btn--primary:hover {
    background: #2d2d2b;
  }
  #MainProduct-{{ section.id }} .cro-pw__tog-btn.is-active {
    background: #191917;
    border-color: #191917;
  }
  #MainProduct-{{ section.id }} .cro-pw__freq-btn.is-active {
    background: #191917;
    border-color: #191917;
    color: #ffffff;
  }
  #MainProduct-{{ section.id }} .cro-sticky-atc__btn {
    background: #ffffff;
    color: #191917;
  }
  #MainProduct-{{ section.id }} .cro-sticky-atc__btn:hover {
    background: #e8e8e8;
    color: #191917;
  }
  {%- endif -%}
  {%- if section.settings.sticky_bg_color != blank and section.settings.sticky_bg_color != 'rgba(0,0,0,0)' -%}
  #CroStickyATC-{{ section.id }} {
    background: {{ section.settings.sticky_bg_color }};
  }
  {%- endif -%}
  {%- if section.settings.sticky_btn_color != blank and section.settings.sticky_btn_color != 'rgba(0,0,0,0)' -%}
  #CroStickyATC-{{ section.id }} .cro-sticky-atc__btn {
    background: {{ section.settings.sticky_btn_color }};
  }
  #CroStickyATC-{{ section.id }} .cro-sticky-atc__btn:hover:not(:disabled) {
    background: {{ section.settings.sticky_btn_color }};
    opacity: 0.88;
  }
  {%- endif -%}
  {%- if section.settings.sticky_btn_text_color != blank and section.settings.sticky_btn_text_color != 'rgba(0,0,0,0)' -%}
  #CroStickyATC-{{ section.id }} .cro-sticky-atc__btn {
    color: {{ section.settings.sticky_btn_text_color }};
  }
  {%- endif -%}
  /* Hide subscription UI instantly for no-plan variants — prevents flash before JS runs */
  .cro-pw[data-variant-has-plans="0"] .cro-pw__toggle,
  .cro-pw[data-variant-has-plans="0"] .cro-pw__perks,
  .cro-pw[data-variant-has-plans="0"] .cro-pw__freq,
  .cro-pw[data-variant-has-plans="0"] .cro-pw__cancel-note { display: none !important; }
{% endstyle %}

{%- assign product_form_id = 'product-form-cro-' | append: section.id -%}

<section
  class="pdp-cro cro-hero-section-{{ section.id }} shopify-section-main-product"
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="cro-container">
    <div class="cro-product-hero">

      {%- comment -%}═══════════════════════════════════════════
        LEFT PANEL — PRODUCT GALLERY
      ═══════════════════════════════════════════{%- endcomment -%}
      <div class="cro-gallery" id="CroGallery-{{ section.id }}">

        {%- comment -%} ── MAIN IMAGE AREA ── {%- endcomment -%}
        <div class="cro-gallery__main cro-gallery__main-{{ section.id }}">

          {%- comment -%} Best Seller / featured badge from product tags {%- endcomment -%}
          {%- if product.tags contains 'best-seller'
               or product.tags contains 'bestseller'
               or product.tags contains 'Best Seller'
               or product.tags contains 'BestSeller' -%}
            <span class="cro-gallery__badge cro-tag cro-tag--highlight">Best Seller</span>
          {%- elsif product.tags contains 'new'
                 or product.tags contains 'New'
                 or product.tags contains 'NEW' -%}
            <span class="cro-gallery__badge cro-tag cro-tag--dark">New</span>
          {%- endif -%}

          {%- comment -%} Main image slider — reuses existing snippet {%- endcomment -%}
          <div class="cro-gallery__slider-wrap">
            {%- if product.media.size > 0 -%}
              <div
                class="cro-gallery__slides"
                id="CroSlides-{{ section.id }}"
                aria-label="{{ 'products.modal.label' | t }}"
                tabindex="0"
              >
                {%- comment -%} Slide order: image[1] first, then image[0], then image[2+] {%- endcomment -%}
                {%- assign _slide_i = 0 -%}

                {%- comment -%} Slot 0 — image[1] (shown first on product page) {%- endcomment -%}
                {%- if product.media.size > 1 -%}
                  {%- assign _m = product.media[1] -%}
                  <div class="cro-gallery__slide is-active" data-index="0" aria-hidden="false">
                    {%- if _m.media_type == 'video' -%}
                      {{ _m | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping, controls: true, preload: 'none' }}
                    {%- elsif _m.media_type == 'external_video' -%}
                      {{ _m | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping }}
                    {%- else -%}
                      <img
                        srcset="{{ _m | img_url: '480x' }} 480w, {{ _m | img_url: '720x' }} 720w, {{ _m | img_url: '1080x' }} 1080w"
                        sizes="(min-width: 990px) 50vw, 100vw"
                        src="{{ _m | img_url: '720x' }}"
                        alt="{{ _m.alt | default: product.title | escape }}"
                        loading="eager"
                        width="{{ _m.preview_image.width }}"
                        height="{{ _m.preview_image.height }}"
                        data-media-id="{{ _m.id }}"
                      >
                    {%- endif -%}
                  </div>
                  {%- assign _slide_i = 1 -%}
                {%- endif -%}

                {%- comment -%} Slot 1 (or 0 if only 1 image) — original first image {%- endcomment -%}
                {%- assign _m = product.media[0] -%}
                <div class="cro-gallery__slide{% unless product.media.size > 1 %} is-active{% endunless %}" data-index="{{ _slide_i }}" aria-hidden="{% if product.media.size > 1 %}true{% else %}false{% endif %}">
                  {%- if _m.media_type == 'video' -%}
                    {{ _m | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping, controls: true, preload: 'none' }}
                  {%- elsif _m.media_type == 'external_video' -%}
                    {{ _m | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping }}
                  {%- else -%}
                    <img
                      srcset="{{ _m | img_url: '480x' }} 480w, {{ _m | img_url: '720x' }} 720w, {{ _m | img_url: '1080x' }} 1080w"
                      sizes="(min-width: 990px) 50vw, 100vw"
                      src="{{ _m | img_url: '720x' }}"
                      alt="{{ _m.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="{{ _m.preview_image.width }}"
                      height="{{ _m.preview_image.height }}"
                      data-media-id="{{ _m.id }}"
                    >
                  {%- endif -%}
                </div>
                {%- assign _slide_i = _slide_i | plus: 1 -%}

                {%- comment -%} Slots 2+ — remaining images from index 2 onwards {%- endcomment -%}
                {%- for media in product.media offset: 2 -%}
                  <div class="cro-gallery__slide" data-index="{{ _slide_i }}" aria-hidden="true">
                    {%- if media.media_type == 'video' -%}
                      {{ media | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping, controls: true, preload: 'none' }}
                    {%- elsif media.media_type == 'external_video' -%}
                      {{ media | media_tag: image_size: '900x', autoplay: false, loop: section.settings.enable_video_looping }}
                    {%- else -%}
                      <img
                        srcset="{{ media | img_url: '480x' }} 480w, {{ media | img_url: '720x' }} 720w, {{ media | img_url: '1080x' }} 1080w"
                        sizes="(min-width: 990px) 50vw, 100vw"
                        src="{{ media | img_url: '720x' }}"
                        alt="{{ media.alt | default: product.title | escape }}"
                        loading="lazy"
                        width="{{ media.preview_image.width }}"
                        height="{{ media.preview_image.height }}"
                        data-media-id="{{ media.id }}"
                      >
                    {%- endif -%}
                  </div>
                  {%- assign _slide_i = _slide_i | plus: 1 -%}
                {%- endfor -%}
              </div>

              {%- comment -%} Prev / Next arrows {%- endcomment -%}
              {%- if product.media.size > 1 -%}
                <button
                  class="cro-gallery__arrow cro-gallery__arrow--prev"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                  data-target="CroSlides-{{ section.id }}"
                  data-dir="-1"
                >
                  <svg width="9" height="16" viewBox="0 0 9 16" fill="none" aria-hidden="true">
                    <path d="M8 1L1 8L8 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <button
                  class="cro-gallery__arrow cro-gallery__arrow--next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                  data-target="CroSlides-{{ section.id }}"
                  data-dir="1"
                >
                  <svg width="9" height="16" viewBox="0 0 9 16" fill="none" aria-hidden="true">
                    <path d="M1 1L8 8L1 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              {%- endif -%}

            {%- else -%}
              {%- comment -%} No media fallback {%- endcomment -%}
              <div class="cro-gallery__slide is-active cro-gallery__no-media">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>{%- comment -%} /.cro-gallery__slider-wrap {%- endcomment -%}
        </div>{%- comment -%} /.cro-gallery__main {%- endcomment -%}

        {%- comment -%} ── THUMBNAIL STRIP ── {%- endcomment -%}
        {%- if product.media.size > 1 -%}
          <div class="cro-gallery__thumbs" id="CroThumbs-{{ section.id }}" role="tablist">
            {%- assign _ti = 0 -%}

            {%- comment -%} Thumb 0 — image[1] first {%- endcomment -%}
            {%- assign _m = product.media[1] -%}
            <button class="cro-gallery__thumb is-active" data-index="0" data-target="CroSlides-{{ section.id }}" role="tab" aria-selected="true" aria-label="{{ _m.alt | default: product.title | escape }}">
              <img src="{{ _m | img_url: '120x120', crop: 'center' }}" alt="{{ _m.alt | default: product.title | escape }}" loading="eager" width="120" height="120">
            </button>
            {%- assign _ti = 1 -%}

            {%- comment -%} Thumb 1 — original first image {%- endcomment -%}
            {%- assign _m = product.media[0] -%}
            <button class="cro-gallery__thumb" data-index="{{ _ti }}" data-target="CroSlides-{{ section.id }}" role="tab" aria-selected="false" aria-label="{{ _m.alt | default: product.title | escape }}">
              <img src="{{ _m | img_url: '120x120', crop: 'center' }}" alt="{{ _m.alt | default: product.title | escape }}" loading="lazy" width="120" height="120">
            </button>
            {%- assign _ti = 2 -%}

            {%- comment -%} Thumbs 2+ — remaining images {%- endcomment -%}
            {%- for media in product.media offset: 2 limit: 4 -%}
              <button class="cro-gallery__thumb" data-index="{{ _ti }}" data-target="CroSlides-{{ section.id }}" role="tab" aria-selected="false" aria-label="{{ media.alt | default: product.title | escape }}">
                <img src="{{ media | img_url: '120x120', crop: 'center' }}" alt="{{ media.alt | default: product.title | escape }}" loading="lazy" width="120" height="120">
              </button>
              {%- assign _ti = _ti | plus: 1 -%}
            {%- endfor -%}
          </div>
        {%- endif -%}


      </div>{%- comment -%} /.cro-gallery {%- endcomment -%}

      {%- comment -%}═══════════════════════════════════════════
        RIGHT PANEL — PURCHASE INFO
        (built out in Task 3)
      ═══════════════════════════════════════════{%- endcomment -%}
      <div
        class="cro-info-panel"
        id="CroInfoPanel-{{ section.id }}"
      >
        <div
          class="cro-info-panel__sticky"
          id="CroInfoSticky-{{ section.id }}"
        >

          {%- assign first_app_seen = false -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'text' -%}
                {%- comment -%} Product category pill badge {%- endcomment -%}
                {%- if product.metafields.custom.product_tagline != blank -%}
                  <div class="cro-info-panel__tagline" {{ block.shopify_attributes }}>
                    <span class="cro-product-badge">
                      {{- product.metafields.custom.product_tagline -}}
                    </span>
                  </div>
                {%- endif -%}

              {%- when 'title' -%}
                {%- comment -%} Split title: first word italic, rest bold {%- endcomment -%}
                {%- assign title_first = product.title | split: ' ' | first -%}
                {%- assign title_rest  = product.title | remove_first: title_first | lstrip -%}
                <div class="cro-info-panel__title" {{ block.shopify_attributes }}>
                  <h1 class="cro-heading cro-product-title">
                    <em>{{ title_first | escape }}</em>
                    {%- if title_rest != blank %} <strong>{{ title_rest | escape }}</strong>{%- endif -%}
                  </h1>
                  {%- if product.type != blank -%}
                    <p class="cro-product-type">{{ product.type }}</p>
                  {%- endif -%}
                </div>

              {%- when 'short_description' -%}
                {%- comment -%} Short description with Read More / Read Less toggle {%- endcomment -%}
                {%- assign short_desc = product.metafields.custom.custom_description -%}
                {%- if short_desc == blank -%}
                  {%- assign short_desc = product.description | strip_html | truncatewords: 30 -%}
                {%- endif -%}
                {%- if short_desc != blank -%}
                  <div class="cro-info-panel__short-desc" {{ block.shopify_attributes }}>
                    <p class="cro-short-desc">{{ short_desc }}</p>
                    {%- if product.description != blank -%}
                      <div class="cro-desc-full rte" id="CroDescFull-{{ section.id }}" aria-hidden="true">
                        {{ product.description }}
                      </div>
                      {%- unless block.settings.hide_read_more -%}
                      <button
                        class="cro-read-more-btn"
                        id="CroReadMoreBtn-{{ section.id }}"
                        aria-expanded="false"
                        aria-controls="CroDescFull-{{ section.id }}"
                        data-label="{{ block.settings.read_more_label | default: 'Read More' | escape }}"
                        type="button"
                      >
                        <span class="cro-read-more-btn__text">{{ block.settings.read_more_label | default: 'Read More' }}</span>
                        <svg class="cro-read-more-btn__icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                          <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                      {%- endunless -%}
                    {%- endif -%}
                  </div>
                {%- endif -%}

              {%- when 'benefit_pills' -%}
                {%- comment -%} Benefit pills — per-product metafields first, block settings as fallback {%- endcomment -%}
                {%- assign mf_p1t = product.metafields.cro.pill_1_text.value -%}
                {%- assign mf_p2t = product.metafields.cro.pill_2_text.value -%}
                {%- assign mf_p3t = product.metafields.cro.pill_3_text.value -%}
                {%- assign mf_p4t = product.metafields.cro.pill_4_text.value -%}
                {%- if mf_p1t != blank or mf_p2t != blank or mf_p3t != blank or mf_p4t != blank -%}
                  <div class="cro-benefit-pills" {{ block.shopify_attributes }}>
                    {%- if mf_p1t != blank -%}
                      <span class="cro-benefit-pill">
                        {%- assign mf_p1i = product.metafields.cro.pill_1_icon.value -%}
                        {%- if mf_p1i != blank -%}<span class="cro-benefit-pill__icon" aria-hidden="true">{{ mf_p1i }}</span>{%- endif -%}
                        {{ mf_p1t }}
                      </span>
                    {%- endif -%}
                    {%- if mf_p2t != blank -%}
                      <span class="cro-benefit-pill">
                        {%- assign mf_p2i = product.metafields.cro.pill_2_icon.value -%}
                        {%- if mf_p2i != blank -%}<span class="cro-benefit-pill__icon" aria-hidden="true">{{ mf_p2i }}</span>{%- endif -%}
                        {{ mf_p2t }}
                      </span>
                    {%- endif -%}
                    {%- if mf_p3t != blank -%}
                      <span class="cro-benefit-pill">
                        {%- assign mf_p3i = product.metafields.cro.pill_3_icon.value -%}
                        {%- if mf_p3i != blank -%}<span class="cro-benefit-pill__icon" aria-hidden="true">{{ mf_p3i }}</span>{%- endif -%}
                        {{ mf_p3t }}
                      </span>
                    {%- endif -%}
                    {%- if mf_p4t != blank -%}
                      <span class="cro-benefit-pill">
                        {%- assign mf_p4i = product.metafields.cro.pill_4_icon.value -%}
                        {%- if mf_p4i != blank -%}<span class="cro-benefit-pill__icon" aria-hidden="true">{{ mf_p4i }}</span>{%- endif -%}
                        {{ mf_p4t }}
                      </span>
                    {%- endif -%}
                  </div>
                {%- else -%}
                  {%- assign has_pill = false -%}
                  {%- if block.settings.pill_1_text != blank or block.settings.pill_2_text != blank
                       or block.settings.pill_3_text != blank or block.settings.pill_4_text != blank -%}
                    {%- assign has_pill = true -%}
                  {%- endif -%}
                  {%- if has_pill -%}
                    <div class="cro-benefit-pills" {{ block.shopify_attributes }}>
                      {%- for i in (1..4) -%}
                        {%- assign pill_icon = 'pill_' | append: i | append: '_icon' -%}
                        {%- assign pill_text = 'pill_' | append: i | append: '_text' -%}
                        {%- if block.settings[pill_text] != blank -%}
                          <span class="cro-benefit-pill">
                            {%- if block.settings[pill_icon] != blank -%}
                              <span class="cro-benefit-pill__icon" aria-hidden="true">{{ block.settings[pill_icon] }}</span>
                            {%- endif -%}
                            {{ block.settings[pill_text] }}
                          </span>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}

              {%- when '@app' -%}
                {%- unless first_app_seen -%}
                  <div class="cro-info-panel__app-block cro-review-inline-row" {{ block.shopify_attributes }}>
                    {% render block %}
                    <span class="cro-rating-verified">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M2 6L5 9L10 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      Verified
                    </span>
                  </div>
                  {%- assign first_app_seen = true -%}
                {%- else -%}
                  <div class="cro-info-panel__app-block" {{ block.shopify_attributes }}>
                    {% render block %}
                  </div>
                {%- endunless -%}

              {%- when 'price' -%}
                <div
                  class="cro-info-panel__price"
                  id="CroPrice-{{ section.id }}"
                  role="status"
                  {{ block.shopify_attributes }}
                >
                  {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' -%}

                  {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="cro-info-panel__tax caption rte">
                      {%- if shop.taxes_included -%}
                        {{ 'products.product.include_taxes' | t }}
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'variant_picker' -%}
                <div class="cro-info-panel__variants" {{ block.shopify_attributes }}>
                  {%- assign variant_label = block.settings.variant_label | default: 'Choose Pack Size' -%}
                  <span class="cro-label cro-label--section">{{ variant_label }}</span>

                  {%- unless product.has_only_default_variant -%}
                    {%- if block.settings.picker_type == 'button' -%}
                      <variant-radios
                        class="no-js-hidden cro-variant-row"
                        data-section="{{ section.id }}"
                        data-url="{{ product.url }}"
                      >
                        {%- for option in product.options_with_values -%}
                          <fieldset class="js product-form__input">
                            <legend class="cro-label">{{ option.name }}</legend>
                            <div class="cro-variant-row">
                              {%- for value in option.values -%}
                                <input
                                  type="radio"
                                  id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                  name="{{ option.name }}"
                                  value="{{ value | escape }}"
                                  form="{{ product_form_id }}"
                                  class="visually-hidden"
                                  {% if option.selected_value == value %}checked{% endif %}
                                >
                                <label
                                  for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                  class="cro-variant-btn{% if option.selected_value == value %} is-active{% endif %}"
                                >
                                  {{ value }}
                                </label>
                              {%- endfor -%}
                            </div>
                          </fieldset>
                        {%- endfor -%}
                        <script data-cst_variant="data" type="application/json">
                          {{ product.variants | json }}
                        </script>
                      </variant-radios>
                      {%- assign hint_has_plans = product.selected_or_first_available_variant.selling_plan_allocations.size | default: 0 -%}
                      {%- if product.tags contains 'no-subscription' -%}{%- assign hint_has_plans = 0 -%}{%- endif -%}
                      <p id="CroNoSubHint-{{ section.id }}" class="cro-variant-nosub-hint" {% if hint_has_plans > 0 %}hidden{% endif %}>{{ block.settings.nosub_hint | default: 'One-time purchase — subscribe & save on the 15 pack with free shipping always' }}</p>
                    {%- else -%}
                      <variant-selects
                        class="no-js-hidden"
                        data-section="{{ section.id }}"
                        data-url="{{ product.url }}"
                      >
                        {%- for option in product.options_with_values -%}
                          <div class="product-form__input product-form__input--dropdown">
                            <label class="cro-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                              {{ option.name }}
                            </label>
                            <div class="select">
                              <select
                                id="Option-{{ section.id }}-{{ forloop.index0 }}"
                                class="select__select"
                                name="options[{{ option.name | escape }}]"
                                form="{{ product_form_id }}"
                              >
                                {%- for value in option.values -%}
                                  <option
                                    value="{{ value | escape }}"
                                    {% if option.selected_value == value %}selected="selected"{% endif %}
                                  >{{ value }}</option>
                                {%- endfor -%}
                              </select>
                              {% render 'icon-caret' %}
                            </div>
                          </div>
                        {%- endfor -%}
