                        {%- if block.settings[icon_key] != blank -%}
                          <span class="cro-mini-trust-icon" aria-hidden="true">{{ block.settings[icon_key] }}</span>
                        {%- endif -%}
                        <span>{{ block.settings[text_key] }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
