{{ 'section-product-cro.css' | asset_url | stylesheet_tag }}

{% style %}
  .crosssell-cro-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .crosssell-cro-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }
  }
{% endstyle %}

<section
  class="pdp-cro crosssell-cro-{{ section.id }}"
  id="crosssell-cro-{{ section.id }}"
>
  <div class="cro-container">

    {%- comment -%} Section header {%- endcomment -%}
    <div class="cro-section-header cro-fade-up">
      {%- if section.settings.heading != blank -%}
        <h2 class="cro-heading cro-crosssell__heading">
          {%- if section.settings.heading_accent != blank -%}
            {%- assign accent = section.settings.heading_accent -%}
            {%- assign plain  = section.settings.heading | remove: accent -%}
            {{ plain }}<em>{{ accent }}</em>
          {%- else -%}
            {{ section.settings.heading }}
          {%- endif -%}
        </h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="cro-crosssell__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Product grid from featured collections {%- endcomment -%}
    <div class="cro-crosssell-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'featured_collection' -%}
          {%- assign col = collections[block.settings.collection] -%}
          {%- if col != blank -%}
            {%- assign limit = block.settings.product_limit | default: 4 -%}
            {%- for product in col.products limit: limit -%}
              {%- assign delay_i = forloop.index -%}
              <div class="cro-crosssell-card cro-fade-up delay-{{ delay_i }}" {{ block.shopify_attributes }}>
                <a href="{{ product.url }}" class="cro-crosssell-card__img-link">
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                      alt="{{ product.featured_image.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'cro-crosssell-card__placeholder-svg' }}
                  {%- endif -%}
                </a>

                <div class="cro-crosssell-card__body">
                  <a href="{{ product.url }}" class="cro-crosssell-card__title">{{ product.title }}</a>
                  <div class="cro-crosssell-card__price-row">
                    <span class="cro-crosssell-card__price">{{ product.price | money }}</span>
                    {%- if product.compare_at_price > product.price -%}
                      <s class="cro-crosssell-card__compare">{{ product.compare_at_price | money }}</s>
                    {%- endif -%}
                  </div>
                  <form action="/cart/add" method="post" class="cro-crosssell-card__form">
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button
                      type="submit"
                      class="cro-btn cro-btn--outline cro-crosssell-card__atc"
                      {%- unless product.available %} disabled{% endunless %}
                    >
                      {%- if product.available -%}
                        Add to cart
                      {%- else -%}
                        Sold out
                      {%- endif -%}
                    </button>
                  </form>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  var section = document.getElementById('crosssell-cro-{{ section.id }}');
  if (!section) return;

  var items = section.querySelectorAll('.cro-fade-up');
  if (!items.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });

    items.forEach(function (el) { observer.observe(el); });
  } else {
    items.forEach(function (el) { el.classList.add('is-visible'); });
  }

  /* Inline ATC — AJAX cart add */
  section.addEventListener('submit', function (e) {
    var form = e.target.closest('.cro-crosssell-card__form');
    if (!form) return;
    e.preventDefault();

    var btn = form.querySelector('.cro-crosssell-card__atc');
    if (!btn || btn.disabled) return;

    var originalText = btn.textContent.trim();
    btn.disabled = true;
    btn.textContent = 'Adding…';

    var data = new FormData(form);
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: data.get('id'), quantity: parseInt(data.get('quantity'), 10) })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btn.textContent = '✓ Added';
      document.dispatchEvent(new CustomEvent('cart:updated'));
      setTimeout(function () {
        btn.textContent = originalText;
        btn.disabled = false;
      }, 2000);
    })
    .catch(function () {
      btn.textContent = originalText;
      btn.disabled = false;
    });
  });
})();
</script>

{% schema %}
{
  "name": "Cross-sell CRO",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "featured_collection",
      "name": "Featured Collection",
      "limit": 3,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "product_limit",
          "label": "Max products to show",
          "min": 2, "max": 8, "step": 1,
          "default": 4
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete your Wellness Routine"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent word(s) in heading",
      "default": "Wellness Routine",
      "info": "These exact words will be highlighted in accent colour"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Customers who buy this also love these"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Cross-sell CRO"
    }
  ]
}
{% endschema %}
