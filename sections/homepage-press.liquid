{%- style -%}
  .press-{{ section.id }} {
    background: {{ section.settings.bg_color | default: 'var(--goju-page-bg, #f5f0e8)' }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: 40px;
    padding-right: 40px;
  }
  @media screen and (min-width: 750px) {
    .press-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .press-{{ section.id }} .press__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Label row ── */
  .press-{{ section.id }} .press__label-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .press-{{ section.id }} .press__label-line {
    flex: 1;
    height: 1px;
    background: rgba(0,0,0,0.15);
  }
  .press-{{ section.id }} .press__label {
    font-size: {{ section.settings.label_size | default: 11 }}px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.label_color | default: '#666666' }};
    white-space: nowrap;
  }

  /* ── Logo grid ── */
  .press-{{ section.id }} .press__logos {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 40px 60px;
  }
  .press-{{ section.id }} .press__logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .press-{{ section.id }} .press__logo-img {
    height: 80px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* Mobile */
  @media screen and (max-width: 767px) {
    .press-{{ section.id }} {
      padding-left: 20px;
      padding-right: 20px;
    }
    .press-{{ section.id }} .press__logos {
      gap: 28px 40px;
    }
  }
{%- endstyle -%}

<section class="press-{{ section.id }}">
  <div class="press__inner">

    <div class="press__label-row">
      <span class="press__label-line"></span>
      <span class="press__label">{{ section.settings.label_text | default: 'As Seen In' | escape }}</span>
      <span class="press__label-line"></span>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="press__logos">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' and block.settings.logo != blank -%}
            {%- assign logo_img = block.settings.logo -%}
            {%- assign logo_alt = block.settings.logo_alt | default: section.settings.label_text | default: 'Press logo' -%}
            <div class="press__logo-item" {{ block.shopify_attributes }}>
              {%- if block.settings.logo_url != blank -%}
                <a href="{{ block.settings.logo_url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ logo_alt | escape }}">
                  <img
                    src="{{ logo_img | image_url: width: 300 }}"
                    alt="{{ logo_alt | escape }}"
                    class="press__logo-img"
                    width="150"
                    height="80"
                    loading="lazy"
                  >
                </a>
              {%- else -%}
                <img
                  src="{{ logo_img | image_url: width: 300 }}"
                  alt="{{ logo_alt | escape }}"
                  class="press__logo-img"
                  width="150"
                  height="56"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Press / As Seen In",
  "settings": [
    {
      "type": "text",
      "id": "label_text",
      "label": "Label text",
      "default": "As Seen In"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label text colour",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#f5f0e8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Press logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "logo_url",
          "label": "Link URL (optional)"
        },
        {
          "type": "text",
          "id": "logo_alt",
          "label": "Alt text",
          "info": "Describe the publication name for accessibility"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Press / As Seen In"
    }
  ]
}
{% endschema %}
